    "grammar": {
      "title": "단위명사",
      "title_en": "Counting Words",
      "explanation": "한국어에서는 세는 것에 따라 다른 단위명사를 써요!",
      "explanation_en": "In Korean, different counting words are used depending on what you're counting!",
      "rule_boxes": [
        {
          "color": "red",
          "label": "하나, 둘, 셋, 넷 → 단위명사 앞에서 바뀌어요!",
          "label_en": "하나, 둘, 셋, 넷 change their form before a counter!",
          "examples": [
            "하나 → 한 살  (one year old)",
            "둘 → 두 사람  (two people)",
            "셋 → 세 마리  (three animals)",
            "넷 → 네 개  (four things)"
          ]
        },
        {
          "color": "blue",
          "label": "다섯, 여섯, 일곱... 은 그대로!",
          "label_en": "다섯, 여섯, 일곱... stay the same!",
          "examples": [
            "다섯 대  (five vehicles)",
            "여섯 잔  (six glasses)",
            "일곱 송이  (seven flowers)"
          ]
        },
        {
          "color": "green",
          "label": "순서: 명사 + 숫자 + 단위명사",
          "label_en": "Order: noun  +  number  +  counter",
          "examples": [
            "사과 네 개  (four apples)",
            "우유 여섯 잔  (six glasses of milk)",
            "장미 일곱 송이  (seven roses)"
          ]
        }
      ]
    },
