    "grammar": {
      "sections": [
        {
          "id": "g05_aniéyo",
          "title": "N이/가 아니에요",
          "subtitle": "Negative form of 예요/이에요",
          "pattern": "Consonant ending → 이 아니에요 / Vowel ending → 가 아니에요",
          "meaning": "it is not ~",
          "description": "아니에요 is the negative form of 예요/이에요. The same consonant/vowel rule applies: use 이 after a consonant-ending noun, 가 after a vowel-ending noun.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "Consonant ending → 이 아니에요",
              "examples": [
                "안경 → 안경이 아니에요 (ends in ㅇ)",
                "양말 → 양말이 아니에요 (ends in ㄹ)"
              ]
            },
            {
              "color": "blue",
              "label": "Vowel ending → 가 아니에요",
              "examples": [
                "치마 → 치마가 아니에요 (ends in ㅏ)",
                "구두 → 구두가 아니에요 (ends in ㅜ)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "이게 치마예요?",
              "english": "Is this a skirt?",
              "highlight": "예요"
            },
            {
              "korean": "네, 치마예요.",
              "english": "Yes, it's a skirt.",
              "highlight": "예요"
            },
            {
              "korean": "저게 모자예요?",
              "english": "Is that a hat?",
              "highlight": "예요"
            },
            {
              "korean": "아니요, 모자가 아니에요.",
              "english": "No, it's not a hat.",
              "highlight": "가 아니에요"
            },
            {
              "korean": "안경이 아니에요. 양말이에요.",
              "english": "It's not glasses. It's socks.",
              "highlight": "이 아니에요"
            },
            {
              "korean": "구두가 아니에요. 운동화예요.",
              "english": "It's not dress shoes. It's sneakers.",
              "highlight": "가 아니에요"
            }
          ],
          "qna": [
            {
              "question": "이게 구두예요?",
              "answer": "아니요, 구두가 아니에요. 운동화예요."
            },
            {
              "question": "이게 안경이에요?",
              "answer": "아니요, 안경이 아니에요. 양말이에요."
            },
            {
              "question": "저게 치마예요?",
              "answer": "아니요, 치마가 아니에요. 바지예요."
            },
            {
              "question": "이게 양말이에요?",
              "answer": "네, 양말이에요."
            }
          ]
        },
        {
          "id": "g05_e_location",
          "title": "_에 — Location Particle",
          "subtitle": "Where something is / going to",
          "pattern": "Place + 에",
          "meaning": "at / in / to (location)",
          "description": "에 marks where something exists (있어요) or where you are going (가요). 에서 is for where actions happen.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "📍 N에 있어요 — existence",
              "examples": [
                "동물원에 있어요. = (It) is at the zoo.",
                "호랑이가 우리에 있어요. = The tiger is in the cage."
              ]
            },
            {
              "color": "green",
              "label": "🚶 N에 가요 — direction",
              "examples": [
                "동물원에 가요. = We go to the zoo.",
                "학교에 가요. = I go to school."
              ]
            },
            {
              "color": "red",
              "label": "🏃 N에서 뭐해요? — activity",
              "examples": [
                "동물원에서 동물을 봐요.",
                "공원에서 뛰어요."
              ]
            }
          ],
          "examples": [
            {
              "korean": "동물원에 가요.",
              "english": "We go to the zoo.",
              "highlight": "에"
            },
            {
              "korean": "표범은 우리에 있어요.",
              "english": "The leopard is in the cage.",
              "highlight": "에"
            },
            {
              "korean": "동물원에서 사자를 봐요.",
              "english": "We see lions at the zoo.",
              "highlight": "에서"
            }
          ]
        },
        {
          "id": "g05_iga_euneun",
          "title": "이/가 vs 은/는",
          "subtitle": "Subject vs. Topic Marker",
          "pattern": "N이/가 (subject) · N은/는 (topic)",
          "meaning": "Subject marker vs. Topic marker",
          "description": "이/가 marks the grammatical subject. 은/는 marks the topic — used for contrast or general statements.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "📌 이/가 — subject (new info)",
              "examples": [
                "호랑이가 무서워요. = Tigers are scary.",
                "강아지가 자요. = The dog sleeps."
              ]
            },
            {
              "color": "green",
              "label": "📌 은/는 — topic (contrast)",
              "examples": [
                "표범은 빨라요. = Leopards are fast.",
                "사자는 커요. = Lions are big."
              ]
            }
          ],
          "examples": [
            {
              "korean": "호랑이가 무서워요.",
              "english": "Tigers are scary.",
              "highlight": "가"
            },
            {
              "korean": "표범은 빨라요.",
              "english": "Leopards are fast.",
              "highlight": "은"
            },
            {
              "korean": "사자는 커요.",
              "english": "Lions are big.",
              "highlight": "는"
            }
          ]
        }
      ]
    },
