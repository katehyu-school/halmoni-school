          "id": "g02_hago",
          "title": "하고",
          "subtitle": "두 장소나 사람을 연결해요",
          "pattern": "명사 + 하고 + 명사",
          "meaning": "and (connecting two nouns)",
          "examples": [
            {
              "korean": "놀이터하고 공원에 가요.",
              "english": "I go to the playground and the park.",
              "highlight": "하고"
            },
            {
              "korean": "친구하고 수영장에 가요.",
              "english": "I go to the swimming pool with my friend.",
              "highlight": "하고"
            },
            {
              "korean": "엄마하고 집에 있어요.",
              "english": "I am at home with Mom.",
              "highlight": "하고"
            }
          ],
          "qna": [
            {
              "question": "누구하고 가요?",
              "answer": "친구하고 가요."
            },
            {
              "question": "어디하고 어디에 가요?",
              "answer": "놀이터하고 공원에 가요."
            }
          ]
        },
        {
          "id": "g02_eunneun",
          "title": "은/는",
          "subtitle": "이야기의 주제를 표시해요",
          "pattern": "받침 O → 은 / 받침 X → 는",
          "meaning": "topic marker (as for ~)",
          "examples": [
            {
              "korean": "저는 공원에 가요.",
              "english": "As for me, I go to the park.",
              "highlight": "는"
            },
            {
              "korean": "친구는 수영장에 가요.",
              "english": "As for my friend, they go to the pool.",
              "highlight": "는"
            },
            {
              "korean": "선생님은 교실에 있어요.",
              "english": "As for the teacher, they are in the classroom.",
              "highlight": "은"
            }
          ],
          "qna": [
            {
              "question": "어디에 가요?",
              "answer": "저는 놀이터에 가요."
