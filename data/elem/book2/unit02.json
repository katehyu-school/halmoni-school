    "grammar": {
      "sections": [
        {
          "id": "g02_hago",
          "title": "하고",
          "subtitle": "Connects two people or places",
          "pattern": "Noun + 하고 + Noun",
          "meaning": "and (connecting two nouns)",
          "pattern_box": "[Person A] <span style='color:var(--coral);font-size:1.2rem;'>하고</span> [Person B]",
          "pairs": [
            {"korean": "할아버지하고 할머니", "english": "Grandpa and Grandma", "highlight": "하고"},
            {"korean": "엄마하고 아빠", "english": "Mom and Dad", "highlight": "하고"},
            {"korean": "리아하고 애라", "english": "Lia and Aera", "highlight": "하고"},
            {"korean": "리암하고 카요", "english": "Liam and Kayo", "highlight": "하고"},
            {"korean": "고양이하고 강아지", "english": "Cat and Dog", "highlight": "하고"}
          ],
          "examples": [
            {
              "korean": "형하고 나는 공원에 가요.",
              "english": "My brother and I go to the park.",
              "highlight": "하고"
            },
            {
              "korean": "친구하고 나는 수영장에 가요.",
              "english": "I go to the swimming pool with my friend.",
              "highlight": "하고"
            },
            {
              "korean": "엄마하고 나는 집에 있어요.",
              "english": "I am at home with Mom.",
              "highlight": "하고"
            }
          ],
          "qna": [
            {
              "question": "누구하고 가요?",
              "answer": "친구하고 가요."
            },
            {
              "question": "어디하고 어디에 가요?",
              "answer": "놀이터하고 공원에 가요."
            }
          ]
        },
        {
          "id": "g02_eunneun",
          "title": "은/는",
          "subtitle": "Marks the topic of the sentence",
          "pattern": "Consonant ending → 은 / Vowel ending → 는",
          "meaning": "topic marker (as for ~)",
          "rule_boxes": [
            {
              "color": "red",
              "label": "Consonant ending → 은",
              "examples": ["동생 → 동생은 (ends in ㅇ)", "선생님 → 선생님은 (ends in ㅁ)"]
            },
            {
              "color": "blue",
              "label": "Vowel ending → 는",
              "examples": ["엄마 → 엄마는 (ends in ㅏ)", "저 → 저는 (ends in ㅓ)", "친구 → 친구는 (ends in ㅜ)"]
            }
          ],
          "examples": [
            {
              "korean": "저는 공원에 가요.",
              "english": "As for me, I go to the park.",
              "highlight": "는"
            },
            {
              "korean": "친구는 수영장에 가요.",
              "english": "As for my friend, they go to the pool.",
              "highlight": "는"
            },
            {
              "korean": "선생님은 교실에 있어요.",
              "english": "As for the teacher, they are in the classroom.",
              "highlight": "은"
            }
          ],
          "qna": [
            {
              "question": "어디에 가요?",
              "answer": "저는 놀이터에 가요."
            },
            {
              "question": "친구는 어디에 가요?",
              "answer": "친구는 운동장에 가요."
            }
          ]
        }
      ]
    },
