    "grammar": {
      "sections": [
        {
          "id": "g04_future",
          "title": "(ㄹ/을) 거예요 — 미래형",
          "subtitle": "Talking about future plans",
          "pattern": "동사 stem + (ㄹ/을) 거예요",
          "meaning": "will ~ / going to ~",
          "description": "(ㄹ/을) 거예요 is how you talk about future plans in Korean. If the stem ends in a vowel, add ㄹ 거예요. If it ends in a consonant, add 을 거예요.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 모음 끝 stem + ㄹ 거예요",
              "examples": [
                "놀다 → 놀 거예요 (will play)",
                "쉬다 → 쉴 거예요 (will rest)",
                "팔다 → 팔 거예요 (will sell)"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 자음 끝 stem + 을 거예요",
              "examples": [
                "먹다 → 먹을 거예요 (will eat)",
                "읽다 → 읽을 거예요 (will read)",
                "씻다 → 씻을 거예요 (will wash)"
              ]
            }
          ],
          "examples": [
            { "korean": "조이랑 같이 놀 거예요.",   "english": "I'm going to play with Zoe.",          "highlight": "놀 거예요" },
            { "korean": "일요일에는 쉴 거예요.",     "english": "I'm going to rest on Sunday.",         "highlight": "쉴 거예요" },
            { "korean": "내일 뭐 할 거예요?",        "english": "What are you going to do tomorrow?",  "highlight": "할 거예요" }
          ]
        },
        {
          "id": "g04_day_event",
          "title": "요일 + 에 있어요 — 일정 말하기",
          "subtitle": "Saying when an event is",
          "pattern": "요일 + 에 + 행사/일정 + 있어요",
          "meaning": "There is [event] on [day]",
          "description": "Use 요일 + 에 to say when something happens. 있어요 after an event means 'it's on that day / it's happening'.",
          "rule_boxes": [
            {
              "color": "green",
              "label": "🟢 요일 + 에 있어요",
              "examples": [
                "토요일에 결승전이 있어요. = There is a final on Saturday.",
                "월요일에 시험이 있어요. = There is a test on Monday.",
                "금요일에 파티가 있어요. = There is a party on Friday."
              ]
            }
          ],
          "examples": [
            { "korean": "이번 토요일에 배구 결승전이 있어요.", "english": "There is a volleyball final this Saturday.", "highlight": "토요일에 있어요" },
            { "korean": "수요일에 수업이 있어요.",             "english": "There is class on Wednesday.",             "highlight": "수요일에 있어요" }
          ]
        }
      ]
    },
    "practice": {
