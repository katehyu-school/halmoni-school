  "book": 3,
  "goal": {
    "ko": "요일과 미래 계획을 말할 수 있어요! 📅",
    "en": "I can talk about days and future plans!"
  },
  "key_points": [
    "요일 — days of the week",
    "N에 있어요 — event on a day",
    "~(ㄹ) 거예요 — future tense (will / going to)"
  ],
  "sections": {
    "vocab": {
