            { "speaker": "리아", "color": "teal",  "text": "일요일에는 ___ 거예요.",              "en": "I'm going to rest on Sunday.",                      "type": "fill", "ans": "쉴", "opts": ["쉴","먹을","갈"] },
            { "speaker": "엄마", "color": "coral", "text": "잘 쉬어! 고생했어~",                  "en": "Rest well! You've worked hard~",                    "type": "given" }
