    "grammar": {
      "sections": [
        {
          "id": "g08_deo",
          "title": "더 + 형용사 — 더 예뻐요",
          "subtitle": "More ~ / ~er (comparison)",
          "pattern": "더 + 형용사",
          "meaning": "More ~ / ~er",
          "description": "Put 더 before an adjective to say something is 'more' of that quality. It's like '-er' in English (bigger, prettier, cooler). You can also use 보다 to say 'more than something'.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 더 + 형용사 = more ~",
              "examples": [
                "더 예뻐요. (It's prettier.)",
                "더 멋있어요. (It's cooler.)",
                "더 커요. (It's bigger.)",
                "더 좋아요. (It's better.)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 A가 B보다 더 + 형용사 = A is more ~ than B",
              "examples": [
                "제 글씨가 더 예뻐요. (My handwriting is prettier.)",
                "사과가 바나나보다 더 좋아요. (I like apples more than bananas.)",
                "오늘이 어제보다 더 추워요. (Today is colder than yesterday.)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 Tip — 더 잘 vs 더 예뻐요",
              "examples": [
                "더 잘 써요. → more skillfully (더 + adverb 잘)",
                "더 예뻐요. → prettier (더 + adjective 예쁘다)",
                "Both are natural! 더 works with both."
              ]
            }
          ],
          "examples": [
            {
              "korean": "제 글씨가 더 예뻐요!",
              "english": "My handwriting is prettier!",
              "highlight": "더 예뻐요"
            },
            {
              "korean": "이게 저것보다 더 멋있어요.",
              "english": "This is cooler than that.",
              "highlight": "더 멋있어요"
            },
            {
              "korean": "오늘이 더 추워요.",
              "english": "Today is colder.",
              "highlight": "더 추워요"
            }
          ]
        },
        {
          "id": "g08_jeil",
          "title": "제일 + 형용사 — 제일 멋있어!",
          "subtitle": "The most ~ / ~est (superlative)",
          "pattern": "제일 + 형용사 / (N 중에) 제일 + 형용사",
          "meaning": "The most ~ / ~est",
          "description": "Put 제일 before an adjective to say something is 'the most' of that quality. You can add N 중에 (among N) to say 'the most among ~'.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 제일 + 형용사 = the most ~",
              "examples": [
                "제일 예뻐요. (It's the prettiest.)",
                "제일 멋있어요. (It's the coolest.)",
                "제일 좋아요. (It's the best.)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 N 중에 제일 + 형용사 = the most ~ among N",
              "examples": [
                "셋 중에 제일 멋있어! (The coolest among the three!)",
                "우리 반에서 제일 키가 커요. (The tallest in our class.)",
                "이 케이크가 제일 맛있어요! (This cake is the most delicious!)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 더 vs 제일",
              "examples": [
                "더 예뻐요. → prettier (comparing two things)",
                "제일 예뻐요. → the prettiest (out of everything)",
                "Think: more vs the most!"
              ]
            }
          ],
          "examples": [
            {
              "korean": "셋 중에 제일 멋있어! 최고야!",
              "english": "The coolest among the three! The best!",
              "highlight": "제일 멋있어"
            },
            {
              "korean": "이 음식이 제일 맛있어요.",
              "english": "This food is the most delicious.",
              "highlight": "제일 맛있어요"
            },
            {
              "korean": "수학이 제일 어려워요.",
              "english": "Math is the most difficult.",
              "highlight": "제일 어려워요"
            }
          ]
        }
      ]
    },
