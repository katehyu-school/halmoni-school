    "grammar": {
      "sections": [
        {
          "id": "g01_mari_counter",
          "title": "마리 — 동물 세는 단위",
          "subtitle": "Counter word for animals",
          "pattern": "숫자(관형형) + 마리",
          "meaning": "number of animals",
          "description": "In Korean, when counting animals, use '마리' after the number. The number changes shape slightly when it comes before a counter: 하나→한, 둘→두, 셋→세, 넷→네.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 하나/둘/셋/넷 → 한/두/세/네 (단위 앞에서!)",
              "examples": [
                "하나 → 한 마리 (one animal)",
                "둘 → 두 마리 (two animals)",
                "셋 → 세 마리 (three animals)",
                "넷 → 네 마리 (four animals)"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 다섯부터는 그대로!",
              "examples": [
                "다섯 마리 (five animals)",
                "여섯 마리 (six animals)",
                "일곱 마리 (seven animals)"
              ]
            }
          ],
          "examples": [
            { "korean": "곰이 세 마리 있어요.",    "english": "There are three bears.",      "highlight": "세 마리" },
            { "korean": "토끼가 두 마리예요.",      "english": "There are two rabbits.",      "highlight": "두 마리" },
            { "korean": "물고기가 몇 마리예요?",    "english": "How many fish are there?",    "highlight": "몇 마리" }
          ]
        },
        {
          "id": "g01_counting_pattern",
          "title": "몇 + 단위명사예요? — 묻기",
          "subtitle": "Asking 'how many?'",
          "pattern": "몇 + 단위명사 + 예요/이에요?",
          "meaning": "How many ~?",
          "description": "Use '몇' (how many) + a counter word to ask quantities. '몇 마리예요?' = How many animals are there?",
          "rule_boxes": [
            {
              "color": "green",
              "label": "🟢 몇 + 단위명사",
              "examples": [
                "몇 마리예요? = How many animals?",
                "몇 개예요? = How many pieces?",
                "몇 명이에요? = How many people?"
              ]
            }
          ],
          "examples": [
            { "korean": "코끼리가 몇 마리예요?", "english": "How many elephants are there?", "highlight": "몇 마리" },
            { "korean": "네 마리예요.",           "english": "There are four.",               "highlight": "네 마리" }
          ]
        }
      ]
    },
    "practice": {
