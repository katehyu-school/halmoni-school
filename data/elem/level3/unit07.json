{
  "unit": 7,
  "title": "저녁 노을을 보면서 라면을 먹고 싶어요",
  "book": 3,
  "goal": {
    "ko": "원하는 것과 해야 하는 것을 말할 수 있어요! 🌅",
    "en": "I can say what I want to do and what I have to do!"
  },
  "key_points": [
    "-고 싶어요 / -고 싶었어요 — I want / I wanted to ~",
    "-고 싶지 않아요 — I don't want to ~",
    "-아야/어야 해요 — I have to / must ~",
    "-면서 — while doing ~ (at the same time)"
  ],
  "sections": {
    "vocab": {
      "🌅 풍경 & 감탄 Scenery & Exclamations": [
        { "emoji": "🌅", "kr": "저녁 노을", "en": "evening glow / sunset", "rom": "jeo-nyeok no-eul" },
        { "emoji": "✨", "kr": "근사해요", "en": "wonderful / magnificent", "rom": "geun-sa-hae-yo" },
        { "emoji": "😎", "kr": "멋져요", "en": "awesome / cool", "rom": "meot-jyeo-yo" },
        { "emoji": "🌸", "kr": "아름다워요", "en": "beautiful", "rom": "a-reum-da-wo-yo" },
        { "emoji": "😄", "kr": "재미있어요", "en": "fun / interesting", "rom": "jae-mi-i-sseo-yo" }
      ],
      "😊 감정 Feelings": [
        { "emoji": "😢", "kr": "속상해요", "en": "upset / disappointed", "rom": "sok-sang-hae-yo" },
