      ]
    },
    "grammar": {
      "sections": [
        {
          "id": "g07_gosipo",
          "title": "-고 싶어요 심화 — 더 많이 표현해봐요!",
          "subtitle": "Want / Wanted / Don't want",
          "pattern": "동사 stem + 고 싶어요 / 고 싶었어요 / 고 싶지 않아요",
          "meaning": "I want to ~ / I wanted to ~ / I don't want to ~",
          "description": "You already know -고 싶어요 (I want to)! Now let's learn the past tense and negative. These three together let you express all your wishes and feelings!",
          "rule_boxes": [
            {
              "color": "teal",
              "label": "🟢 현재 — 지금 원해요 (I want now)",
              "examples": [
                "라면을 먹고 싶어요. (I want to eat ramen.)",
                "노을을 보고 싶어요. (I want to see the sunset.)",
                "자고 싶어요. (I want to sleep.)"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 과거 — 그때 원했어요 (I wanted then)",
              "examples": [
                "라면을 먹고 싶었어요. (I wanted to eat ramen.)",
                "집에 가고 싶었어요. (I wanted to go home.)",
                "울고 싶었어요. (I wanted to cry.)"
              ]
            },
            {
              "color": "red",
              "label": "🔴 부정 — 원하지 않아요 (I don't want)",
              "examples": [
                "나눠 먹고 싶지 않아요. (I don't want to share.)",
                "가고 싶지 않아요. (I don't want to go.)",
                "하고 싶지 않아요. (I don't want to do it.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "나는 노을을 보면서 라면을 먹고 싶었어요.",
              "english": "I wanted to eat ramen while watching the sunset.",
              "highlight": "먹고 싶었어요"
            },
            {
              "korean": "나눠 먹고 싶지 않아요!",
              "english": "I don't want to share!",
              "highlight": "싶지 않아요"
            },
            {
              "korean": "방에서 쉬고 싶어요.",
              "english": "I want to rest in my room.",
              "highlight": "쉬고 싶어요"
            }
          ]
        },
        {
          "id": "g07_ayahaeyo",
          "title": "-아야/어야 해요 — 먹어야 해요!",
          "subtitle": "Have to / Must do something",
          "pattern": "동사 stem + 아야 해요 / 어야 해요",
          "meaning": "Have to ~ / Must ~",
          "description": "To say you HAVE TO do something, use -아야 해요 or -어야 해요. Rule: if the last vowel in the stem is ㅏ or ㅗ, use -아야 해요. For all others, use -어야 해요. 하다 → 해야 해요 (special!).",
          "rule_boxes": [
            {
              "color": "orange",
              "label": "🟠 ㅏ / ㅗ 끝 → 아야 해요",
              "examples": [
                "가다 → 가야 해요 (have to go)",
                "오다 → 와야 해요 (have to come)",
                "자다 → 자야 해요 (have to sleep)"
              ]
            },
            {
              "color": "purple",
              "label": "🟣 그 외 → 어야 해요",
              "examples": [
                "먹다 → 먹어야 해요 (have to eat)",
                "읽다 → 읽어야 해요 (have to read)",
                "쓰다 → 써야 해요 (have to write)"
              ]
            },
            {
              "color": "teal",
              "label": "⭐ 하다 → 해야 해요 (special!)",
              "examples": [
                "공부하다 → 공부해야 해요 (have to study)",
                "운동하다 → 운동해야 해요 (have to exercise)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "라면은 한 사람이 하나를 다 먹어야 해요.",
              "english": "Each person has to eat one whole ramen.",
              "highlight": "먹어야 해요"
            },
            {
              "korean": "학교에 가야 해요.",
              "english": "I have to go to school.",
              "highlight": "가야 해요"
            },
            {
              "korean": "숙제를 해야 해요.",
              "english": "I have to do my homework.",
              "highlight": "해야 해요"
            }
          ]
        },
        {
          "id": "g07_myunseo",
          "title": "-면서 — 보면서 먹어요!",
          "subtitle": "While doing ~ / At the same time",
          "pattern": "동사 stem + (으)면서",
          "meaning": "While doing ~ (two actions at the same time)",
          "description": "Use -면서 to describe two things happening at the same time. The first action (with -면서) is the background, and the second is the main action. Like 'while' in English!",
          "rule_boxes": [
            {
              "color": "teal",
              "label": "🟢 받침 없음 / ㄹ → 면서",
              "examples": [
                "보다 → 보면서 (while watching)",
                "가다 → 가면서 (while going)",
                "만들다 → 만들면서 (while making)"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 받침 있음 → 으면서",
              "examples": [
                "먹다 → 먹으면서 (while eating)",
                "읽다 → 읽으면서 (while reading)",
                "듣다 → 들으면서 (while listening — ㄷ 불규칙!)"
              ]
            },
            {
              "color": "orange",
              "label": "🟠 패턴: [action 1]-면서 + [action 2]",
              "examples": [
                "노을을 보면서 라면을 먹어요. (I eat ramen while watching the sunset.)",
                "음악을 들으면서 공부해요. (I study while listening to music.)",
                "걸으면서 이야기해요. (We talk while walking.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "나는 노을을 보면서 라면을 먹고 싶었어요.",
              "english": "I wanted to eat ramen while watching the sunset.",
              "highlight": "보면서"
            },
            {
              "korean": "음악을 들으면서 그림을 그려요.",
              "english": "I draw while listening to music.",
              "highlight": "들으면서"
            },
            {
              "korean": "친구랑 이야기하면서 걸어요.",
              "english": "I walk while talking with my friend.",
              "highlight": "이야기하면서"
            }
          ]
        }
      ]
    },
