    "grammar": {
      "sections": [
        {
          "id": "g03_location",
          "title": "위치 명사 + 에 있어요/없어요",
          "subtitle": "Saying where something is or isn't",
          "pattern": "물건 + 위치명사 + 에 + 있어요/없어요",
          "meaning": "Something is/isn't [location]",
          "description": "To say where something is, put the location word + 에 after the object. 있어요 = it's there, 없어요 = it's not there.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 기본 패턴: N + 위치 + 에 + 있어요",
              "examples": [
                "열쇠가 탁자 위에 있어요. = The key is on the table.",
                "고양이가 상자 안에 있어요. = The cat is inside the box.",
                "가방이 의자 옆에 있어요. = The bag is next to the chair."
              ]
            },
            {
              "color": "blue",
              "label": "🔵 없어요 패턴: N + 위치 + 에 + 없어요",
              "examples": [
                "열쇠가 항아리 속에 없어요. = The key is not inside the jar.",
                "반닫이 아래에도 없어요. = It's not under the chest either.",
                "탁자 위에도 없어요. = It's not on top of the table either."
              ]
            }
          ],
          "examples": [
            {
              "korean": "열쇠가 탁자 위에 있어요.",
              "english": "The key is on the table.",
              "highlight": "위에 있어요"
            },
            {
              "korean": "항아리 속에 없어요.",
              "english": "It's not inside the jar.",
              "highlight": "속에 없어요"
            },
            {
              "korean": "마법 열쇠가 어디에 있을까요?",
              "english": "Where could the magic key be?",
              "highlight": "어디에 있을까요"
            }
          ]
        },
        {
          "id": "g03_also",
          "title": "~에도 없어요 — not there either",
          "subtitle": "Adding 도 = also / either",
          "pattern": "위치 + 에도 + 없어요",
          "meaning": "It's not there either",
          "description": "Add 도 after 에 to mean 'also' or 'either'. It connects a series of places you've already checked.",
          "rule_boxes": [
            {
              "color": "green",
              "label": "🟢 에도 = not ... either",
              "examples": [
                "항아리 속에 없어요. = Not in the jar.",
                "반닫이 아래에도 없어요. = Not under the chest either.",
                "탁자 위에도 없어요. = Not on the table either."
              ]
            }
          ],
          "examples": [
            {
              "korean": "가방 안에도 없어요.",
              "english": "It's not inside the bag either.",
              "highlight": "안에도 없어요"
            },
            {
              "korean": "침대 아래에도 없어요.",
              "english": "It's not under the bed either.",
              "highlight": "아래에도 없어요"
            }
          ]
        },
        {
          "id": "g03_demonstrative",
          "title": "이/그/저 — This / That / That over there",
          "subtitle": "Pointing to things in Korean",
          "pattern": "이/그/저 + 물건",
          "meaning": "this / that (near you) / that (over there)",
          "description": "Korean has three demonstratives depending on how far the object is from the speaker.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 이 — This (near me)",
              "examples": [
                "이 자물통은 할머니 거예요. = This lock is grandma's.",
                "이 열쇠가 맞아요. = This key is correct.",
                "이 반닫이는 오래됐어요. = This chest is old."
              ]
            },
            {
              "color": "blue",
              "label": "🔵 그 — That (near you)",
              "examples": [
                "그 자물통은 뭐예요? = What is that lock?",
                "그 열쇠 줘! = Give me that key!",
                "그 항아리 안에 있어요. = It's in that jar."
              ]
            },
            {
              "color": "green",
              "label": "🟢 저 — That over there",
              "examples": [
                "저 반닫이 아래에 있어요. = It's under that chest over there.",
                "저 탁자 위에 있어요. = It's on that table over there."
              ]
            }
          ],
          "table": {
            "headers": [
              "",
              "한국어",
              "영어"
            ],
            "rows": [
              [
                "가까이 (near me)",
                "이",
                "this"
              ],
              [
                "당신 근처 (near you)",
                "그",
                "that"
              ],
              [
                "저기 (far away)",
                "저",
                "that over there"
              ]
            ]
          },
          "examples": [
            {
              "korean": "이 자물통은 어디서 왔어요?",
              "english": "Where did this lock come from?",
              "highlight": "이 자물통"
            },
            {
              "korean": "그 열쇠가 맞아요!",
              "english": "That key is the right one!",
              "highlight": "그 열쇠"
            },
            {
              "korean": "저 항아리 속에 있을까요?",
              "english": "Could it be inside that jar over there?",
              "highlight": "저 항아리"
            }
          ]
        },
        {
          "id": "g03_possessive",
          "title": "~의 — Possessive · 's",
          "subtitle": "Showing who something belongs to",
          "pattern": "사람/이름 + 의 + 물건",
          "meaning": "[person]'s [thing]",
          "description": "의 is the possessive particle in Korean, similar to 's in English. It shows belonging or ownership.",
          "rule_boxes": [
            {
              "color": "green",
              "label": "🟢 N + 의 + N = N's N",
              "examples": [
                "할머니의 자물통 = grandma's lock",
                "나의 열쇠 = my key",
                "우리의 마법 = our magic"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 TIP: 나의 → 내, 너의 → 네 (spoken shortcut)",
              "examples": [
                "나의 열쇠 → 내 열쇠 (my key)",
                "너의 가방 → 네 가방 (your bag)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "이 자물통은 할머니의 거예요.",
              "english": "This lock is grandma's.",
              "highlight": "할머니의"
            },
            {
              "korean": "내 열쇠는 어디 있어요?",
              "english": "Where is my key?",
              "highlight": "내 열쇠"
            },
            {
              "korean": "우리 집 반닫이 안에 있어요.",
              "english": "It's inside our house's chest.",
              "highlight": "우리 집"
            }
          ]
        },
        {
          "id": "g03_an_verb",
          "title": "안 + 동사 — 안 해요!",
          "subtitle": "Making verbs negative",
          "pattern": "안 + 동사",
          "meaning": "don't ~ / can't see ~ / not doing ~",
          "description": "Put 안 before any verb to make it negative. It's the easiest way to say 'not' in Korean — just add 안 before the verb!",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 안 + 동사 = negative",
              "examples": [
                "보여요 → 안 보여요. (I can see it → I can't see it.)",
                "가요 → 안 가요. (I go → I don't go.)",
                "먹어요 → 안 먹어요. (I eat → I don't eat.)",
                "해요 → 안 해요. (I do it → I don't do it.)"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 하다 동사는 명사 + 안 + 해요",
              "examples": [
                "공부해요 → 공부 안 해요. (I study → I don't study.)",
                "운동해요 → 운동 안 해요. (I exercise → I don't exercise.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "마법 열쇠가 안 보여요!",
              "english": "I can't see the magic key!",
              "highlight": "안 보여요"
            },
            {
              "korean": "오늘은 학교에 안 가요.",
              "english": "I'm not going to school today.",
              "highlight": "안 가요"
            },
            {
              "korean": "숙제 안 했어요.",
              "english": "I didn't do my homework.",
              "highlight": "안 했어요"
            }
          ]
        }
      ]
    },
