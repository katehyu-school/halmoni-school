    "grammar": {
      "sections": [
        {
          "id": "g05_past",
          "title": "~았/었어요 — 과거형",
          "subtitle": "Talking about the past",
          "pattern": "동사 stem + 았/었어요",
          "meaning": "Something happened (past tense)",
          "description": "To talk about things that already happened, add 았어요 or 었어요 to the verb stem. Use 았 when the last vowel is ㅏ or ㅗ, and 었 for everything else.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 ㅏ/ㅗ 모음 → 았어요",
              "examples": [
                "가다 → 갔어요 (went)  · ㅏ 모음",
                "팔다 → 팔았어요 (sold)  · ㅏ 모음",
                "보다 → 봤어요 (saw)  · ㅗ 모음"
              ]
            },
            {
              "color": "purple",
              "label": "🟣 그 외 → 었어요",
              "examples": [
                "먹다 → 먹었어요 (ate)  · ㅓ 모음",
                "만들다 → 만들었어요 (made)  · ㅡ 모음"
              ]
            },
            {
              "color": "red",
              "label": "🔴 하다 → 했어요 (특별!)",
              "examples": [
                "하다 → 했어요 (did)",
                "공부하다 → 공부했어요 (studied)",
                "일하다 → 일했어요 (worked)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "어제는 우리 가족이 모두 함께 앱을 만들었어요.",
              "english": "Yesterday, our whole family made an app together.",
              "highlight": "만들었어요"
            },
            {
              "korean": "레모네이드를 팔았어요.",
              "english": "We sold lemonade.",
              "highlight": "팔았어요"
            },
            {
              "korean": "너무 재밌었어요!",
              "english": "It was so fun!",
              "highlight": "재밌었어요"
            }
          ],
          "images": [
            "data/elem/level3/slides/L3_05/동사 활용_놀다.png",
            "data/elem/level3/slides/L3_05/동사 활용_만들다.png"
          ]
        },
        {
          "id": "g05_future",
          "title": "~(으)ㄹ 거예요 — 미래형",
          "subtitle": "Talking about the future",
          "pattern": "동사 stem + (으)ㄹ 거예요",
          "meaning": "Going to / will do something",
          "description": "To talk about plans or what will happen, add (으)ㄹ 거예요 to the verb stem. If the stem ends in a vowel, add ㄹ 거예요. If it ends in a consonant, add 을 거예요.",
          "rule_boxes": [
            {
              "color": "teal",
              "label": "🟢 모음 끝 → ㄹ 거예요",
              "examples": [
                "팔다 → 팔 거예요 (will sell)",
                "가다 → 갈 거예요 (will go)",
                "만들다 → 만들 거예요 (will make)"
              ]
            },
            {
              "color": "orange",
              "label": "🟠 자음 끝 → 을 거예요",
              "examples": [
                "먹다 → 먹을 거예요 (will eat)",
                "읽다 → 읽을 거예요 (will read)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "내일은 친구랑 같이 레모네이드를 팔 거예요.",
              "english": "Tomorrow I will sell lemonade with my friend.",
              "highlight": "팔 거예요"
            },
            {
              "korean": "우리 내일 뭐 할 거예요?",
              "english": "What are we going to do tomorrow?",
              "highlight": "할 거예요"
            },
            {
              "korean": "저는 주스를 만들 거예요.",
              "english": "I will make juice.",
              "highlight": "만들 거예요"
            }
          ]
        },
        {
          "id": "g05_can",
          "title": "~ㄹ 수 있어요 — 할 수 있어요!",
          "subtitle": "I can do it!",
          "pattern": "동사 stem + ㄹ 수 있어요",
          "meaning": "I can / It is possible to",
          "description": "To say you CAN do something, add ㄹ 수 있어요 after the verb stem. This is a very useful expression!",
          "rule_boxes": [
            {
              "color": "green",
              "label": "🟢 패턴: 동사 stem + ㄹ 수 있어요",
              "examples": [
                "만들 수 있어요. (I can make it.)",
                "팔 수 있어요. (I can sell it.)",
                "먹을 수 있어요. (I can eat it.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "메뉴를 만들 수 있어요.",
              "english": "I can make a menu.",
              "highlight": "만들 수 있어요"
            },
            {
              "korean": "주문을 받을 수 있어요.",
              "english": "I can take orders.",
              "highlight": "받을 수 있어요"
            },
            {
              "korean": "저 혼자 할 수 있어요!",
              "english": "I can do it by myself!",
              "highlight": "할 수 있어요"
            }
          ]
        },
        {
          "id": "g05_aseo",
          "title": "~아/어서 좋아요 — 그래서 좋아요!",
          "subtitle": "Because of that, it is good!",
          "pattern": "이유 + 아/어서 + 좋아요",
          "meaning": "It's good because ~",
          "description": "Use 아/어서 to give a reason why something is good (or any result). It links two parts: the reason and the result.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 패턴: [이유] + 아/어서 + [결과]",
              "examples": [
                "우리가 만들어서 더 좋아요. (It's even better because we made it.)",
                "친구랑 같이 해서 재밌어요. (It's fun because we do it together.)",
                "맛있어서 좋아요. (I like it because it's delicious.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "우리가 만들어서 더 좋아요.",
              "english": "It's even better because we made it.",
              "highlight": "만들어서 더 좋아요"
            },
            {
              "korean": "함께해서 신나요!",
              "english": "It's exciting because we're together!",
              "highlight": "함께해서"
            },
            {
              "korean": "쉬워서 좋아요.",
              "english": "I like it because it's easy.",
              "highlight": "쉬워서 좋아요"
            }
          ]
        }
      ]
    },
