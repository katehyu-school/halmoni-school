    "grammar": {
      "sections": [
        {
          "id": "g10_doedwaeyo",
          "tier": "core",
          "title": "~도 돼요? — 허락 구하기",
          "title_en": "May I ~? / Is it okay to ~?",
          "emoji": "✅",
          "explanation_en": "To ask for permission, attach -아/어도 돼요? to a verb stem. The answer is 돼요 (yes, okay) or 안 돼요 (no, not allowed). You already know 안 돼요 from unit06!",
          "pattern": "Verb stem + -아/어도 돼요? → 돼요 / 안 돼요",
          "scene_example": {
            "korean": "오늘 외갓집에서 자도 돼요?",
            "english": "May I sleep at grandma's house today?",
            "highlight": "자도 돼요?"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "label": "How to make it · 만드는 법",
              "examples": [
                "ㅏ/ㅗ 끝 → 아도 돼요?",
                "가다 → 가도 돼요? (May I go?)",
                "그 외 → 어도 돼요?",
                "자다 → 자도 돼요? (May I sleep?)",
                "먹다 → 먹어도 돼요? (May I eat?)"
              ]
            },
            {
              "color": "green",
              "label": "Answers · 대답",
              "examples": [
                "✅ 돼요. = Yes, it's okay.",
                "✅ 네, 가도 돼요. = Yes, you can go.",
                "❌ 안 돼요. = No, not allowed.",
                "❌ 지금은 안 돼요. = Not right now."
              ]
            },
            {
              "color": "amber",
              "label": "⚠️ 두 개의 도 — Two uses of 도",
              "examples": [
                "도 (also/too) · 나열:",
                "숙제도 하고 → 도 = also",
                "'팔찌도 만들어요' → 팔찌 also",
                "도 (permission) · 허락:",
                "가도 돼요? → 도 = even if",
                "'가도 괜찮아요?' → even if you go, okay?",
                "👉 헷갈리면 문맥을 봐요 — context is everything!"
              ]
            }
          ],
          "examples": [
            {
              "korean": "외갓집에 가도 돼요?",
              "english": "May I go to grandma's house?",
              "highlight": "가도 돼요?"
            },
            {
              "korean": "지금 먹어도 돼요?",
              "english": "May I eat now?",
              "highlight": "먹어도 돼요?"
            },
            {
              "korean": "여기서 뛰어도 돼요?",
              "english": "May I run here?",
              "highlight": "뛰어도 돼요?"
            },
            {
              "korean": "도서관에서 먹으면 안 돼요.",
              "english": "You can't eat in the library.",
              "highlight": "안 돼요"
            }
          ]
        },
        {
          "id": "g10_hante_hanteseo",
          "tier": "core",
          "title": "한테 / 한테서",
          "title_en": "To a person / From a person",
          "emoji": "🔀",
          "explanation_en": "You know 에서 (at/from a place). Now meet 한테/한테서 — same idea, but for PEOPLE. 한테 = direction toward a person. 한테서 = coming from a person.",
          "pattern": "N한테 (→ to/at someone) · N한테서 (← from someone)",
          "scene_example": {
            "korean": "엄마한테 물어 봐. / 할머니한테서 허락 받았어?",
            "english": "Ask mom. / Did you get permission from grandma?",
            "highlight": "한테 / 한테서"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "label": "한테 → (to / at a person)",
              "examples": [
                "엄마한테 물어 봐. → Ask mom.",
                "선생님한테 말해요. → Tell the teacher.",
                "친구한테 전화해요. → Call a friend."
              ]
            },
            {
              "color": "green",
              "label": "한테서 ← (from a person)",
              "examples": [
                "할머니한테서 허락 받았어?",
                "→ Did you get permission FROM grandma?",
                "친구한테서 편지 받았어요.",
                "→ I got a letter FROM a friend."
              ]
            },
            {
              "color": "amber",
              "label": "에서 (장소) vs 한테서 (사람) · Place vs Person",
              "examples": [
                "공원에서 놀아요. (place: at the park)",
                "친구한테서 받았어요. (person: from a friend)",
                "학교에서 배워요. (place: at school)",
                "선생님한테서 배워요. (person: from the teacher)",
                "👉 사람이면 한테/한테서, 장소면 에/에서!"
              ]
            },
            {
              "color": "amber",
              "label": "💡 왜 / 어떻게 — Quick tip",
              "examples": [
                "왜 = why",
                "어떻게 = how",
                "왜 할머니 집에 가고 싶어? → Why do you want to go?",
                "어떻게 만들 거야? → How are you going to make it?",
                "문장 맨 앞에 붙여요 — put them at the start!"
              ]
            }
          ],
          "examples": [
            {
              "korean": "엄마한테 물어 봐.",
              "english": "Ask mom.",
              "highlight": "엄마한테"
            },
            {
              "korean": "할머니한테서 허락 받았어?",
              "english": "Did you get permission from grandma?",
              "highlight": "할머니한테서"
            },
            {
              "korean": "선생님한테 말해요.",
              "english": "Tell the teacher.",
              "highlight": "선생님한테"
            },
            {
              "korean": "친구한테서 배웠어요.",
              "english": "I learned it from a friend.",
              "highlight": "친구한테서"
            }
          ]
        },
        {
          "id": "g10_ro",
          "tier": "preview",
          "title": "(으)로 — 수단·재료",
          "title_en": "Using ~ / Made with ~",
          "emoji": "🔧",
          "explanation_en": "(으)로 tells you HOW something is done — what material or tool is used. It's like 'with' or 'using' in English. You'll learn more of this in Level 4!",
          "pattern": "N(으)로 + 동사: ~로 만들어요 / ~로 가요",
          "scene_example": {
            "korean": "종이 접시로 만들 거예요.",
            "english": "I'm going to make it with a paper plate.",
            "highlight": "종이 접시로"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 없으면 → 로",
              "examples": [
                "종이로 만들어요. → made with paper",
                "가위로 잘라요. → cut with scissors",
                "버스로 가요. → go by bus"
              ]
            },
            {
              "color": "green",
              "label": "받침 있으면 → 으로",
              "examples": [
                "연필으로 써요. → write with a pencil",
                "손으로 만들어요. → made by hand",
                "⚠️ 예외: ㄹ 받침 → 로 (not 으로)",
                "풀로 붙여요. → stick with glue"
              ]
            }
          ],
          "examples": [
            {
              "korean": "종이 접시로 갓을 만들 거예요.",
              "english": "I'm going to make a gat with a paper plate.",
              "highlight": "종이 접시로"
            },
            {
              "korean": "버스로 학교에 가요.",
              "english": "I go to school by bus.",
              "highlight": "버스로"
            },
            {
              "korean": "손으로 만들어요.",
              "english": "I make it by hand.",
              "highlight": "손으로"
            }
          ]
        }
      ]
    },
