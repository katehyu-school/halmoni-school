    "grammar": {
      "sections": [
        {
          "id": "g06_mot",
          "title": "못+동사 — 못 먹어요",
          "subtitle": "I can't do something",
          "pattern": "못 + 동사",
          "meaning": "Cannot / unable to (because of a limitation)",
          "description": "Use 못 before a verb to say you cannot do something — usually because of a physical reason, allergy, or circumstance. It's different from 안 (which is a choice).",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 못 + 동사 = can't (inability)",
              "examples": [
                "못 먹어요. (I can't eat it.)",
                "못 가요. (I can't go.)",
                "못 해요. (I can't do it.)"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 안 vs 못 — 차이!",
              "examples": [
                "안 먹어요. → I don't eat it. (choice)",
                "못 먹어요. → I can't eat it. (inability / allergy)",
                "안 가요. → I'm not going. (choice)",
                "못 가요. → I can't go. (something stops me)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "저는 계란 못 먹어요.",
              "english": "I can't eat eggs.",
              "highlight": "못 먹어요"
            },
            {
              "korean": "저는 수영을 못 해요.",
              "english": "I can't swim.",
              "highlight": "못 해요"
            },
            {
              "korean": "오늘은 못 가요.",
              "english": "I can't go today.",
              "highlight": "못 가요"
            }
          ]
        },
        {
          "id": "g06_jimaseo",
          "title": "-지 마세요 — 넣지 마세요",
          "subtitle": "Please don't do something",
          "pattern": "동사 stem + 지 마세요",
          "meaning": "Please don't ~ (polite request to stop or avoid)",
          "description": "To politely ask someone NOT to do something, add 지 마세요 to the verb stem. This is a very useful expression in everyday Korean!",
          "rule_boxes": [
            {
              "color": "orange",
              "label": "🟠 동사 stem + 지 마세요",
              "examples": [
                "넣지 마세요. (Please don't put it in.)",
                "먹지 마세요. (Please don't eat it.)",
                "가지 마세요. (Please don't go.)",
                "하지 마세요. (Please don't do it.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "제 김밥에는 계란 넣지 마세요.",
              "english": "Please don't put eggs in my gimbap.",
              "highlight": "넣지 마세요"
            },
            {
              "korean": "여기서 뛰지 마세요.",
              "english": "Please don't run here.",
              "highlight": "뛰지 마세요"
            },
            {
              "korean": "떠들지 마세요.",
              "english": "Please don't make noise.",
              "highlight": "떠들지 마세요"
            }
          ]
        },
        {
          "id": "g06_andwae",
          "title": "-(으)면 안 돼요 — 하면 안 돼요!",
          "subtitle": "You must not / It's not allowed",
          "pattern": "동사 stem + (으)면 안 돼요",
          "meaning": "Must not / It's not okay to ~",
          "description": "To say something is not allowed or must not be done, use -(으)면 안 돼요. 면 means 'if', and 안 돼요 means 'it's not okay'. Together: 'If you do it, it's not okay!'",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 모음/ㄹ 끝 stem + 면 안 돼요",
              "examples": [
                "먹으면 안 돼요. (You must not eat it.)",
                "가면 안 돼요. (You must not go.)"
              ]
            },
            {
              "color": "purple",
              "label": "🟣 자음 끝 stem + 으면 안 돼요",
              "examples": [
                "먹다 → 먹으면 안 돼요.",
                "앉다 → 앉으면 안 돼요.",
                "잡다 → 잡으면 안 돼요."
              ]
            }
          ],
          "examples": [
            {
              "korean": "편식을 하면 안 돼요.",
              "english": "You must not be a picky eater.",
              "highlight": "하면 안 돼요"
            },
            {
              "korean": "여기서 뛰면 안 돼요.",
              "english": "You must not run here.",
              "highlight": "뛰면 안 돼요"
            },
            {
              "korean": "늦게 자면 안 돼요.",
              "english": "You must not sleep late.",
              "highlight": "자면 안 돼요"
            }
          ],
          "connective_label": {
            "function_ko": "조건",
            "function_en": "Condition · If"
          }
        },
        {
          "id": "g06_myeon",
          "title": "-(으)면 — 먹으면 배가 아파요",
          "subtitle": "If / When ~ then ~",
          "pattern": "[조건] + (으)면 + [결과]",
          "meaning": "If you do ~, then ~ happens",
          "description": "Use -(으)면 to connect a condition and a result. It works like 'if' or 'when' in English. The first part is the condition, and the second part is what happens.",
          "rule_boxes": [
            {
              "color": "teal",
              "label": "🟢 패턴: [condition] + (으)면 + [result]",
              "examples": [
                "계란을 먹으면 배가 아파요. (If I eat eggs, my stomach hurts.)",
                "열심히 하면 잘 할 수 있어요. (If you try hard, you can do it.)",
                "비가 오면 집에 있어요. (When it rains, I stay home.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "계란을 먹으면 배가 아파요.",
              "english": "If I eat eggs, my stomach hurts.",
              "highlight": "먹으면"
            },
            {
              "korean": "배가 고프면 밥을 먹어요.",
              "english": "If you're hungry, eat some food.",
              "highlight": "고프면"
            },
            {
              "korean": "숙제를 하면 놀 수 있어요.",
              "english": "If you do homework, you can play.",
              "highlight": "하면"
            }
          ],
          "connective_label": {
            "function_ko": "조건",
            "function_en": "Condition · If"
          }
        }
      ]
    },
