    "grammar": {
      "sections": [
        {
          "id": "g02_juseyo",
          "title": "N 주세요 — 주문하기",
          "subtitle": "Asking for something politely",
          "pattern": "물건 + (숫자+단위) + 주세요",
          "meaning": "Please give me ~",
          "description": "주세요 is the magic word for asking for things! Put what you want before 주세요. Add how many if you need.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 기본 패턴: N + 주세요",
              "examples": [
                "아이스크림 주세요. = Ice cream, please!",
                "쿠키 주세요. = A cookie, please!",
                "주스 주세요. = Juice, please!"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 숫자 추가: N + 숫자+단위 + 주세요",
              "examples": [
                "아이스크림 두 개 주세요. = Two ice creams, please.",
                "주스 세 잔 주세요. = Three cups of juice, please.",
                "우유 한 병 주세요. = One bottle of milk, please."
              ]
            }
          ],
          "examples": [
            { "korean": "아이스크림 두 개 주세요.", "english": "Two ice creams, please.",     "highlight": "두 개 주세요" },
            { "korean": "쿠키 세 개 주세요.",       "english": "Three cookies, please.",       "highlight": "세 개 주세요" },
            { "korean": "주스 한 잔 주세요.",       "english": "One cup of juice, please.",    "highlight": "한 잔 주세요" }
          ]
        },
        {
          "id": "g02_gae_jan_byeong",
          "title": "개 / 잔 / 병 — 무엇을 셀 때?",
          "subtitle": "Which counter to use?",
          "pattern": "숫자 + 개 / 잔 / 병",
          "meaning": "counting items / cups / bottles",
          "description": "Different objects use different counter words. 개 is the most common (general items), 잔 for drinks in cups, 병 for drinks in bottles.",
          "rule_boxes": [
            {
              "color": "green",
              "label": "🟢 개 — 일반 물건 (general items)",
              "examples": [
                "아이스크림 두 개 (two ice creams)",
                "쿠키 세 개 (three cookies)",
                "도넛 한 개 (one donut)"
              ]
            },
            {
              "color": "yellow",
              "label": "🟡 잔 — 컵에 든 음료 (drinks in cups)",
              "examples": [
                "주스 두 잔 (two cups of juice)",
                "우유 한 잔 (one cup of milk)"
              ]
            }
          ],
          "examples": [
            { "korean": "초콜릿 네 개 주세요.", "english": "Four chocolates, please.",      "highlight": "네 개" },
            { "korean": "주스 두 잔 주세요.",   "english": "Two cups of juice, please.",   "highlight": "두 잔" },
            { "korean": "우유 한 병 주세요.",   "english": "One bottle of milk, please.",  "highlight": "한 병" }
          ]
        }
      ]
    },
