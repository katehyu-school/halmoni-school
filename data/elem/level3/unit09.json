    "grammar": {
      "sections": [
        {
          "id": "g09_e_eseo",
          "title": "에 / 에서 — 어디로? 어디에서?",
          "subtitle": "Direction: to (에) vs from / at (에서)",
          "pattern": "장소 + 에 (가다/오다/있다) · 장소 + 에서 (출발하다/자다/놀다)",
          "meaning": "to (a place) / from (a place), at (a place)",
          "description": "에 shows the place you're going TO or where something IS (arrow pointing IN). 에서 shows the place you're coming FROM (arrow pointing OUT), or the place WHERE an action happens. Same place word, different meaning!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 장소 + 에 = to / at (destination, existence)",
              "examples": [
                "나이아가라에 가요. (Going to Niagara.)",
                "나이아가라에 있어요. (It's in Niagara.)",
                "외갓집에 가요. (Going to grandma's house.)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 장소 + 에서 = from (origin) · at (doing something)",
              "examples": [
                "외갓집에서 출발해요. (Starting from grandma's house.)",
                "외갓집에서 자요. (Sleeping AT grandma's house.)",
                "여기에서 놀아요. (Playing here.)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 같은 장소, 다른 방향/뜻",
              "examples": [
                "외갓집에 가요 (TO grandma's) ↔ 외갓집에서 와요 (FROM grandma's)",
                "에 = arrow points TO the place",
                "에서 = arrow points FROM the place, or 'doing something there'"
              ]
            }
          ],
          "examples": [
            {
              "korean": "내일 우리가 외갓집에서 거기에 갈 거야?",
              "english": "Are we going there tomorrow from grandma's house?",
              "highlight": "외갓집에서 ... 거기에"
            }
          ]
        },
        {
          "id": "g09_buteo_kkaji",
          "title": "여기부터 ~까지 — 거리를 말해요",
          "subtitle": "from ~ to ~ (place range / distance)",
          "pattern": "장소 + 부터 + 장소 + 까지",
          "meaning": "from (place) to (place)",
          "description": "부터 marks the starting point and 까지 marks the ending point. Use them together to talk about the distance between two places — like 'from here to Niagara'.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 N부터 N까지 = from N to N",
              "examples": [
                "여기부터 나이아가라까지 (from here to Niagara)",
                "집부터 학교까지 (from home to school)",
                "서울부터 부산까지 (from Seoul to Busan)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 얼마나 걸려요? = how long does it take?",
              "examples": [
                "여기부터 나이아가라까지 얼마나 걸려요? (How long from here to Niagara?)",
                "두 시간 걸려요. (It takes two hours.)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 에/에서 vs 부터/까지",
              "examples": [
                "에/에서 = simple to/from (one place)",
                "부터/까지 = the whole range, both ends together",
                "여기에서 가요 (from here) vs 여기부터 ~까지 (from here ALL THE WAY to ~)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "할아버지, 여기부터 나이아가라까지 얼마나 걸려요?",
              "english": "Grandpa, how long does it take from here to Niagara?",
              "highlight": "여기부터 나이아가라까지"
            }
          ]
        },
        {
          "id": "g09_geollida_namda",
          "title": "걸리다 · 남다 · 멀다 · 가깝다",
          "subtitle": "time taken, time left, far, close",
          "pattern": "시간 + 걸려요 / 시간 + 남았어요 / 멀어요 / 가까워요",
          "meaning": "it takes (time) / (time) is left / is far / is close",
          "description": "걸리다 = how much time something takes. 남다 = how much time is left. 멀다 = far away, 가깝다 = close/near. These are exactly the words kids use to ask 'are we there yet?' on a road trip!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 시간 + 걸려요 = it takes (time)",
              "examples": [
                "두 시간 걸려요. (It takes two hours.)",
                "얼마나 걸려요? (How long does it take?)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 몇 분 남았어요? = how many minutes are left?",
              "examples": [
                "이제 몇 분 남았어요? (How many minutes are left now?)",
                "십 분 남았어요. (Ten minutes left.)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 멀어요 ↔ 가까워요",
              "examples": [
                "아직 멀었어요? (Are we still far?)",
                "거의 다 왔어요! 가까워요! (Almost there! It's close!)",
                "멀다 ↔ 가깝다 — opposites!"
              ]
            }
          ],
          "examples": [
            {
              "korean": "아직 멀었어요? 할머니, 이제 몇 분 남았어요?",
              "english": "Are we still far? Grandma, how many minutes are left now?",
              "highlight": "멀었어요? / 남았어요?"
            }
          ]
        },
        {
          "id": "g09_geoya_geoyeyo",
          "title": "갈 거야 / 걸릴 거예요 — 미래 (반말·존댓말)",
          "subtitle": "future tense: casual (거야) vs polite (거예요)",
          "pattern": "동사 어간 + -(으)ㄹ 거야 (반말) / -(으)ㄹ 거예요 (존댓말)",
          "meaning": "will (do) / is going to",
          "description": "Both 거야 and 거예요 mean 'will' or 'going to' — same grammar, different politeness. Use 거야 with siblings/friends (반말), 거예요 with adults like grandparents (존댓말).",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 동사 + -(으)ㄹ 거야 (반말 — 형제/친구에게)",
              "examples": [
                "갈 거야? (Are we going?)",
                "두 시간은 걸릴 거야. (It'll take about two hours.)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 동사 + -(으)ㄹ 거예요 (존댓말 — 어른에게)",
              "examples": [
                "갈 거예요. (I will go. — polite)",
                "두 시간 걸릴 거예요. (It will take two hours. — polite)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 같은 뜻, 다른 높임",
              "examples": [
                "리암 → 카요 (형제 사이): 갈 거야? (반말)",
                "카요 → 할아버지: 걸릴 거예요? (존댓말)",
                "Same meaning — just choose based on who you're talking to!"
              ]
            }
          ],
          "examples": [
            {
              "korean": "내일 우리가 거기에 갈 거야? / 아마 두 시간은 걸릴 거야.",
              "english": "Are we going there tomorrow? / It'll probably take about two hours.",
              "highlight": "갈 거야 / 걸릴 거야"
            }
          ]
        }
      ]
    },
