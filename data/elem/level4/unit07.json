    "grammar": {
      "sections": [
        {
          "id": "g07_deurida",
          "tier": "core",
          "title": "-아/어 드리다",
          "subtitle": "Doing something FOR an elder (humble form)",
          "pattern": "동사 어간 + -아/어 드리다",
          "meaning": "to do (something) for an elder, as a show of respect",
          "description": "When YOU do something for an elder (not them doing it), attach -아/어 드리다 to the verb stem. It's the humble counterpart to -(으)시- from Unit 6 — -(으)시- is for the elder's own actions, 드리다 is for actions you do toward them.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 만드는 법 · How to form it",
              "examples": [
                "주무르다 → 주물러 드리다 (르 불규칙! massage for them)",
                "돕다 → 도와 드리다 (ㅂ 불규칙! help them)",
                "하다 → 해 드리다 (do for them)"
              ]
            },
            {
              "color": "green",
              "label": "✅ 문장에서 · In the episode",
              "examples": [
                "어깨를 주물러 드리자. = Let's rub her shoulders (for her).",
                "청소를 도와 드리고. = We'll help her clean.",
                "요리를 해 드려야지. = We should cook for her."
              ]
            },
            {
              "color": "amber",
              "label": "💡 드리다 vs 주다 · Who gets 드리다?",
              "examples": [
                "어른에게: 드리다 (elders — respectful)",
                "친구/동생에게: 주다 (peers/younger — plain)",
                "할머니께 선물을 드려요. (Give a present to grandma.)"
              ]
            }
          ],
          "examples": [
            { "korean": "어깨를 주물러 드리자.", "english": "Let's massage her shoulders (for her).", "highlight": "주물러 드리자" },
            { "korean": "청소를 도와 드리고,", "english": "We'll help her clean, and", "highlight": "도와 드리고" },
            { "korean": "안아 드려.", "english": "We hug her.", "highlight": "안아 드려" }
          ]
        },
        {
          "id": "g07_date_reading",
          "tier": "core",
          "title": "날짜 / 월 / 년도 읽기",
          "subtitle": "Reading dates — month & day",
          "pattern": "몇 월 며칠이에요? → N월 N일이에요.",
          "meaning": "asking and telling the date",
          "description": "Months and days both use Sino-Korean numbers (일, 이, 삼...) + 월(month)/일(day). But watch out — two months have irregular names!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 월 (달) 읽기 · Reading months",
              "examples": [
                "1월 일월, 2월 이월, 3월 삼월, 4월 사월, 5월 오월",
                "6월 유월 ⚠️ (NOT 육월!)",
                "7월 칠월, 8월 팔월, 9월 구월",
                "10월 시월 ⚠️ (NOT 십월!)",
                "11월 십일월, 12월 십이월"
              ]
            },
            {
              "color": "green",
              "label": "✅ 일 (날) 읽기 · Reading days",
              "examples": [
                "16일 = 십육일", "15일 = 십오일", "1일 = 일일"
              ]
            },
            {
              "color": "amber",
              "label": "💡 질문-답변 패턴 · Q&A pattern",
              "examples": [
                "몇 월 며칠이에요? = What month and day is it?",
                "6월 16일이에요! = It's June 16th!",
                "생신은 몇 월 며칠이세요? = What's your (honorific) birthday? (asking an elder)"
              ]
            }
          ],
          "examples": [
            { "korean": "엄마 생신이 언제야?", "english": "When is Mom's birthday?", "highlight": "언제야" },
            { "korean": "몇월 며칠이냐고? 6월 16일이잖아!", "english": "You're asking what date? It's June 16th!", "highlight": "6월 16일" },
            { "korean": "할머니 생신은 몇 월 며칠이세요?", "english": "Grandma, what's your birthday (month/day)?", "highlight": "몇 월 며칠이세요" }
          ]
        }
      ]
    },
