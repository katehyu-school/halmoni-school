    "grammar": {
      "sections": [
        {
          "id": "g06_honorific",
          "tier": "core",
          "title": "-(으)시- 높임법",
          "subtitle": "Honorific system — showing respect to elders",
          "pattern": "Verb stem + -(으)시- + ending",
          "description": "When talking about an elder's actions, add -(으)시- between the verb stem and the ending. This shows respect and is essential in Korean culture.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 없으면 → -시- · No final consonant",
              "examples": ["가다 → 가시다 (go → go honorific)", "오다 → 오시다 (come)", "하다 → 하시다 (do)"]
            },
            {
              "color": "green",
              "label": "받침 있으면 → -으시- · Final consonant",
              "examples": ["읽다 → 읽으시다 (read)", "앉다 → 앉으시다 (sit)", "있다 → 계시다 ⚠️ 특별 형태!"]
            },
            {
              "color": "amber",
              "label": "특별 높임 동사 3개 · Special honorific verbs",
              "examples": ["먹다/마시다 → 드시다 (eat/drink)", "있다 → 계시다 (be/stay)", "자다 → 주무시다 (sleep)"]
            },
            {
              "color": "red",
              "label": "⚠️ 어른 동작에만! · Only for the elder's OWN actions",
              "examples": ["할아버지 드세요 ✅ (Grandpa, please eat)", "제가 드세요 ❌ (you can't use it for yourself)", "→ 내 동작엔 겸손어: 드리다 (give to elder)"]
            }
          ],
          "examples": [
            { "korean": "할머니 이거 드세요!", "english": "Grandma, please eat this!", "highlight": "드세요" },
            { "korean": "그동안 별 일 없으셨어요?", "english": "Has everything been okay all this time?", "highlight": "없으셨어요" },
            { "korean": "할아버지도 드셔 보세요.", "english": "Grandpa, please try eating it too.", "highlight": "드셔 보세요" }
          ]
        },
        {
          "id": "g06_farewell",
          "tier": "core",
          "title": "안녕히 계세요 vs 안녕히 가세요",
          "subtitle": "Who is leaving? Who is staying?",
          "pattern": "Focus on who moves",
          "description": "These two phrases are easy to mix up! The key is: who is physically leaving the place?",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "내가 떠날 때 · When YOU leave",
              "examples": ["→ 남는 사람에게: 안녕히 계세요 (please stay well)", "리아: 안녕히 계세요. (Lia is leaving, grandparents stay)"]
            },
            {
              "color": "green",
              "label": "상대방이 떠날 때 · When THEY leave",
              "examples": ["→ 떠나는 사람에게: 안녕히 가세요 (please go safely)", "할머니: 안녕히 가세요. (said when visitor leaves)"]
            },
            {
              "color": "amber",
              "label": "반말 버전 · Informal versions",
              "examples": ["잘 가 = casual 안녕히 가세요 (go well)", "잘 있어 = casual 안녕히 계세요 (stay well)"]
            }
          ],
          "examples": [
            { "korean": "안녕히 계세요! (내가 가요)", "english": "Goodbye! (I'm the one leaving)", "highlight": "계세요" },
            { "korean": "안녕히 가세요! (상대가 가요)", "english": "Goodbye! (They're the one leaving)", "highlight": "가세요" },
            { "korean": "잘 가! / 잘 있어!", "english": "Bye! / Stay well! (casual)", "highlight": "잘 가 / 잘 있어" }
          ]
        }
      ]
    },
