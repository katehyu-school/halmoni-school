        { "kr": "계시다", "en": "to be / to stay (honorific)", "emoji": "🏠" },
        { "kr": "가시다", "en": "to go (honorific)", "emoji": "🚶" },
        { "kr": "오시다", "en": "to come (honorific)", "emoji": "🙌" },
