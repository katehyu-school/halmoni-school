    "grammar": {
      "sections": [
        {
          "id": "g05_lgeyo",
          "tier": "core",
          "title": "-(으)ㄹ게요",
          "subtitle": "I will — promise & willingness",
          "pattern": "Verb stem + -(으)ㄹ게요",
          "description": "Use -(으)ㄹ게요 when YOU decide to do something — a promise or willingness. It's about YOUR action, directed at the listener.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 없으면 → -ㄹ게요 · No final consonant",
              "examples": ["가다 → 갈게요 (I'll go)", "오다 → 올게요 (I'll come)", "따다 → 딸게요 (I'll pick)"]
            },
            {
              "color": "green",
              "label": "받침 있으면 → -을게요 · Final consonant",
              "examples": ["읽다 → 읽을게요 (I'll read)", "먹다 → 먹을게요 (I'll eat)", "닫다 → 닫을게요 (I'll close)"]
            },
            {
              "color": "amber",
              "label": "따 올게요 vs 따 갈게요 · Direction matters!",
              "examples": ["따 올게요 = I'll pick and come BACK (to you)", "따 갈게요 = I'll pick and take a lot (away)", "→ 올게요 = toward you / 갈게요 = away from you"]
            },
            {
              "color": "red",
              "label": "⚠️ 내가 하는 것만! · Only for YOUR own action",
              "examples": ["✅ 제가 할게요. (I'll do it.)", "❌ 리아가 할게요. (can't use for others)", "→ 리아가 할 거예요. (Lia will do it. = prediction)"]
            }
          ],
          "examples": [
            { "korean": "제가 따 올게요!", "english": "I'll go pick them and come back!", "highlight": "따 올게요" },
            { "korean": "할머니 많이 따 갈게요!", "english": "Grandma, I'll pick a lot and take them!", "highlight": "따 갈게요" },
            { "korean": "제가 도울게요.", "english": "I'll help.", "highlight": "도울게요" }
          ]
        }
      ]
    },
