    "grammar": {
      "sections": [
        {
          "id": "g03_eo_boda",
          "tier": "core",
          "title": "-아/어 보다",
          "subtitle": "Try doing something · 해 봐요!",
          "pattern": "Verb stem + -아 보다 (ㅏ/ㅗ) / -어 보다 (other vowels) / -해 보다 (하다)",
          "description": "Use -아/어 보다 to say 'try doing' something — often used to encourage someone to give something a shot!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 ㅏ/ㅗ stem → -아 보다",
              "examples": [
                "먹다 → 먹어 보다 = try eating (먹 ends in ㄱ, vowel is ㅓ → 어 보다)",
                "봐요 = 보 + 아 보다 → 봐요  (try looking/tasting)",
                "맛만 봐! = Just try tasting it!"
              ]
            },
            {
              "color": "green",
              "label": "🟢 Other stems → -어 보다 / 하다 → 해 보다",
              "examples": [
                "만들다 → 만들어 봐요  (try making)",
                "입다  → 입어 봐요   (try wearing)",
                "하다  → 해 봐요     (try doing)"
              ]
            },
            {
              "color": "amber",
              "label": "🟡 권유 형태 Suggestions",
              "examples": [
                "해 봐! = Try it! (반말 casual)",
                "해 봐요! = Try it! (존댓말 polite)",
                "해 보자! = Let's try it! (함께 together)"
              ]
            }
          ],
          "examples": [
            {
              "note": "할머니 → 카요 (반말)",
              "korean": "이거 먹어 봐.",
              "english": "Try eating this."
            },
            {
              "note": "카요 → 할머니 (존댓말)",
              "korean": "같이 변신 로봇을 만들어 봐요.",
              "english": "Let's try making a transforming robot together."
            },
            {
              "note": "함께 하자 (informal proposal)",
              "korean": "같이 해 보자!",
              "english": "Let's try doing it together!"
            }
          ]
        },
        {
          "id": "g03_man",
          "tier": "foundation",
          "title": "만 (only)",
          "subtitle": "Just one · exactly one · only",
          "pattern": "N + 만 · 한 번만 · 맛만",
          "description": "만 attaches to a noun or counter to mean 'only' or 'just.' Very common when negotiating!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 N + 만 = only N",
              "examples": [
                "맛만 봐 = just taste it (맛 only)",
                "한 번만이에요 = just one time only",
                "나만 알아 = only I know"
              ]
            }
          ],
          "examples": [
            {
              "korean": "맛만 봐.",
              "english": "Just taste it."
            },
            {
              "korean": "딱 한 번만이에요!",
              "english": "Just exactly one time!"
            }
          ]
        },
        {
          "id": "g03_ui",
          "tier": "foundation",
          "title": "~의 소유격",
          "subtitle": "Possessive: 's · of",
          "pattern": "N + 의 = N's",
          "description": "의 shows possession. In spoken Korean it's often pronounced [에] or even dropped, but it's important to recognize in writing.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 N의 N = N's N",
              "examples": [
                "카요의 부탁 = Kayo's request",
                "할머니의 음식 = grandmother's food",
                "나의 로봇 = my robot"
              ]
            }
          ],
          "examples": [
            {
              "korean": "카요의 부탁을 들어 줄게.",
              "english": "I'll fulfill Kayo's request."
            }
          ]
        }
      ]
    },
