    "grammar": {
      "sections": [
        {
          "id": "g02_reo_gada",
          "tier": "core",
          "title": "-(으)러 가다",
          "title_en": "Going to ~ (purpose)",
          "emoji": "🎯",
          "explanation_en": "Use -(으)러 가다 to say WHY you're going somewhere. Attach it to the verb stem before 가다.",
          "pattern": "Verb stem + -러 가다 (vowel ending) / -으러 가다 (consonant ending)",
          "scene_example": {
            "korean": "호수로 산책하러 갈 사람?",
            "english": "Who wants to go for a walk at the lake?",
            "highlight": "산책하러"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "title": "Vowel stem → -러 가다",
              "content": "산책하다 → 산책하러 가요\n수영하다 → 수영하러 가요\n먹다 → 먹으러 가요"
            },
            {
              "color": "green",
              "title": "Consonant stem → -으러 가다",
              "content": "읽다 → 읽으러 가요\n찾다 → 찾으러 가요"
            },
            {
              "color": "amber",
              "title": "Ask WHY: 왜 가요? · Answer with -(으)러",
              "content": "왜 도서관에 가요?\n→ 책을 빌리러 가요!\n\n왜 공원에 가요?\n→ 운동하러 가요!"
            }
          ],
          "examples": [
            {
              "ko": "나도 운동하러 갈게.",
              "en": "I'll go exercise too."
            },
            {
              "ko": "뭐 먹으러 가요?",
              "en": "What are you going to eat?"
            },
            {
              "ko": "친구 만나러 가요.",
              "en": "I'm going to meet a friend."
            }
          ]
        },
        {
          "id": "g02_ro_direction_means",
          "tier": "core",
          "title": "(으)로 — 방향 & 수단",
          "title_en": "-(으)로: Direction & Means",
          "emoji": "🗺️",
          "explanation_en": "로/으로 has two jobs: showing DIRECTION (toward where) and MEANS (by what / how). Use 으로 after consonants, 로 after vowels or ㄹ.",
          "pattern": "Place + 로/으로 (direction) · Transport/Method + 로/으로 (means)",
          "scene_example": {
            "korean": "난 차로 갈게.",
            "english": "I'll go by car.",
            "highlight": "차로"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "title": "Direction 방향 — toward where?",
              "content": "호수로 가요 · going toward the lake\n학교로 가요 · going toward school\n집으로 가요 · going toward home"
            },
            {
              "color": "green",
              "title": "Means 수단 — by what / how?",
              "content": "차로 가요 · go by car\n버스로 가요 · go by bus\n자전거로 가요 · go by bike\n걸어서 가요 · go on foot (걸어서 not 로)"
            },
            {
              "color": "amber",
              "title": "Ask HOW: 어떻게 가요?",
              "content": "어떻게 가요?\n→ 자전거로 가요!\n→ 지하철로 가요!"
            },
            {
              "color": "amber",
              "title": "Vowel/ㄹ → 로 · Consonant → 으로",
              "content": "차 → 차로 ✅\n버스 → 버스로 ✅\n지하철 → 지하철로 ✅ (ㄹ)\n집 → 집으로 ✅"
            }
          ],
          "example_groups": [
            {
              "label": "방향 Direction",
              "examples": [
                {
                  "ko": "호수로 산책하러 가요.",
                  "en": "I'm going for a walk toward the lake."
                },
                {
                  "ko": "어디로 가요?",
                  "en": "Which way are you going?"
                }
              ]
            },
            {
              "label": "수단 Means",
              "examples": [
                {
                  "ko": "차로 겨우 3분이에요.",
                  "en": "It's barely 3 minutes by car."
                },
                {
                  "ko": "스쿠터 타고 가요.",
                  "en": "I'm going by scooter."
                }
              ]
            }
          ]
        },
        {
          "id": "g02_lge",
          "tier": "core",
          "title": "-ㄹ게요 / -ㄹ게",
          "title_en": "I'll ~ (promise / intention)",
          "emoji": "🤝",
          "explanation_en": "Use -ㄹ게 (informal) or -ㄹ게요 (polite) to make a promise or state your intention to do something.",
          "pattern": "Verb stem + -ㄹ게요 (vowel/ㄹ) / -을게요 (consonant)",
          "scene_example": {
            "korean": "난 차로 갈게.",
            "english": "I'll go by car.",
            "highlight": "갈게"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "title": "Vowel / ㄹ stem → -ㄹ게요",
              "content": "가다 → 갈게요 (I'll go)\n오다 → 올게요 (I'll come)\n하다 → 할게요 (I'll do it)"
            },
            {
              "color": "green",
              "title": "Consonant stem → -을게요",
              "content": "먹다 → 먹을게요 (I'll eat)\n읽다 → 읽을게요 (I'll read)"
            },
            {
              "color": "amber",
              "title": "-ㄹ게 vs -ㄹ게요",
              "content": "갈게 · casual (friends/family)\n갈게요 · polite (teacher/adults)"
            }
          ],
          "examples": [
            {
              "ko": "나도 운동하러 갈게.",
              "en": "I'll go exercise too."
            },
            {
              "ko": "제가 할게요!",
              "en": "I'll do it!"
            },
            {
              "ko": "먼저 갈게요.",
              "en": "I'll go first."
            }
          ]
        },
        {
          "id": "g02_si_preview",
          "tier": "preview",
          "title": "-(으)시- 존댓말",
          "title_en": "Honorific -(으)시- (preview)",
          "emoji": "🙏",
          "explanation_en": "-(으)시- is added to verbs when talking about or to someone older/respected. You'll study this properly later — just notice it in the scene!",
          "pattern": "Verb stem + -(으)시- + ending",
          "scene_example": {
            "korean": "운동을 하셔야 다리가 더 튼튼해져요.",
            "english": "Your legs get stronger when you exercise.",
            "highlight": "하셔야"
          },
          "rule_boxes": [
            {
              "color": "blue",
              "title": "Spot it in the scene!",
              "content": "하다 → 하셔야 (honorific: you should do)\n있다 → 계세요 (honorific: to be/stay)\n먹다 → 드세요 (honorific: please eat)"
            }
          ],
          "examples": [
            {
              "ko": "선생님이 오셨어요.",
              "en": "The teacher has arrived."
            },
            {
              "ko": "할머니가 주무세요.",
              "en": "Grandma is sleeping."
            }
          ]
        }
      ]
    },
