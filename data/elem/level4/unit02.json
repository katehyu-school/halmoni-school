    "grammar": {
      "sections": [
        {
          "id": "g02_reo_gada",
          "tier": "core",
          "title": "-(으)러 가다",
          "subtitle": "Going to ~ (purpose)",
          "pattern": "Verb stem + -러 가다 (vowel) / -으러 가다 (consonant)",
          "description": "Use -(으)러 가다 to say WHY you're going somewhere — attach it to the verb stem before 가다.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 Vowel stem → -러 가다 · 모음으로 끝나면",
              "examples": [
                "산책하다 → 산책하러 가요  (go for a walk)",
                "수영하다 → 수영하러 가요  (go swimming)",
                "보다    → 보러 가요      (go to see/watch)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 Consonant stem → -으러 가다 · 자음으로 끝나면",
              "examples": [
                "먹다 → 먹으러 가요  (go to eat)",
                "읽다 → 읽으러 가요  (go to read)",
                "찾다 → 찾으러 가요  (go to find)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 Ask WHY: 왜 가요? → answer with -(으)러",
              "examples": [
                "왜 도서관에 가요? → 책을 빌리러 가요!",
                "왜 공원에 가요? → 운동하러 가요!"
              ]
            }
          ],
          "examples": [
            {
              "korean": "나도 운동하러 갈게.",
              "english": "I'll go exercise too.",
              "highlight": "운동하러"
            },
            {
              "korean": "뭐 먹으러 가요?",
              "english": "What are you going to eat?",
              "highlight": "먹으러"
            },
            {
              "korean": "친구 만나러 가요.",
              "english": "I'm going to meet a friend.",
              "highlight": "만나러"
            }
          ]
        },
        {
          "id": "g02_ro_direction_means",
          "tier": "core",
          "title": "(으)로 — 방향 & 수단",
          "subtitle": "Direction & Means of Transport",
          "pattern": "Place + 로/으로 (→ direction) · Transport + 로/으로 (→ by what)",
          "description": "로/으로 has two jobs: DIRECTION (toward where) and MEANS (by what). Use 으로 after consonants, 로 after vowels or ㄹ.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🗺️ Direction 방향 — toward where?",
              "examples": [
                "호수로 가요     · going toward the lake",
                "학교로 가요     · going toward school",
                "집으로 가요     · going toward home (집 ends in ㅂ → 으로)"
              ]
            },
            {
              "color": "green",
              "label": "🚗 Means 수단 — by what / how?",
              "examples": [
                "차로 가요       · go by car",
                "버스로 가요     · go by bus",
                "자전거로 가요   · go by bike",
                "걸어서 가요     · go on foot (걸어서, not 로!)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 Vowel/ㄹ → 로 · Consonant → 으로",
              "examples": [
                "차 → 차로 ✅   버스 → 버스로 ✅",
                "지하철 → 지하철로 ✅  (ㄹ ending)",
                "집 → 집으로 ✅  (ㅂ consonant)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "난 차로 갈게.",
              "english": "I'll go by car.",
              "highlight": "차로"
            },
            {
              "korean": "호수로 산책하러 가요.",
              "english": "I'm going for a walk at the lake.",
              "highlight": "호수로"
            },
            {
              "korean": "어떻게 가요? — 지하철로 가요!",
              "english": "How do you get there? — By subway!",
              "highlight": "지하철로"
            }
          ]
        },
        {
          "id": "g02_lge",
          "tier": "core",
          "title": "-ㄹ게요 / -ㄹ게",
          "subtitle": "I'll ~ · Promise or Intention",
          "pattern": "Verb stem + -ㄹ게요 (vowel/ㄹ) / -을게요 (consonant)",
          "description": "Use -ㄹ게 (casual) or -ㄹ게요 (polite) to announce what YOU will do — a personal decision or promise.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 Vowel / ㄹ stem → -ㄹ게요",
              "examples": [
                "가다  → 갈게요   (I'll go)",
                "오다  → 올게요   (I'll come)",
                "하다  → 할게요   (I'll do it)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 Consonant stem → -을게요",
              "examples": [
                "먹다  → 먹을게요  (I'll eat)",
                "읽다  → 읽을게요  (I'll read)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 Casual vs Polite · 반말 vs 존댓말",
              "examples": [
                "갈게  · casual — friends & family",
                "갈게요 · polite — teacher & adults"
              ]
            }
          ],
          "examples": [
            {
              "korean": "나도 운동하러 갈게.",
              "english": "I'll go exercise too.",
              "highlight": "갈게"
            },
            {
              "korean": "제가 할게요!",
              "english": "I'll do it!",
              "highlight": "할게요"
            },
            {
              "korean": "먼저 갈게요.",
              "english": "I'll go first.",
              "highlight": "갈게요"
            }
          ]
        },
        {
          "id": "g02_si_preview",
          "tier": "preview",
          "title": "-(으)시- 존댓말 (preview)",
          "subtitle": "Honorific -(으)시- · coming soon",
          "pattern": "Verb stem + -(으)시- + ending",
          "description": "-(으)시- is added to show respect to older/senior people. You'll study this fully in a later episode — just notice it in the scene!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "👀 Spot it in the scene!",
              "examples": [
                "하다 → 하셔야  (you should do — honorific)",
                "있다 → 계세요  (to be/stay — honorific)",
                "먹다 → 드세요  (please eat — honorific)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "운동을 하셔야 다리가 더 튼튼해져요.",
              "english": "Your legs get stronger when you exercise.",
              "highlight": "하셔야"
            },
            {
              "korean": "선생님이 오셨어요.",
              "english": "The teacher has arrived.",
              "highlight": "오셨어요"
            }
          ]
        }
      ]
    },
