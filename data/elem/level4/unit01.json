    "grammar": {
      "sections": [
        {
          "id": "g01_goisseoyo",
          "tier": "core",
          "title": "-고 있어요",
          "subtitle": "Right now / Currently doing",
          "pattern": "동사 어간 + -고 있어요",
          "meaning": "is -ing (right now)",
          "description": "To say someone is doing something RIGHT NOW, add -고 있어요 to the verb stem. It's like English '-ing'!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 만드는 법 · How to form it",
              "examples": [
                "그리다 → 그리 + 고 있어요 = 그리고 있어요  (is drawing)",
                "먹다 → 먹 + 고 있어요 = 먹고 있어요  (is eating)",
                "자다 → 자 + 고 있어요 = 자고 있어요  (is sleeping)",
                "보다 → 보 + 고 있어요 = 보고 있어요  (is watching)"
              ]
            },
            {
              "color": "green",
              "label": "✅ 질문-답변 패턴 · Q&A pattern",
              "examples": [
                "지금 뭐 하고 있어요? = What are you doing right now?",
                "그림을 그리고 있어요. = I'm drawing a picture.",
                "밥 먹고 있어요. = I'm eating."
              ]
            }
          ],
          "examples": [
            { "korean": "애라는 그림을 그리고 있어요.", "english": "Aera is drawing a picture.", "highlight": "그리고 있어요" },
            { "korean": "지금 뭐 하고 있어요?", "english": "What are you doing right now?", "highlight": "하고 있어요" },
            { "korean": "나는 밥을 먹고 있어요.", "english": "I'm eating.", "highlight": "먹고 있어요" }
          ]
        },
        {
          "id": "g01_gogyeseyo",
          "tier": "preview",
          "title": "-고 계세요",
          "subtitle": "Polite progressive (for elders)",
          "pattern": "동사 어간 + -고 계세요",
          "meaning": "is -ing (polite form)",
          "description": "When talking about what an elder or someone you respect is doing, use -고 계세요 instead of -고 있어요. We'll learn more about 존댓말 progressives in Episode 6!",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 -고 있어요 vs -고 계세요",
              "examples": [
                "엄마가 밥 먹고 있어요. (okay for close family/friends)",
                "선생님이 밥 드시고 계세요. (respectful — teacher eating)",
                "할머니가 주무시고 계세요. (grandma is sleeping — polite)"
              ]
            },
            {
              "color": "amber",
              "label": "💡 ep6에서 더 배울 거예요! More in Episode 6!",
              "examples": [
                "지금은 '하시고 계세요' 패턴만 알아 두세요.",
                "For now, just remember: use -고 계세요 for elders."
              ]
            }
          ],
          "examples": [
            { "korean": "엄마는 일 하시고 계세요.", "english": "Mom is working (polite).", "highlight": "하시고 계세요" },
            { "korean": "할머니가 주무시고 계세요.", "english": "Grandma is sleeping (polite).", "highlight": "주무시고 계세요" }
          ]
        }
      ]
    },
