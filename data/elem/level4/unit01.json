        { "emoji": "🕐", "kr": "지금", "en": "right now", "rom": "ji-geum" }
      ],
      "진행형 표현 Progressive Expressions": [
        { "emoji": "❓", "kr": "뭐 하고 있어요?", "en": "What are you doing?", "rom": "mwo ha-go i-sseo-yo" },
