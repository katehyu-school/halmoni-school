        {
          "id": "g01_i_ga",
          "title": "이/가",
          "subtitle": "Marks the subject of the sentence",
          "pattern": "Consonant ending → 이 / Vowel ending → 가",
          "meaning": "subject marker",
          "rule_boxes": [
            {
              "color": "red",
              "label": "Consonant ending → 이",
              "examples": ["준영 → 준영이 (ends in ㅇ)", "선생님 → 선생님이 (ends in ㅁ)", "보람 → 보람이 (ends in ㅁ)"]
            },
            {
              "color": "blue",
              "label": "Vowel ending → 가",
              "examples": ["민수 → 민수가 (ends in ㅜ)", "슬기 → 슬기가 (ends in ㅣ)", "재우 → 재우가 (ends in ㅜ)"]
            }
          ],
          "examples": [
            {
              "korean": "남자아이가 노래해요.",
              "english": "The boy sings.",
              "highlight": "가"
            },
