    "grammar": {
      "sections": [
        {
          "id": "g04_isseoyo_eopseoyo",
          "title": "있어요 / 없어요",
          "subtitle": "Expresses possession or existence",
          "pattern": "N이/가 있어요 ↔ N이/가 없어요",
          "meaning": "have / don't have",
          "description": "있어요 means 'there is' or 'I have'. 없어요 means 'there isn't' or 'I don't have'. The subject marker 이/가 follows the same consonant/vowel rule from Unit 1.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "Consonant ending → 이",
              "examples": [
                "인형 → 인형이 있어요 (ends in ㅇ)",
                "인형 → 인형이 없어요 (ends in ㅇ)"
              ]
            },
            {
              "color": "blue",
              "label": "Vowel ending → 가",
              "examples": [
                "기차 → 기차가 있어요 (ends in ㅏ)",
                "기차 → 기차가 없어요 (ends in ㅏ)"
              ]
            }
          ],
          "examples": [
            { "korean": "장난감 기차가 있어요.", "english": "There is a toy train. / I have a toy train.", "highlight": "가 있어요" },
            { "korean": "장난감 비행기가 있어요.", "english": "There is a toy airplane.", "highlight": "가 있어요" },
            { "korean": "곰 인형이 있어요.", "english": "There is a teddy bear. / I have a teddy bear.", "highlight": "이 있어요" },
            { "korean": "토끼 인형이 없어요.", "english": "There is no rabbit doll. / I don't have a rabbit doll.", "highlight": "이 없어요" },
            { "korean": "장난감 자동차가 없어요.", "english": "There is no toy car. / I don't have a toy car.", "highlight": "가 없어요" },
            { "korean": "강아지 인형이 있어요.", "english": "There is a puppy doll.", "highlight": "이 있어요" }
          ],
          "qna": [
            { "question": "장난감 기차가 있어요?", "answer": "네, 있어요." },
