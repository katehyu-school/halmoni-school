    "grammar": {
      "sections": [
        {
          "id": "g04_isseoyo_eopseoyo",
          "title": "있어요 / 없어요",
          "subtitle": "Expresses possession or existence",
          "pattern": "N이/가 있어요 ↔ N이/가 없어요",
          "meaning": "have / don't have",
          "description": "있어요 means 'there is' or 'I have'. 없어요 means 'there isn't' or 'I don't have'. The subject marker 이/가 follows the same consonant/vowel rule from Unit 1.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "Consonant ending → 이",
              "examples": [
                "인형 → 인형이 있어요 (ends in ㅇ)",
                "인형 → 인형이 없어요 (ends in ㅇ)"
              ]
            },
            {
              "color": "blue",
              "label": "Vowel ending → 가",
              "examples": [
                "기차 → 기차가 있어요 (ends in ㅏ)",
                "기차 → 기차가 없어요 (ends in ㅏ)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "장난감 기차가 있어요.",
              "english": "There is a toy train. / I have a toy train.",
              "highlight": "가 있어요"
            },
            {
              "korean": "장난감 비행기가 있어요.",
              "english": "There is a toy airplane.",
              "highlight": "가 있어요"
            },
            {
              "korean": "곰 인형이 있어요.",
              "english": "There is a teddy bear. / I have a teddy bear.",
              "highlight": "이 있어요"
            },
            {
              "korean": "토끼 인형이 없어요.",
              "english": "There is no rabbit doll. / I don't have a rabbit doll.",
              "highlight": "이 없어요"
            },
            {
              "korean": "장난감 자동차가 없어요.",
              "english": "There is no toy car. / I don't have a toy car.",
              "highlight": "가 없어요"
            },
            {
              "korean": "강아지 인형이 있어요.",
              "english": "There is a puppy doll.",
              "highlight": "이 있어요"
            }
          ],
          "qna": [
            {
              "question": "장난감 기차가 있어요?",
              "answer": "네, 있어요."
            },
            {
              "question": "곰 인형이 있어요?",
              "answer": "아니요, 없어요."
            },
            {
              "question": "토끼 인형이 있어요?",
              "answer": "네, 있어요."
            },
            {
              "question": "장난감 자동차가 있어요?",
              "answer": "아니요, 없어요."
            }
          ]
        },
        {
          "id": "g04_i_geu_jeo",
          "title": "이 / 그 / 저 — This / That / That over there",
          "subtitle": "Pointing to things!",
          "pattern": "이/그/저 + 명사(noun)",
          "meaning": "this N / that N / that N over there",
          "description": "이/그/저 come BEFORE a noun to point at something. Use 이 for things close to you, 그 for things close to the listener, 저 for things far from both.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "🔴 이 — this (가까이)",
              "examples": [
                "이 사과 = this apple",
                "이 상자 = this box",
                "이 책 = this book"
              ]
            },
            {
              "color": "blue",
              "label": "🔵 그 — that (상대방 쪽)",
              "examples": [
                "그 가방 = that bag",
                "그 의자 = that chair",
                "그 강아지 = that dog"
              ]
            },
            {
              "color": "green",
              "label": "🟢 저 — that over there (멀리)",
              "examples": [
                "저 선반 = that shelf over there",
                "저 방 = that room over there",
                "저 나무 = that tree over there"
              ]
            }
          ],
          "examples": [
            {
              "korean": "이 사과 어디 있어요?",
              "english": "Where is this apple?",
              "highlight": "이"
            },
            {
              "korean": "그 상자 안에 있어요.",
              "english": "It's inside that box.",
              "highlight": "그"
            },
            {
              "korean": "저 선반 위에 없어요.",
              "english": "It's not on that shelf over there.",
              "highlight": "저"
            }
          ],
          "tip": "💡 이/그/저 + 것 = 이것/그것/저것 (this thing / that thing). 말할 때는 이거/그거/저거 라고 줄여요! Already know 이거/그거? Same family! 😊"
        }
      ]
    },
