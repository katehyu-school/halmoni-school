    "grammar": {
      "title": "형용사",
      "title_en": "Describing Words",
      "explanation": "한국어에서 형용사는 문장의 마지막에 와요!",
      "explanation_en": "In Korean, describing words come at the END of the sentence!",
      "rule_boxes": [
        {
          "color": "blue",
          "label": "순서: 주어 + 형용사!",
          "label_en": "Order: Subject + Adjective (at the end!)",
          "examples": [
            "코끼리가 커요.  (The elephant is big.)",
            "피자가 맛있어요.  (Pizza is delicious.)",
            "게임이 재미있어요.  (Games are fun.)"
          ]
        },
        {
          "color": "red",
          "label": "있어요 ↔ 없어요",
          "label_en": "있어요 = have/exist  →  없어요 = don't have/not",
          "examples": [
            "재미있어요  ↔  재미없어요",
            "맛있어요  ↔  맛없어요"
          ]
        },
        {
          "color": "green",
          "label": "반대말! Opposite pairs",
          "label_en": "Korean adjectives come in opposite pairs",
          "examples": [
            "커요 ↔ 작아요   (big ↔ small)",
            "빨라요 ↔ 느려요   (fast ↔ slow)",
            "길어요 ↔ 짧아요   (long ↔ short)",
            "많아요 ↔ 적어요   (many ↔ few)"
          ]
        }
      ]
