          "scene_en": "Music class",
          "lines": [
            { "speaker": "마야", "color": "purple", "text": "올리비아야, 뭐 해요?", "en": "Olivia, what are you doing?", "type": "given" },
            { "speaker": "올리비아", "color": "teal", "text": "노래___! 🎵 같이 해요!", "en": "I'm singing! Let's do it together!", "type": "fill", "ans": "해요", "opts": ["해요", "먹어요", "자요"] },
            { "speaker": "마야", "color": "purple", "text": "나는 춤___! 💃", "en": "I'm dancing!", "type": "fill", "ans": "춰요", "opts": ["춰요", "읽어요", "그려요"] }
          ]
        }
