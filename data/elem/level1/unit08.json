{
  "unit": 8,
  "title": "🎨 그림을 그려요!",
  "book": 1,
  "goal": {
    "ko": "내가 하는 일을 말할 수 있어요! 🖍️",
    "en": "I can say what I'm doing!"
  },
  "key_points": [
    "그림을 그려요 = I draw a picture",
    "뭐 해요? = What are you doing?",
    "~아요/어요 = present tense verb ending"
  ],
  "sections": {
    "vocab": {
      "🎨 활동 Activities": [
        { "emoji": "🎨", "kr": "그리다", "en": "to draw", "rom": "geu-ri-da" },
        { "emoji": "📖", "kr": "읽다", "en": "to read", "rom": "ik-da" },
        { "emoji": "✍️", "kr": "쓰다", "en": "to write", "rom": "sseu-da" },
        { "emoji": "🎵", "kr": "노래하다", "en": "to sing", "rom": "no-rae-ha-da" },
        { "emoji": "💃", "kr": "춤추다", "en": "to dance", "rom": "chum-chu-da" },
        { "emoji": "🏃", "kr": "달리다", "en": "to run", "rom": "dal-li-da" },
        { "emoji": "😴", "kr": "자다", "en": "to sleep", "rom": "ja-da" },
        { "emoji": "🍽️", "kr": "먹다", "en": "to eat", "rom": "meok-da" }
      ],
      "🖼️ 미술 Art": [
        { "emoji": "🖍️", "kr": "크레파스", "en": "crayons", "rom": "keu-re-pa-seu" },
        { "emoji": "🖌️", "kr": "붓", "en": "paintbrush", "rom": "but" },
        { "emoji": "🎨", "kr": "그림", "en": "picture / drawing", "rom": "geu-rim" },
        { "emoji": "📄", "kr": "종이", "en": "paper", "rom": "jong-i" }
      ]
    },
    "grammar": {
      "sections": [
        {
          "id": "g08_ayo_eoyo",
          "title": "동사 + 아요/어요",
          "subtitle": "Present tense action verbs",
          "pattern": "verb stem + 아요 (ㅏ/ㅗ) · 어요 (other vowels)",
          "meaning": "What someone is doing right now",
          "description": "To say what you're doing NOW, add 아요 or 어요 to the verb stem. The vowel in the stem decides which one!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 ㅏ or ㅗ stem → 아요",
              "examples": [
                "자다 → 자 + 아요 → 자요 (sleep)",
                "오다 → 와요 (come) — special!"
              ]
            },
            {
              "color": "coral",
              "label": "🔴 Other vowels → 어요",
              "examples": [
                "먹다 → 먹 + 어요 → 먹어요 (eat)",
                "읽다 → 읽 + 어요 → 읽어요 (read)"
              ]
            },
            {
              "color": "green",
              "label": "🟢 하다 verbs → 해요",
              "examples": [
                "노래하다 → 노래해요 (sing)",
                "춤추다 → 춤춰요 (dance) — special!"
              ]
            }
          ],
          "examples": [
            { "korean": "그림을 그려요.", "english": "I'm drawing a picture.", "highlight": "그려요" },
            { "korean": "책을 읽어요.", "english": "I'm reading a book.", "highlight": "읽어요" },
            { "korean": "노래해요!", "english": "I'm singing!", "highlight": "노래해요" },
            { "korean": "뭐 해요? — 먹어요!", "english": "What are you doing? — I'm eating!", "highlight": "먹어요" }
          ]
        }
      ]
    },
    "practice": {
