            { "speaker": "루카스", "color": "amber", "text": "책을 ___. 📖", "en": "I'm reading a book.", "type": "fill", "ans": "읽어요", "opts": ["읽어요", "써요", "그려요"] },
            { "speaker": "해리", "color": "blue", "text": "나는 편지를 ___. ✍️", "en": "I'm writing a letter.", "type": "fill", "ans": "써요", "opts": ["써요", "읽어요", "먹어요"] }
          ]
        },
        {
