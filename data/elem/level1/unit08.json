            { "speaker": "애라", "color": "coral", "text": "그림을 ___! 🎨", "en": "I'm drawing a picture!", "type": "fill", "ans": "그려요", "opts": ["그려요", "먹어요", "자요"] },
            { "speaker": "선생님", "color": "green", "text": "와, 예쁜 그림이에요! 뭐 그려요?", "en": "Wow, pretty picture! What are you drawing?", "type": "given" },
            { "speaker": "애라", "color": "coral", "text": "고양이를 그려요! 🐱", "en": "I'm drawing a cat!", "type": "given" }
          ]
        },
