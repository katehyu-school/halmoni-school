{
  "unit": 1,
  "title": "👋 안녕하세요?",
  "book": 1,
  "goal": {
    "ko": "인사하고 이름을 말할 수 있어요! 🌟",
    "en": "I can say hello and tell my name!"
  },
  "key_points": [
    "안녕하세요 = Hello (to adults)",
    "안녕 = Hi (to friends)",
    "저는 ___이에요/예요 = My name is ___"
  ],
  "sections": {
    "vocab": {
      "👋 인사 Greetings": [
        { "emoji": "😊", "kr": "안녕하세요?", "en": "Hello! (to adults)", "rom": "an-nyeong-ha-se-yo" },
        { "emoji": "🤗", "kr": "안녕?", "en": "Hi! (to friends)", "rom": "an-nyeong" },
        { "emoji": "🚶", "kr": "안녕히 가세요.", "en": "Goodbye (you're leaving)", "rom": "an-nyeong-hi ga-se-yo" },
        { "emoji": "🏠", "kr": "안녕히 계세요.", "en": "Goodbye (I'm leaving)", "rom": "an-nyeong-hi gye-se-yo" },
        { "emoji": "🙏", "kr": "고맙습니다.", "en": "Thank you!", "rom": "go-map-seum-ni-da" }
      ],
      "🏷️ 이름 Names": [
        { "emoji": "🙋‍♀️", "kr": "이름이 뭐예요?", "en": "What is your name?", "rom": "i-reum-i mwo-ye-yo" },
        { "emoji": "😄", "kr": "저는 ___예요.", "en": "My name is ___.", "rom": "jeo-neun ___ye-yo" },
        { "emoji": "😄", "kr": "저는 ___이에요.", "en": "My name is ___.", "rom": "jeo-neun ___i-e-yo" }
      ]
    },
    "grammar": {
      "sections": [
        {
          "id": "g01_ieyo",
          "title": "저는 ___이에요 / ___예요",
          "subtitle": "My name is ___ · How to say who you are",
          "pattern": "저는 + NAME + 이에요/예요",
          "meaning": "My name is ___",
          "description": "In Korean, 'I am ___' uses two different endings depending on the last sound of the word. If the name ends with a consonant (받침), add 이에요. If it ends with a vowel, add 예요.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 받침 있으면 → 이에요",
              "examples": [
                "해리 → 해리예요? ❌  →  해리이에요? 🤔  →  해리예요 ✅  (ㅣ ends in vowel!)",
                "리암 → 리암이에요 ✅  (ㅁ is a consonant!)"
              ]
            },
            {
              "color": "coral",
              "label": "🔴 받침 없으면 → 예요",
              "examples": [
                "애라 → 애라예요 ✅  (ㅏ ends in vowel!)",
                "마야 → 마야예요 ✅",
                "올리비아 → 올리비아예요 ✅"
              ]
            }
          ],
          "examples": [
            { "korean": "저는 애라예요.", "english": "My name is Aera.", "highlight": "예요" },
            { "korean": "저는 해리예요.", "english": "My name is Harry.", "highlight": "예요" },
            { "korean": "저는 리암이에요.", "english": "My name is Liam.", "highlight": "이에요" },
            { "korean": "저는 루카스예요.", "english": "My name is Lucas.", "highlight": "예요" }
          ]
        },
        {
          "id": "g01_greetings",
          "title": "안녕하세요 vs 안녕",
          "subtitle": "Formal Hello vs Casual Hi",
          "pattern": "상대방에 따라 다른 인사",
          "meaning": "Who are you talking to?",
          "description": "Korean has two levels of greeting — one for adults and teachers, one for friends and younger kids. Always use 안녕하세요 with grown-ups!",
          "rule_boxes": [
            {
              "color": "red",
              "label": "👨‍🏫 어른 Adults & Teachers",
              "examples": ["안녕하세요? ✅", "안녕? ❌"]
            },
            {
              "color": "green",
              "label": "👫 친구 Friends & classmates",
              "examples": ["안녕? ✅", "안녕하세요? 🤷 (too formal but OK)"]
            }
          ],
          "examples": [
            { "korean": "선생님, 안녕하세요!", "english": "Hello, teacher!", "highlight": "안녕하세요" },
            { "korean": "해리야, 안녕!", "english": "Hi, Harry!", "highlight": "안녕" }
          ]
        }
      ]
    },
