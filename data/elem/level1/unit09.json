    "grammar": {
      "sections": [
        {
          "id": "g09_joahaeyo",
          "title": "N을/를 좋아해요 · 싫어해요",
          "subtitle": "Likes and dislikes",
          "pattern": "N을/를 좋아해요 · 싫어해요",
          "meaning": "Saying what you like or dislike",
          "description": "Use 좋아해요 to say you like something and 싫어해요 for dislike. Add 을/를 after the thing you like/dislike!",
          "rule_boxes": [
            {
              "color": "green",
              "label": "❤️ 좋아해요 — I LIKE",
              "examples": [
                "사과를 좋아해요. = I like apples.",
                "축구를 좋아해요. = I like soccer.",
                "음악을 좋아해요. = I like music."
              ]
            },
            {
              "color": "red",
              "label": "💔 싫어해요 — I DON'T LIKE",
              "examples": [
                "라면을 싫어해요. = I don't like ramen.",
                "수영을 싫어해요. = I don't like swimming."
              ]
            },
            {
              "color": "blue",
              "label": "🔵 을/를 after N (object particle)",
              "examples": [
                "받침 있으면 → 을 (음악을, 축구를❌→축구를✅)",
                "받침 없으면 → 를 (사과를, 음악→음악을✅)",
                "💡 받침 있으면 을, 없으면 를 (same rule as 이에요/예요!)"
              ]
            }
          ],
          "examples": [
            { "korean": "뭐를 좋아해요? — 딸기를 좋아해요!", "english": "What do you like? — I like strawberries!", "highlight": "좋아해요" },
            { "korean": "피자를 좋아해요? — 네, 아주 좋아해요!", "english": "Do you like pizza? — Yes, I really like it!", "highlight": "좋아해요" },
            { "korean": "뭐를 싫어해요? — 라면을 싫어해요.", "english": "What don't you like? — I don't like ramen.", "highlight": "싫어해요" }
          ]
        }
      ]
    },
