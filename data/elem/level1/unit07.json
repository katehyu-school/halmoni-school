    "grammar": {
      "sections": [
        {
          "id": "g07_isseo_eopseo",
          "title": "있어요 / 없어요",
          "subtitle": "There is / There isn't",
          "pattern": "장소에 N이/가 있어요 · 없어요",
          "meaning": "Something exists (or doesn't) in a place",
          "description": "있어요 means 'there is' or 'I have'. 없어요 is the opposite — 'there isn't' or 'I don't have'. Add 에 after the place!",
          "rule_boxes": [
            {
              "color": "green",
              "label": "✅ 있어요 — There IS / I HAVE",
              "examples": [
                "방에 침대가 있어요. = There is a bed in the room.",
                "책상이 있어요. = There is a desk.",
                "고양이가 있어요. = There is a cat."
              ]
            },
            {
              "color": "red",
              "label": "❌ 없어요 — There ISN'T / I DON'T HAVE",
              "examples": [
                "방에 텔레비전이 없어요. = There's no TV in the room.",
                "화분이 없어요. = There is no plant.",
                "강아지가 없어요. = There is no dog."
              ]
            },
            {
              "color": "blue",
              "label": "📍 장소 + 에 → 에 marks LOCATION",
              "examples": [
                "방에 = in the room",
                "거실에 = in the living room",
                "부엌에 = in the kitchen"
              ]
            }
          ],
          "examples": [
            { "korean": "방에 침대가 있어요.", "english": "There is a bed in the room.", "highlight": "있어요" },
            { "korean": "방에 텔레비전이 없어요.", "english": "There is no TV in the room.", "highlight": "없어요" },
            { "korean": "거실에 소파가 있어요.", "english": "There is a sofa in the living room.", "highlight": "있어요" }
          ]
        }
      ]
    },
    "practice": {
