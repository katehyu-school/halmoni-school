        { "emoji": "✅", "kr": "네", "en": "Yes", "rom": "ne" },
        { "emoji": "❌", "kr": "아니요", "en": "No", "rom": "a-ni-yo" }
      ]
    },
    "grammar": {
      "sections": [
        {
          "id": "g03_yes_no",
          "title": "네 / 아니요",
          "subtitle": "Yes / No — The most important words!",
          "pattern": "이게 N이에요/예요? → 네 / 아니요, N이에요/예요.",
          "meaning": "Answering yes/no questions",
          "description": "In Korean, 네 means yes and 아니요 means no. When you say no, you also say what it actually IS! '아니요, ___이에요/예요.'",
          "rule_boxes": [
            {
              "color": "green",
              "label": "✅ 네 — Yes!",
              "examples": [
                "이게 빵이에요? → 네, 빵이에요! (Yes, it's bread!)"
              ]
            },
            {
              "color": "red",
              "label": "❌ 아니요 — No! (+ what it really is)",
              "examples": [
                "이게 빵이에요? → 아니요, 우유예요. (No, it's milk.)",
                "이게 고양이예요? → 아니요, 강아지예요. (No, it's a puppy.)"
              ]
            }
          ],
          "examples": [
            { "korean": "이게 사탕이에요? — 네, 사탕이에요!", "english": "Is this candy? — Yes, it's candy!", "highlight": "네" },
            { "korean": "이게 주스예요? — 아니요, 우유예요.", "english": "Is this juice? — No, it's milk.", "highlight": "아니요" },
            { "korean": "이게 토끼예요? — 아니요, 곰이에요!", "english": "Is this a rabbit? — No, it's a bear!", "highlight": "아니요" }
          ]
        }
      ]
    },
