{
  "unit": 3,
  "title": "🍞 네, 빵이에요!",
  "book": 1,
  "goal": {
    "ko": "네/아니요로 대답할 수 있어요! ✅❌",
    "en": "I can answer yes and no in Korean!"
  },
  "key_points": [
    "네 = Yes",
    "아니요 = No",
    "이게 ___이에요? = Is this ___?"
  ],
