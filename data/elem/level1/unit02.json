            { "speaker": "애라", "color": "coral", "text": "___예요! 같이 써요~ 🖍️", "en": "It's a crayon! Let's use it together~", "type": "fill", "ans": "크레파스", "opts": ["크레파스", "색종이", "가위"] },
            { "speaker": "해리", "color": "blue", "text": "와, 색연필도 있어요?", "en": "Wow, are there colored pencils too?", "type": "given" },
            { "speaker": "애라", "color": "coral", "text": "네, 이게 색연필이에요! 🎨", "en": "Yes, this is the colored pencils!", "type": "given" }
          ]
        },
        {
          "scene": "🔍 교실 탐험 — Classroom exploration",
          "scene_en": "Exploring the classroom",
          "lines": [
