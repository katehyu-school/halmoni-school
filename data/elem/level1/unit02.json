{
  "unit": 2,
  "title": "🖊️ 이게 뭐예요?",
  "book": 1,
  "goal": {
    "ko": "교실 물건 이름을 말할 수 있어요! 🏫",
    "en": "I can name things in the classroom!"
  },
  "key_points": [
    "이게 = this (thing near me)",
    "저게 = that (thing far away)",
    "이게 뭐예요? = What is this?"
  ],
  "sections": {
    "vocab": {
      "🏫 교실 물건 Classroom Things": [
        { "emoji": "👩‍🏫", "kr": "선생님", "en": "teacher", "rom": "seon-saeng-nim" },
        { "emoji": "🪑", "kr": "책상", "en": "desk", "rom": "chaek-sang" },
        { "emoji": "💺", "kr": "의자", "en": "chair", "rom": "ui-ja" },
        { "emoji": "🖊️", "kr": "칠판", "en": "blackboard", "rom": "chil-pan" },
        { "emoji": "🕐", "kr": "시계", "en": "clock", "rom": "si-gye" },
        { "emoji": "🩹", "kr": "지우개", "en": "eraser", "rom": "ji-u-gae" },
        { "emoji": "📚", "kr": "책", "en": "book", "rom": "chaek" },
        { "emoji": "📓", "kr": "공책", "en": "notebook", "rom": "gong-chaek" },
        { "emoji": "✏️", "kr": "연필", "en": "pencil", "rom": "yeon-pil" }
      ],
      "🎨 미술 도구 Art Supplies (보너스!)": [
        { "emoji": "✂️", "kr": "가위", "en": "scissors", "rom": "ga-wi" },
        { "emoji": "🗂️", "kr": "풀", "en": "glue", "rom": "pul" },
        { "emoji": "🌈", "kr": "색종이", "en": "colored paper", "rom": "saek-jong-i" },
        { "emoji": "🖍️", "kr": "크레파스", "en": "crayons", "rom": "keu-re-pa-seu" },
        { "emoji": "🎨", "kr": "색연필", "en": "colored pencils", "rom": "saeng-yeon-pil" }
      ]
    },
    "grammar": {
      "sections": [
        {
          "id": "g02_ige_jeoge",
          "title": "이게 vs 저게",
          "subtitle": "This vs That",
          "pattern": "이게 (near me) · 저게 (far away)",
          "meaning": "pointing at things",
          "description": "In Korean, 이게 means 'this' (something close to you) and 저게 means 'that' (something far away). Use them before 뭐예요? to ask what something is!",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "👉 이게 — This (close to me)",
              "examples": ["이게 뭐예요? = What is THIS? (pointing to something nearby)"]
            },
            {
              "color": "purple",
              "label": "👉👉 저게 — That (far from me)",
              "examples": ["저게 뭐예요? = What is THAT? (pointing to something far)"]
            }
          ],
          "examples": [
            { "korean": "이게 뭐예요?", "english": "What is this?", "highlight": "이게" },
            { "korean": "저게 뭐예요?", "english": "What is that?", "highlight": "저게" },
            { "korean": "연필이에요.", "english": "It's a pencil.", "highlight": "연필이에요" },
            { "korean": "시계예요.", "english": "It's a clock.", "highlight": "시계예요" }
          ]
        },
        {
          "id": "g02_ieyo_review",
          "title": "N이에요 / N예요 — 복습!",
          "subtitle": "Naming things (review from Unit 1)",
          "pattern": "N (받침 O) + 이에요 · N (받침 X) + 예요",
          "meaning": "It is ___",
          "description": "Remember the rule from Unit 1! Same ending for names AND for things.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "🔵 받침 있으면 → 이에요",
              "examples": ["책 → 책이에요 ✅", "칠판 → 칠판이에요 ✅", "연필 → 연필이에요 ✅"]
            },
            {
              "color": "coral",
              "label": "🔴 받침 없으면 → 예요",
              "examples": ["의자 → 의자예요 ✅", "시계 → 시계예요 ✅", "지우개 → 지우개예요 ✅"]
            }
          ],
          "examples": [
            { "korean": "이게 뭐예요? — 책이에요.", "english": "What is this? — It's a book.", "highlight": "책이에요" },
            { "korean": "저게 뭐예요? — 의자예요.", "english": "What is that? — It's a chair.", "highlight": "의자예요" }
          ]
        }
      ]
    },
    "practice": {
      "dialogue_practice": [
        {
          "scene": "🏫 교실에서 — In the classroom",
          "scene_en": "In the classroom",
          "lines": [
            { "speaker": "애라", "color": "coral", "text": "선생님, 이게 뭐예요?", "en": "Teacher, what is this?", "type": "given" },
