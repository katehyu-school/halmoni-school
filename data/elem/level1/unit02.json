            { "speaker": "해리", "color": "blue", "text": "___이에요!", "en": "It's a blackboard!", "type": "fill", "ans": "칠판", "opts": ["칠판", "책상", "공책"] },
            { "speaker": "루카스", "color": "amber", "text": "이게 뭐야?", "en": "What is this?", "type": "given" },
            { "speaker": "해리", "color": "blue", "text": "___이에요. 앉아봐요! 😄", "en": "It's a chair. Let's sit!", "type": "fill", "ans": "의자", "opts": ["의자", "책상", "지우개"] }
          ]
        }
      ],
