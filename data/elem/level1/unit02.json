            { "speaker": "애라", "color": "coral", "text": "저게 뭐예요?", "en": "What is that?", "type": "given" },
            { "speaker": "선생님", "color": "green", "text": "___예요.", "en": "It's a clock.", "type": "fill", "ans": "시계", "opts": ["시계", "의자", "칠판"] }
          ]
