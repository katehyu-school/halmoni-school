{
  "unit": 5,
  "title": "🏠 집이 어디예요?",
  "book": 1,
  "goal": {
    "ko": "장소 이름을 알고 어디인지 말할 수 있어요! 🗺️",
    "en": "I can name places and say where things are!"
  },
  "key_points": [
    "어디예요? = Where is it?",
    "여기예요 = It's here (near me)",
    "저기예요 = It's there (far away)"
  ],
  "sections": {
    "vocab": {
      "🏘️ 장소 Places": [
        { "emoji": "🏫", "kr": "학교", "en": "school", "rom": "hak-gyo" },
        { "emoji": "🏛️", "kr": "교실", "en": "classroom", "rom": "gyo-sil" },
        { "emoji": "🏠", "kr": "집", "en": "house / home", "rom": "jip" },
        { "emoji": "🛏️", "kr": "방", "en": "room", "rom": "bang" },
        { "emoji": "🍳", "kr": "부엌", "en": "kitchen", "rom": "bu-eok" },
        { "emoji": "🌳", "kr": "공원", "en": "park", "rom": "gong-won" },
        { "emoji": "🏊", "kr": "수영장", "en": "swimming pool", "rom": "su-yeong-jang" },
        { "emoji": "🏪", "kr": "가게", "en": "store / shop", "rom": "ga-ge" }
      ],
      "📍 위치 Location Words": [
        { "emoji": "👇", "kr": "여기", "en": "here (near me)", "rom": "yeo-gi" },
        { "emoji": "👉", "kr": "저기", "en": "there (far away)", "rom": "jeo-gi" }
      ]
    },
    "grammar": {
      "sections": [
        {
          "id": "g05_eodie",
          "title": "어디예요? — Where is it?",
          "subtitle": "Asking about location",
          "pattern": "N이/가 어디예요? → 여기예요 / 저기예요",
          "meaning": "Where is ___?",
          "description": "Use 어디예요? to ask where something or someone is. Answer with 여기예요 (it's here, near me) or 저기예요 (it's there, far away).",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "❓ N이/가 어디예요? = Where is N?",
              "examples": [
                "집이 어디예요? = Where is your house?",
                "학교가 어디예요? = Where is the school?"
              ]
            },
            {
              "color": "green",
              "label": "👇 여기예요 = It's HERE (close to me)",
              "examples": ["집이 어디예요? → 여기예요! (pointing to nearby)"]
            },
            {
              "color": "coral",
              "label": "👉 저기예요 = It's THERE (far from me)",
              "examples": ["학교가 어디예요? → 저기예요! (pointing far away)"]
            }
          ],
          "examples": [
            { "korean": "집이 어디예요? — 여기예요.", "english": "Where is your house? — It's here.", "highlight": "여기예요" },
            { "korean": "학교가 어디예요? — 저기예요.", "english": "Where is the school? — It's there.", "highlight": "저기예요" },
            { "korean": "공원이 어디예요? — 저기예요!", "english": "Where is the park? — It's over there!", "highlight": "저기예요" }
          ]
        },
        {
          "id": "g05_yeogi_jeogi",
          "title": "여기가 N이에요/예요",
          "subtitle": "Naming a place you're pointing at",
          "pattern": "여기가 N이에요/예요 · 저기가 N이에요/예요",
          "meaning": "This place is N · That place is N",
          "description": "You can also flip it! Instead of 'Where is X?', say 'This is X!' Use 여기가 (here is) or 저기가 (there is) + place name.",
          "rule_boxes": [
            {
              "color": "purple",
              "label": "📍 여기가/저기가 + 장소",
              "examples": [
                "여기가 우리 집이에요. = This is my house.",
                "저기가 수영장이에요. = That is the swimming pool.",
                "여기가 부엌이에요. = This is the kitchen."
              ]
            }
          ],
          "examples": [
            { "korean": "여기가 우리 집이에요.", "english": "This is my house.", "highlight": "여기가" },
            { "korean": "저기가 학교예요.", "english": "That is the school.", "highlight": "저기가" }
          ]
        }
      ]
    },
