  "title": "이름이 뭐야? What's your name?",
  "phase": "sentence",
  "goal": {
    "ko": "N이에요/예요로 이름을 말할 수 있어요!",
    "en": "I can introduce names using N이에요/예요!"
  },
  "pattern": {
    "rule": "N + 이에요 / 예요",
    "note_ko": "받침 있으면 이에요, 받침 없으면 예요",
    "note_en": "End in a consonant → 이에요 / End in a vowel → 예요",
    "examples": [
      {
        "kr": "강아지예요.",
        "en": "It's a dog.",
        "note": "강아지 ends in 이(vowel) → 예요"
      },
      {
        "kr": "고양이예요.",
        "en": "It's a cat.",
        "note": "고양이 ends in 이(vowel) → 예요"
      },
      {
        "kr": "곰이에요.",
        "en": "It's a bear.",
        "note": "곰 ends in ㅁ(consonant) → 이에요"
      },
      {
        "kr": "달이에요.",
        "en": "It's the moon.",
        "note": "달 ends in ㄹ(consonant) → 이에요"
      }
    ]
  },
