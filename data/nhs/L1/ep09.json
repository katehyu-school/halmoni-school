  "script": [
    {
      "speaker": "할아버지",
      "slide": 0,
      "text": "안녕하세요?",
      "en": "Hello!",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/1안녕하세요_slide1.mp3"
    },
    {
      "speaker": "상인",
      "slide": 1,
      "text": "어서 오세요!",
      "en": "Welcome!",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/2어서+오세요_slide2.mp3"
    },
    {
      "speaker": "할머니",
      "slide": 2,
      "text": "오늘 과일 뭐가 좋아요?",
      "en": "What fruit is good today?",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/3오늘+과일+뭐가+좋아요_slide3.mp3"
    },
    {
      "speaker": "상인",
      "slide": 3,
      "text": "요새 딸기가 제철이에요. 아주 맛있어요.",
      "en": "Strawberries are in season these days. They're very delicious.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/4요새+딸기가+제철이에요_+아주+맛있어요_slide4.mp3"
    },
    {
      "speaker": "할머니",
      "slide": 4,
      "text": "그래요? 그럼 딸기 한 박스하고 사과 여섯 개 주세요.",
      "en": "Really? Then please give me one box of strawberries and six apples.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/5그래요_+그럼+딸기+한+박스하고+사과+여섯+개+주세요_slide5.mp3"
    },
    {
      "speaker": "상인",
      "slide": 5,
      "text": "네, 딸기 만오천 원하고 사과 만 원, 모두 이만오천 원이에요.",
      "en": "Yes, strawberries are 15,000 won and apples are 10,000 won — 25,000 won in total.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/6네+딸기+만오천+원하고+사과+만+원+모두+이만오천+원이에요_slide6.mp3"
    },
    {
      "speaker": "할머니",
      "slide": 6,
      "text": "여기 있어요.",
      "en": "Here you go.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/7여기+있어요_slide7.mp3"
    },
    {
      "speaker": "상인",
      "slide": 7,
      "text": "감사합니다. 거스름돈 오천 원 여기요.",
      "en": "Thank you. Here's your change — 5,000 won.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/8감사합니다_+거스름+돈+오천+원+여기요_slide8.mp3"
    },
    {
      "speaker": "할아버지",
      "slide": 8,
      "text": "소고기는 한 근에 얼마예요?",
      "en": "How much is beef per geun (600g)?",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/9소고기는+한근에+얼마예요_slide9.mp3"
    },
    {
      "speaker": "상인",
      "slide": 9,
      "text": "그건, 잘 모르겠는데요.",
      "en": "That, I'm not sure about.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep09/10그건+잘+모르겠는데요_slide10.mp3"
    }
  ],
