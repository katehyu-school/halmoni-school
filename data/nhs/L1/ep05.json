  "script": [
    {
      "speaker": "narrator",
      "text": "여기는 동물원이 아니에요. 놀이공원이에요!",
      "en": "This isn't a zoo. It's an amusement park!",
      "slide": 0,
      "audio": "data/nhs/L1/TTS/ep05/1여기는+동물원이+아니에요_+놀이공원이에요_slide1.mp3"
    },
    {
      "speaker": "jungmin",
      "text": "헐! 청소년 표 한 장이 오만오천 원이야!",
      "en": "Oh my! A youth ticket is 55,000 won!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep05/2헐!+청소년+표+한+장이+오만오천+원이야_slide2.mp3",
      "slide": 1
    },
    {
      "speaker": "mina",
      "text": "와, 너무 비싸다.",
      "en": "Wow, that's too expensive.",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep05/3와+너무+비싸다_slide3.mp3",
      "slide": 2
    },
    {
      "speaker": "jungmin",
      "text": "그래도 들어가자!",
      "en": "Let's go in anyway!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep05/4그래도+들어가자_slide4.mp3",
      "slide": 3
    },
    {
      "speaker": "mina",
      "text": "돈이 얼마 있지?",
      "en": "How much money do we have?",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep05/5돈이+얼마+있지_slide5.mp3",
      "slide": 4
    },
    {
      "speaker": "jungmin",
      "text": "청소년 표 세 장 주세요.",
      "en": "Three youth tickets, please.",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep05/6청소년+표+세+장+주세요_slide6.mp3",
      "slide": 5
    },
    {
      "speaker": "mina",
      "text": "모두 얼마예요?",
      "en": "How much is it altogether?",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep05/7모두+얼마예요_slide7.mp3",
      "slide": 6
    },
    {
      "speaker": "staff",
      "text": "십육만오천 원이에요.",
      "en": "It's 165,000 won.",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep05/8십육만오천+원이에요_slide8.mp3",
      "slide": 7
    },
    {
      "speaker": "jungmin",
      "text": "감사합니다!",
      "en": "Thank you!",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep05/9감사합니다!+야호!+신난다_slide9.mp3",
      "slide": 8
    },
    {
      "speaker": "mina",
      "text": "야호! 신난다!",
      "en": "Yay! This is exciting!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep05/9감사합니다!+야호!+신난다_slide9.mp3",
      "slide": 8
    },
    {
      "speaker": "jungmin",
      "text": "대박! 너무 좋아!",
      "en": "Awesome! This is so good!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep05/10대박!+너무+좋아_slide10.mp3",
      "slide": 9
    }
