  "grammar": [
    {
      "id": "g_ep03_01",
      "title": "이/가 아니에요",
      "title_en": "It's not ~ (Negative Identification)",
      "icon": "🚫",
      "rule": "받침 O → 이 아니에요 | 받침 X → 가 아니에요",
      "pattern": "명사 + 이/가 + 아니에요",
      "explanation_en": "Use 이/가 아니에요 to say something is NOT something else. Pick 이 after a noun ending in a consonant (받침 O), and 가 after a noun ending in a vowel (받침 X). In casual speech (반말), use 이/가 아니야.",
      "table": {
        "columns": [
          "Noun ending",
          "Particle",
          "Full form",
          "Example"
        ],
        "rows": [
          [
            "consonant (받침 O)",
            "이",
            "이 아니에요",
            "동물원이 아니에요."
          ],
          [
            "vowel (받침 X)",
            "가",
            "가 아니에요",
            "가게가 아니에요."
          ],
          [
            "casual (반말)",
            "(이/가)",
            "이/가 아니야",
            "동물원이 아니야!"
          ]
        ]
      },
      "examples": [
        {
          "ko": "여기는 동물원이 아니에요. 놀이공원이에요!",
          "en": "This isn't a zoo. It's an amusement park!"
        },
        {
          "ko": "저는 선생님이 아니에요. 학생이에요.",
          "en": "I'm not a teacher. I'm a student."
        },
        {
          "ko": "이거 물이 아니에요. 주스예요.",
          "en": "This isn't water. It's juice."
        },
        {
          "ko": "오늘은 월요일이 아니에요. 화요일이에요.",
          "en": "Today isn't Monday. It's Tuesday."
        }
      ],
      "fill_blanks": [
        {
          "sentence": "이거 밥이 아니에요. 국___이에요.",
          "answer": "수",
          "hint": "밥 아니면? → 국수!"
        },
        {
          "sentence": "여기는 학교___아니에요. 도서관이에요.",
          "answer": "가",
          "hint": "학교 ends in a vowel → 가"
        },
        {
          "sentence": "저는 미국 사람이 ___이에요. 한국 사람이에요.",
          "answer": "아니",
          "hint": "'not' = 아니(에요)"
        }
      ]
    },
