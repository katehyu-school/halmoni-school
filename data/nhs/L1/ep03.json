  "script": [
    {
      "speaker": "narrator",
      "text": "여기는 우리 집이에요.",
      "en": "This is our house.",
      "speech_type": "나레이터",
      "audio": "data/nhs/L1/TTS/ep03/01여기는+우리+집이에요_slide1.mp3",
      "slide": 0
    },
    {
      "speaker": "narrator",
      "text": "저는 동생하고 배구를 해요.",
      "en": "I'm playing volleyball with my sibling.",
      "speech_type": "나레이터",
      "audio": "data/nhs/L1/TTS/ep03/02저는+동생하고+배구를+해요_slide2.mp3",
      "slide": 1,
      "annotation": {
        "highlight": "배구를",
        "grammar": "을/를 목적격 조사",
        "note": "받침 O → 을  |  받침 X → 를\n배구 + 를 → 배구를 ✅\n밥 + 을 → 밥을 ✅\n'배구를 해요' = play volleyball"
      }
    },
    {
      "speaker": "na",
      "text": "내 공 받아!",
      "en": "Catch my ball!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep03/03내공+받아_slide3.mp3",
      "slide": 2
    },
    {
      "speaker": "dongsaeng",
      "text": "알았어!",
      "en": "Got it!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep03/04알았어_slide3.mp3",
      "slide": 2
    },
    {
      "speaker": "mom",
      "text": "얘들아~ 밥 먹어!",
      "en": "Kids~ time to eat!",
      "speech_type": "반말",
      "audio": "data/nhs/L1/TTS/ep03/05얘들아~+밥+먹어slide4.mp3",
      "slide": 3
    },
    {
      "speaker": "narrator",
      "text": "우리는 저녁 밥을 먹어요.",
      "en": "We eat dinner.",
      "speech_type": "나레이터",
      "audio": "data/nhs/L1/TTS/ep03/06우리는+저녁+밥을+먹어요_slide5.mp3",
      "slide": 4
    },
    {
      "speaker": "mom",
      "text": "모두들 맛있게 먹어요.",
      "en": "Everyone, enjoy your meal!",
      "speech_type": "casual 존댓말",
      "audio": "data/nhs/L1/TTS/ep03/07모두들+맛있게+먹어요slide6.mp3",
      "slide": 5
    },
    {
      "speaker": "dongsaeng",
      "text": "잘 먹겠습니다!",
      "en": "Thank you for the food! (before eating)",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep03/08잘+먹겠습니다slide6.mp3",
      "slide": 5,
      "annotation": {
        "highlight": "잘 먹겠습니다",
        "grammar": "먹겠습니다 — 겠 (의지/예고)",
        "note": "V-겠습니다 = I will ~ (formal intention)\n먹겠습니다 = I will eat (before meal)\n먹었습니다 = I ate (after meal)"
      }
    },
    {
      "speaker": "na",
      "text": "잘 먹겠습니다!",
      "en": "Thank you for the food! (before eating)",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep03/09잘+먹겠습니다slide6.mp3",
      "slide": 5
    },
    {
      "speaker": "na",
      "text": "엄마, 이거 너무 맛있어요!",
      "en": "Mom, this is so delicious!",
      "speech_type": "존댓말",
      "audio": "data/nhs/L1/TTS/ep03/10엄마이거너무맛있어요slide7.mp3",
      "slide": 6,
      "annotation": {
        "highlight": "이거",
