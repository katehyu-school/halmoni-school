  "usage": [
    {
      "title": "여기 / 거기 / 저기",
      "title_en": "Here / There / Over There",
      "explanation_en": "Korean has three distance-based words for 'here/there', matching 이/그/저 (this/that/that over there). The choice depends on proximity to the speaker and listener.",
      "examples": [
        {
          "ko": "여기 있어요!",
          "en": "It's HERE! (near me, the speaker)"
        },
        {
          "ko": "거기 봐요.",
          "en": "Look THERE. (near you, the listener)"
        },
        {
          "ko": "저기가 서울이에요.",
          "en": "OVER THERE is Seoul. (far from both)"
        }
      ]
    },
    {
      "title": "학교 다녀오겠습니다 / 잘 다녀와",
      "title_en": "Going-Out Greetings",
      "explanation_en": "These fixed expressions are used when leaving home. They're uniquely Korean — English has no direct equivalent. The person leaving says '다녀오겠습니다' (I'll go and come back), and those staying say '잘 다녀와 / 잘 다녀오세요' (Go and come back well).",
      "examples": [
        {
          "ko": "학교 다녀오겠습니다!",
          "en": "[I'm off to school!] — said by person leaving"
        },
        {
          "ko": "잘 다녀와!",
          "en": "[Have a good day!] — said by person staying (casual)"
        },
        {
          "ko": "잘 다녀오세요.",
          "en": "[Have a good day!] — said by person staying (polite)"
        },
        {
          "ko": "다녀왔습니다!",
          "en": "[I'm home!] — when returning"
        },
        {
          "ko": "어서 와! / 어서 오세요.",
          "en": "[Welcome back!] — when greeting returnee"
        }
      ]
    }
  ],
