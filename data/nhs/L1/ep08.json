    },
    {
      "speaker": "미래",
      "slide": 1,
      "text": "엄마, 늦었어요. 빨리 가야 해요.",
      "en": "Mom, we're late. We have to go quickly.",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep08/2엄마+늦었어요_+빨리+가야+해요_slide2.mp3"
    },
    {
      "speaker": "리아",
      "slide": 2,
      "text": "엄마, 내 점심 도시락 어디 있어요?",
      "en": "Mom, where is my lunchbox?",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep08/3엄마+내+점심+도시락+어디+있어요_slide3.mp3"
    },
    {
      "speaker": "엄마",
      "slide": 3,
      "text": "거기, 식탁 위에 있어.",
      "en": "There? It's on top of the dining table.",
      "speech_type": "banmal",
      "audio": "data/nhs/L1/TTS/ep08/4거기+식탁+위에+있어_slide4.mp3"
    },
    {
      "speaker": "리아",
      "slide": 4,
      "text": "아, 여기 있어요!",
      "en": "Oh, here it is!",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep08/5아__+여기+있어요_slide5.mp3"
    },
    {
      "speaker": "미래+리아",
      "slide": 5,
      "text": "학교 다녀오겠습니다!",
      "en": "We're off to school! (I'll be back from school!)",
      "speech_type": "jondaemal",
      "audio": "data/nhs/L1/TTS/ep08/6학교+다녀+오겠습니다_slide6.mp3"
    },
    {
      "speaker": "엄마",
      "slide": 6,
      "text": "잘 다녀와!",
      "en": "Have a good day! (Go and come back well!)",
      "speech_type": "banmal",
      "audio": "data/nhs/L1/TTS/ep08/7잘+다녀+와_slide7.mp3"
    },
