    {
      "speaker": "mirae",
      "text": "안녕? 나는 미래야. 만나서 반가워.",
      "en": "Hi! I'm Mirae. Nice to meet you!",
      "speech_type": "반말",
      "audio": "data/nhs/TTS/ep1/02_안녕_나는_미래야_만나서_반가워.mp3",
      "slide": 5
    },
    {
      "speaker": "mirae",
      "text": "인사해. 우리 엄마야.",
      "en": "Say hi. This is my mom.",
