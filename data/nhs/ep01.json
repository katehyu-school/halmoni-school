  "grammar": [
    {
      "id": "g7",
      "title": "하고 — And (Noun + Noun)",
      "explanation_en": "하고 connects two nouns together, meaning 'and.' It's the simplest way to list things in Korean. Unlike English, it goes between and after each item!",
      "pattern": "Noun + 하고 + Noun",
      "examples": [
        {
          "korean": "나무하고 연못이 있어요.",
          "en": "There are trees and a pond."
        },
        {
          "korean": "엄마하고 아빠",
          "en": "mom and dad"
        },
        {
          "korean": "사과하고 바나나",
          "en": "apple and banana"
        }
      ],
      "tip": "하고 can also mean 'with' — '친구하고 가요' = 'I go with a friend.'",
      "usage": [
        {
          "situation": "물건 나열",
          "example": "연필하고 지우개 있어요?",
          "en": "Do you have a pencil and eraser?"
        },
        {
          "situation": "같이 하는 사람",
          "example": "누구하고 왔어요?",
          "en": "Who did you come with?"
        }
      ]
    },
    {
      "id": "g3",
      "title": "은/는 — Topic Marker",
      "explanation_en": "은/는 marks the topic of a sentence — what we're talking about. Use 은 after a consonant, 는 after a vowel.",
      "pattern": "Noun + 은/는",
      "examples": [
        {
          "korean": "나는 정민이야.",
          "en": "I'm Jeongmin. (topic: me)"
        },
        {
          "korean": "저는 학생이에요.",
          "en": "I'm a student. (topic: me)"
        },
        {
          "korean": "미래는 내 친구야.",
          "en": "Mirae is my friend. (topic: Mirae)"
        }
      ],
      "tip": "은 comes after consonants (학생은), 는 comes after vowels (나는, 저는).",
      "usage": [
        {
          "situation": "자기소개할 때",
          "example": "저는 케이트예요.",
          "en": "I'm Kate."
        },
        {
          "situation": "이름 물어볼 때",
          "example": "이름이 뭐예요?",
          "en": "What's your name?"
        }
      ]
    },
    {
      "id": "g1",
      "title": "나는/저는 — I am (반말 vs 존댓말)",
      "explanation_en": "나는 is casual (used with friends, younger people). 저는 is polite (used with adults, strangers). Both mean 'I' but the level of politeness is different!",
      "pattern": "나는 + Noun + 이야 / 저는 + Noun + 이에요",
      "examples": [
        {
          "korean": "나는 정민이야.",
          "en": "I'm Jeongmin. (casual)"
        },
        {
          "korean": "저는 정민이에요.",
          "en": "I'm Jeongmin. (polite)"
        },
        {
          "korean": "나는 미래야.",
          "en": "I'm Mirae. (casual)"
        }
      ],
      "tip": "With friends your age → 나는 ...이야. With adults or strangers → 저는 ...이에요.",
      "usage": [
        {
          "situation": "친구에게 (casual)",
          "example": "나는 제이크야!",
          "en": "I'm Jake!"
        },
        {
          "situation": "어른에게 (polite)",
          "example": "저는 제이크예요.",
          "en": "I'm Jake."
        }
      ]
    },
    {
      "id": "g6",
      "title": "에 vs 에서 — Location Markers",
      "explanation_en": "에 marks a destination or location of existence (where something is / where you go TO). 에서 marks where an action happens (where you DO something).",
      "pattern": "Place + 에 (destination/existence) / Place + 에서 (action location)",
      "examples": [
        {
          "korean": "학교에 가요.",
          "en": "I go to school. (destination)"
        },
        {
          "korean": "학교에서 공부해요.",
          "en": "I study at school. (action)"
        },
        {
          "korean": "집에 있어요.",
          "en": "I'm at home. (existence)"
        }
      ],
      "tip": "에 = where you GO or ARE. 에서 = where you DO something.",
      "usage": [
        {
          "situation": "어디 가요?",
          "example": "도서관에 가요.",
          "en": "I'm going to the library."
        },
        {
          "situation": "어디서 먹어요?",
          "example": "학교에서 먹어요.",
          "en": "I eat at school."
        }
      ]
    },
    {
      "id": "g2",
      "title": "만나서 반가워(요) — Nice to meet you",
      "explanation_en": "만나서 means 'having met' and 반가워(요) means 'I'm glad / happy.' Together: 'I'm glad to have met you!' Use 반가워 with friends, 반가워요 with adults.",
      "pattern": "만나서 반가워 (casual) / 만나서 반가워요 (polite)",
      "examples": [
        {
          "korean": "만나서 반가워!",
          "en": "Nice to meet you! (casual)"
        },
        {
          "korean": "만나서 반가워요!",
          "en": "Nice to meet you! (polite)"
        },
        {
          "korean": "처음 만나서 반가워요.",
          "en": "Nice to meet you for the first time."
        }
      ],
      "tip": "반가워 for friends, 반가워요 for adults — same rule as 이야/이에요!",
      "usage": [
        {
          "situation": "처음 만나는 친구에게",
          "example": "안녕? 만나서 반가워!",
          "en": "Hi! Nice to meet you!"
        },
        {
          "situation": "어른에게",
          "example": "안녕하세요? 만나서 반가워요!",
          "en": "Hello! Nice to meet you!"
        }
      ]
    },
    {
      "id": "g4",
      "title": "저도 — Me too / I also",
      "explanation_en": "도 is a particle meaning 'also' or 'too.' 저도 means 'me too' or 'I also.' It replaces 는 when you want to say 'also.'",
      "pattern": "Noun + 도",
      "examples": [
        {
          "korean": "저도 반가워요!",
          "en": "Nice to meet you too!"
        },
        {
          "korean": "나도 학생이야.",
          "en": "I'm also a student."
        },
        {
          "korean": "미래도 왔어?",
          "en": "Did Mirae come too?"
        }
      ],
      "tip": "도 replaces 은/는. Don't say 저는도 — just 저도!",
      "usage": [
        {
          "situation": "같은 감정 표현",
          "example": "저도 반가워요!",
          "en": "Nice to meet you too!"
        },
        {
          "situation": "나도 같아요",
          "example": "나도 배고파!",
          "en": "I'm hungry too!"
        }
      ]
    },
    {
      "id": "g5",
      "title": "우리 — Our / We",
      "explanation_en": "우리 literally means 'we' or 'our,' but Koreans use it even when talking about one person! 우리 엄마 means 'my mom' (literally 'our mom'). This is a uniquely Korean cultural habit.",
      "pattern": "우리 + Family/Close relationship",
      "examples": [
        {
          "korean": "우리 엄마야.",
          "en": "This is my mom. (lit: our mom)"
        },
        {
          "korean": "우리 학교야.",
          "en": "This is my school. (lit: our school)"
        },
        {
          "korean": "우리 집에 와!",
          "en": "Come to my house! (lit: our house)"
        }
      ],
      "tip": "Koreans say 우리 엄마, not 나의 엄마. It shows closeness and belonging!",
      "usage": [
        {
          "situation": "가족 소개",
          "example": "우리 엄마야, 인사해!",
          "en": "This is my mom, say hi!"
        },
        {
          "situation": "내 물건/장소",
          "example": "우리 학교 정말 좋아!",
          "en": "I really like my school!"
        }
      ]
    }
  ],
