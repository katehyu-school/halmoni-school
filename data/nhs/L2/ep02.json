  "script": [
    {
      "speaker": "mirae",
      "text": "할머니! 미라예요!",
      "slide": 0,
      "audio": "data/nhs/L2/TTS/ep02/01할머니!+미래예요!_slide1.mp3",
      "en": "Grandma! It's me, Mira!"
    },
    {
      "speaker": "halmoni",
      "text": "미라야, 지금 어디 있어?",
      "slide": 1,
      "audio": "data/nhs/L2/TTS/ep02/02미래야+지금+어디+있어_slide2.mp3",
      "en": "Mira, where are you right now?"
    },
    {
      "speaker": "mirae",
      "text": "인천공항이에요.",
      "slide": 1,
      "audio": "data/nhs/L2/TTS/ep02/03인천공항이에요_slide2.mp3",
      "en": "We're at Incheon Airport."
    },
    {
      "speaker": "halmoni",
      "text": "모두 무사히 도착했어?",
      "slide": 2,
      "audio": "data/nhs/L2/TTS/ep02/04모두+무사히+도착했어_slide3.mp3",
      "en": "Did everyone arrive safely?"
    },
    {
      "speaker": "mirae",
      "text": "네!",
      "slide": 3,
      "audio": "data/nhs/L2/TTS/ep02/05네!_slide4.mp3",
      "en": "Yes!"
    },
    {
      "speaker": "ria",
      "text": "할머니 우리 왔어요!",
      "slide": 3,
      "audio": "data/nhs/L2/TTS/ep02/06할머니+우리+왔어요!_slide4.mp3",
      "en": "Grandma, we're here!"
    },
    {
      "speaker": "halmoni",
      "text": "출구 근처에 있는 공항버스 매표소를 찾아 봐.",
      "slide": 4,
      "audio": "data/nhs/L2/TTS/ep02/07출구+근처에+있는+공항버스+매표소를+찾아+봐_slide5.mp3",
      "en": "Try to find the airport bus ticket booth near the exit.",
      "annotation": {
        "highlight": "찾아 봐",
        "grammar": "V-아/어 보다 — try doing",
        "note": "동사 + 아/어 봐(요) = try to V\n찾아 봐 = try looking for it\n먹어 봐 = try eating it\n해 봐요 = give it a try!"
      }
    },
    {
      "speaker": "mirae",
      "text": "안 보여요. 못 찾겠어요.",
      "slide": 5,
      "audio": "data/nhs/L2/TTS/ep02/08안+보여요_+못+찾겠어요_slide6.mp3",
      "en": "I can't see it. I can't find it.",
      "annotation": {
        "highlight": "안 보여요",
        "grammar": "안 + 동사 — negation",
        "note": "안 + 동사 = don't/can't see\n안 보여요 = can't see it (not visible)\n↔ 못 찾겠어요 = can't find it (inability)\n안(의지·상태) vs 못(능력·불가)"
      }
    },
    {
      "speaker": "kayo",
      "text": "아. 보여요! 찾았어요!",
      "slide": 6,
      "audio": "data/nhs/L2/TTS/ep02/09아_+보여요!+찾았어요!_slide7.mp3",
      "en": "Oh! I can see it! Found it!"
    },
    {
      "speaker": "halmoni",
      "text": "시티 터미널행 공항버스를 타고 종점까지 오면 돼.",
      "slide": 7,
      "audio": "data/nhs/L2/TTS/ep02/10시티+터미널행+공항버스를+타고+종점까지+오면+돼_slide8.mp3",
      "en": "Take the airport bus to City Terminal and ride it to the last stop."
    },
    {
      "speaker": "halmoni",
      "text": "타고 올 수 있어?",
      "slide": 8,
      "audio": "data/nhs/L2/TTS/ep02/11타고+올+수+있어_slide9.mp3",
      "en": "Can you make it here?"
    },
    {
      "speaker": "mirae",
      "text": "해 볼게요.",
      "slide": 9,
      "audio": "data/nhs/L2/TTS/ep02/12해+볼게요_slide10.mp3",
      "en": "I'll try!",
      "annotation": {
        "highlight": "해 볼게요",
        "grammar": "V-아/어 볼게요 — I'll give it a try",
        "note": "해 보다 + ㄹ게요 = I'll try doing it\n해 볼게요 = I'll give it a try!\n먹어 볼게요 = I'll try eating it\n찾아 볼게요 = I'll try to find it"
      }
    },
    {
      "speaker": "halmoni",
      "text": "거기서 기다릴게.",
      "slide": 10,
      "audio": "data/nhs/L2/TTS/ep02/13거기서+기다릴게_slide11.mp3",
      "en": "I'll be waiting there.",
      "annotation": {
        "highlight": "기다릴게",
        "grammar": "V-(으)ㄹ게요 — I will (promise)",
        "note": "동사 + ㄹ게요 = I will ~ (speaker's intention)\n기다릴게 = I'll wait (for you)\n= 상대방을 위해 하겠다는 약속\n할게요 / 갈게요 / 먹을게요"
      }
    }
