 "grammar": [
  {
   "id": "g01_adnominal",
   "tier": "core",
   "title": "-(으)ㄴ/는 + 명사",
   "title_en": "Describing a Noun with a Verb",
   "emoji": "🔗",
   "pattern": "Verb stem + -는 (present) / -(으)ㄴ (past) + Noun",
   "scene_example": {
    "korean": "캐나다에서 오는 사촌들을 만날 거예요.",
    "english": "I'm going to meet the cousins who are coming from Canada.",
    "highlight": "오는"
   },
   "rules": [
    {
     "form": "-는",
     "condition": "현재 동사 (action verbs)",
     "example": "오다 → 오는 사람, 먹다 → 먹는 음식"
    },
    {
     "form": "-(으)ㄴ",
     "condition": "과거 동사 또는 형용사",
     "example": "도착한 사람들, 작은 가방"
    },
    {
     "form": "-(으)ㄹ",
     "condition": "미래/추측",
     "example": "만날 친구, 살 물건"
    }
   ],
   "examples": [
    {
     "ko": "캐나다에서 온 사촌들",
     "en": "cousins who came from Canada"
    },
    {
     "ko": "캐나다에서 오는 사촌들",
     "en": "cousins who are coming from Canada"
    },
    {
     "ko": "어제 만난 친구",
     "en": "the friend I met yesterday"
    },
    {
     "ko": "일하는 직원",
     "en": "the staff who works there"
    },
    {
     "ko": "번호표를 뽑는 기계",
     "en": "the machine where you take a number ticket"
    }
   ],
   "tip": "The verb goes BEFORE the noun — opposite of English! · 온 사촌 = the cousin who CAME (not \"the cousin came\")",
   "fill_blanks": [
    {
     "sentence": "공항에서 일___ 직원이 친절해요.",
     "answer": "하는",
     "hint": "동사 현재형 + 명사"
    },
    {
     "sentence": "캐나다에서 ___ 사촌들이에요.",
     "answer": "온",
     "hint": "오다 → -(으)ㄴ"
    },
    {
     "sentence": "이게 번호표를 ___ 곳이에요.",
     "answer": "뽑는",
     "hint": "뽑다 → 뽑는"
    }
   ],
   "explanation_en": "In Korean, verbs and adjectives go BEFORE the noun they describe — like a built-in \"who/that/which\" clause!",
   "rule_boxes": [
    {
     "type": "blue",
     "label": "-는 (present action)",
     "content": "Verb stem + -는 + Noun",
     "note": "캐나다에서 오는 사촌 = the cousin who is coming from Canada"
    },
    {
     "type": "green",
     "label": "-(으)ㄴ (past / adjective)",
     "content": "Verb stem + -(으)ㄴ + Noun",
     "note": "캐나다에서 온 사촌 = the cousin who came from Canada"
    },
    {
     "type": "amber",
     "label": "-(으)ㄹ (future / guess)",
     "content": "Verb stem + -(으)ㄹ + Noun",
     "note": "만날 친구 = the friend I'm going to meet"
    }
   ],
   "example_groups": [
    {
     "label": "-(으)ㄴ  ·  past / adjective",
     "items": [
      {
       "ko": "캐나다에서 온 사촌",
       "en": "the cousin who came from Canada"
      },
      {
       "ko": "어제 만난 친구",
       "en": "the friend I met yesterday"
      },
      {
       "ko": "작은 가방",
       "en": "the small bag (adjective)"
      }
     ]
    },
    {
     "label": "-는  ·  present action",
     "items": [
      {
       "ko": "캐나다에서 오는 사촌",
       "en": "the cousin who is coming from Canada"
      },
      {
       "ko": "공항에서 일하는 직원",
       "en": "the staff who works at the airport"
      },
      {
       "ko": "번호표를 뽑는 기계",
       "en": "the machine where you take a number ticket"
      }
     ]
    }
   ]
  },
  {
   "id": "g01_myeon",
   "tier": "core",
   "title": "-(으)면",
   "title_en": "If / When",
   "emoji": "🔀",
   "pattern": "동사/형용사 어간 + -(으)면",
   "scene_example": {
    "korean": "전화가 안 되면 할머니를 못 만나.",
    "english": "If the phone doesn't work, I can't meet grandma.",
    "highlight": "안 되면"
   },
   "rules": [
    {
     "form": "-면",
     "condition": "모음/ㄹ 받침 어간",
     "example": "오다 → 오면, 알다 → 알면"
    },
    {
     "form": "-으면",
     "condition": "자음 받침 어간 (ㄹ 제외)",
     "example": "먹다 → 먹으면, 없다 → 없으면"
    }
   ],
   "examples": [
    {
     "ko": "비가 오면 우산을 써요.",
     "en": "If it rains, use an umbrella."
    },
    {
     "ko": "학교에 가면 친구들을 만나요.",
     "en": "When I go to school, I meet friends."
    },
    {
     "ko": "심카드가 있으면 전화할 수 있어요.",
     "en": "If you have a SIM card, you can make calls."
    },
    {
     "ko": "모르면 직원에게 물어보세요.",
     "en": "If you don't know, ask a staff member."
    }
   ],
   "tip": "조건 또는 '~할 때'의 뜻. 영어의 'if' 또는 'when'에 해당해요 · Both 'if' and 'when' — context decides which meaning!",
   "fill_blanks": [
    {
     "sentence": "왼쪽으로 가___ 출구가 있어요.",
     "answer": "면",
     "hint": "가다 + -(으)면"
