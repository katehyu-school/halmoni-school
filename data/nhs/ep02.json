  "usage": [
    {
      "title": "먹어 / 먹어요 / 드세요",
      "title_en": "Three Ways to Say 'Eat'",
      "explanation_en": "Korean has multiple speech levels for eating. 먹어 is casual (반말) — use with younger siblings or close friends your age. 먹어요 is polite (존댓말) — use with parents, teachers, elders. 드세요 is the honorific form — extra respect, for grandparents or very formal situations. Dictionary form: 먹다.",
      "examples": [
        {
          "ko": "동생아, 빨리 먹어!",
          "en": "Sibling, eat quickly! (반말)"
        },
        {
          "ko": "밥 먹어요~",
          "en": "Let's eat~ (polite)"
        },
        {
          "ko": "할머니, 드세요.",
          "en": "Grandma, please eat. (honorific)"
        },
        {
          "ko": "모두들 맛있게 먹어요.",
          "en": "Everyone, eat well! (mom to kids)"
        }
      ]
    },
    {
      "title": "알아요 vs 알았어!",
      "title_en": "알다 in Different Situations",
      "explanation_en": "알아요 = 'I know' or 'I understand' (present, polite). When responding to a request or instruction, 알았어! (반말) or 알았어요! (polite) means 'Got it! / Okay!' — it's the past tense of 알다, meaning 'I have understood.' This is very common in everyday Korean!",
      "examples": [
        {
          "ko": "알았어! (동생에게)",
          "en": "Got it! (반말, to sibling)"
        },
        {
          "ko": "알았어요! (부모님께)",
          "en": "Got it! (polite, to parents)"
        },
        {
          "ko": "한국어 알아요?",
          "en": "Do you know Korean?"
        },
        {
