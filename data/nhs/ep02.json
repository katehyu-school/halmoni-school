  "grammar": [
    {
      "id": "g_ul",
      "title": "-을 / -를 목적격 조사",
      "title_en": "Object Particle -을 / -를",
      "icon": "🎯",
      "rule": "명사(받침 O) + 을  |  명사(받침 X) + 를",
      "pattern": "명사(받침 O) + 을  |  명사(받침 X) + 를",
      "explanation_en": "The object particle marks WHAT the action is done to. Use 을 after a consonant-ending noun, 를 after a vowel-ending noun. The object particle is often dropped in casual speech.",
      "table": {
        "columns": [
          "단어 Word",
          "받침 Final?",
          "조사 Particle",
          "예문 Example"
        ],
        "rows": [
          [
            "밥",
            "O (ㅂ)",
            "을",
            "밥을 먹어요"
          ],
          [
            "배구",
            "X (ㅜ)",
            "를",
            "배구를 해요"
          ],
          [
            "공",
            "O (ㅇ)",
            "을",
            "공을 받아!"
          ],
          [
            "우리",
            "X (ㅣ)",
            "를",
            "우리를 불러요"
          ]
        ]
      },
      "examples": [
        {
          "ko": "저는 배구를 해요.",
          "en": "I play volleyball."
        },
        {
          "ko": "밥을 먹어요.",
          "en": "I eat rice."
        },
        {
          "ko": "내 공 받아!",
          "en": "Catch my ball!"
        },
        {
          "ko": "엄마가 우리를 불러요.",
          "en": "Mom calls us."
        }
      ],
      "fill_blanks": [
        {
          "sentence": "저는 배구___ 해요.",
          "answer": "를",
          "hint": "배구 ends in vowel (ㅜ) → 를"
        },
        {
          "sentence": "밥___ 먹어요.",
          "answer": "을",
          "hint": "밥 ends in consonant (ㅂ) → 을"
        },
        {
          "sentence": "엄마가 우리___ 불러요.",
          "answer": "를",
          "hint": "우리 ends in vowel (ㅣ) → 를"
        }
      ]
    },
    {
      "id": "g6",
      "title": "이거 / 그거 / 저거",
      "title_en": "This / That / That over there",
      "icon": "👆",
      "rule": "이거 (near me) · 그거 (near you) · 저거 (far from both)",
      "pattern": "이거 (near me 🙋) | 그거 (near you 👂) | 저거 (far away 👉)",
      "explanation_en": "이거 = this thing (near speaker), 그거 = that thing (near listener), 저거 = that thing over there (far from both). For places: 여기/거기/저기.",
      "table": {
        "columns": [
          "거리 Distance",
          "사물 Thing",
          "장소 Place",
          "사람 Person"
        ],
        "rows": [
          [
            "가까이 — 나 (near me)",
            "이거",
            "여기",
            "이 사람"
          ],
          [
            "가까이 — 너 (near you)",
            "그거",
            "거기",
            "그 사람"
          ],
          [
            "멀리 (far)",
            "저거",
            "저기",
            "저 사람"
          ]
        ]
      },
      "examples": [
        {
          "ko": "엄마, 이거 너무 맛있어요!",
          "en": "Mom, this is so delicious!"
        },
        {
          "ko": "그거 뭐야?",
          "en": "What's that?"
        },
        {
          "ko": "저거 봐!",
          "en": "Look at that over there!"
        },
        {
          "ko": "이거 얼마예요?",
          "en": "How much is this?"
        }
      ],
      "fill_blanks": [
        {
          "sentence": "엄마, ___ 너무 맛있어요! (this — near me)",
          "answer": "이거",
          "hint": "near the speaker = 이거"
        },
        {
          "sentence": "___ 뭐야? (what's that — near you)",
          "answer": "그거",
          "hint": "near the listener = 그거"
        },
        {
