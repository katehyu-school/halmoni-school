  "grammar": [
    {
      "id": "g1",
      "title": "잘 먹겠습니다 / 잘 먹었습니다",
      "title_en": "Korean Meal Expressions",
      "icon": "🍽️",
      "rule": "식사 전: 잘 먹겠습니다  |  식사 후: 잘 먹었습니다",
      "explanation_en": "Essential Korean mealtime expressions. Say 잘 먹겠습니다 before eating and 잘 먹었습니다 after. For these greetings, the formal -습니다 ending is more natural than casual -어요. Always say them to the person who prepared the food!",
      "examples": [
        {
          "ko": "잘 먹겠습니다!",
          "en": "Thank you for the food! (before eating)"
        },
        {
          "ko": "잘 먹었습니다, 엄마!",
          "en": "Thank you for the meal, Mom! (after eating)"
        },
        {
          "ko": "잘 먹었어요. (casual polite)",
          "en": "I enjoyed the meal. (softer tone)"
        },
        {
          "ko": "잘 먹었어! (반말)",
          "en": "That was good! (to friends/siblings)"
        }
      ]
    },
    {
      "id": "g2",
      "title": "배구하다 vs 배구를 하다",
      "title_en": "Sports Verbs: Compact vs. Separate",
      "icon": "🏐",
      "rule": "스포츠 + 하다  OR  스포츠 + 를/을 + 하다",
      "explanation_en": "Sports and activities can be expressed two ways in Korean. Attach 하다 directly (배구하다) or keep the noun separate with object particle 를/을 (배구를 하다). Both are correct! The separate form is more common in everyday speech.",
      "examples": [
        {
          "ko": "저는 배구를 해요.",
          "en": "I play volleyball. (separate — natural in speech)"
        },
        {
          "ko": "저는 배구해요.",
          "en": "I play volleyball. (compact form)"
        },
        {
          "ko": "축구를 해요.",
          "en": "I play soccer."
        },
        {
          "ko": "숙제를 해요.",
          "en": "I do homework."
        }
      ]
    },
    {
      "id": "g3",
      "title": "아침에 / 저녁에 vs 어제 / 오늘",
      "title_en": "Time Words — When to Use 에",
      "icon": "🕐",
      "rule": "시간대 (아침/점심/저녁) + 에  |  날짜어 (어제/오늘/내일) — 에 없음",
      "explanation_en": "Time-of-day words (아침, 점심, 저녁) take the particle 에. But relative date words (어제, 오늘, 내일) do NOT take 에 — they stand alone!",
      "examples": [
        {
          "ko": "저녁에 밥을 먹어요.",
          "en": "I eat dinner in the evening. (에 ✅)"
        },
        {
          "ko": "아침에 학교에 가요.",
          "en": "I go to school in the morning. (에 ✅)"
        },
        {
          "ko": "오늘 밥을 먹어요.",
          "en": "I eat today. (에 ❌ — no particle!)"
        },
        {
          "ko": "어제 배구를 했어요.",
          "en": "I played volleyball yesterday. (에 ❌)"
        }
      ]
    },
    {
      "id": "g4",
      "title": "맛있어요 / 맛없어요",
      "title_en": "맛 + 있다 / 없다",
      "icon": "😋",
      "rule": "맛 + 있어요 = delicious  |  맛 + 없어요 = not tasty",
      "explanation_en": "맛 means 'taste/flavor'. 맛있어요 literally means 'taste exists' = delicious! 맛없어요 = 'taste doesn't exist' = bland. Pronunciation note: 맛있어요 sounds like 마시써요 (the ㅅ links to the next vowel).",
      "examples": [
        {
          "ko": "이거 너무 맛있어요!",
          "en": "This is SO delicious!"
        },
        {
          "ko": "맛없어요.",
          "en": "It doesn't taste good."
        },
        {
          "ko": "한국 음식은 맛있어요.",
          "en": "Korean food is delicious."
        },
        {
          "ko": "알아요? 맛있어요!",
          "en": "You know what? It's delicious!"
        }
      ]
    },
    {
      "id": "g5",
      "title": "알아요 / 몰라요",
      "title_en": "알다 / 모르다 — Know / Don't Know",
      "icon": "💡",
      "rule": "알다 → 알아요  |  모르다 → 몰라요 (ㄹ irregular)",
      "explanation_en": "알아요 means 'I know / I understand.' 몰라요 means 'I don't know.' Watch the spelling change: 모르다 → 몰라요 (not 모르어요). This ㄹ-irregular pattern also appears in 부르다 → 불러요 (to call/sing).",
      "examples": [
        {
          "ko": "알아요!",
          "en": "I know! / Got it!"
        },
        {
          "ko": "몰라요.",
          "en": "I don't know."
        },
        {
          "ko": "한국어 알아요?",
          "en": "Do you know Korean?"
        },
        {
          "ko": "이름을 몰라요.",
          "en": "I don't know the name."
        }
      ]
    },
    {
      "id": "g6",
      "title": "이거 / 그거 / 저거 — 지시대명사",
      "title_en": "This / That / That over there",
      "icon": "👆",
      "rule": "이거 (near me) · 그거 (near you) · 저거 (far from both)",
      "explanation_en": "이거 = this thing (near the speaker), 그거 = that thing (near the listener), 저거 = that thing over there (far from both). For places, use 여기/거기/저기 instead.",
      "examples": [
        {
          "ko": "엄마, 이거 너무 맛있어요!",
          "en": "Mom, this is so delicious!"
        },
        {
          "ko": "그거 뭐야?",
          "en": "What's that (near you)?"
        },
        {
          "ko": "저거 봐!",
          "en": "Look at that over there!"
        },
        {
          "ko": "이거 얼마예요?",
          "en": "How much is this?"
        }
      ]
    }
  ],
