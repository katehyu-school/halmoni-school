  "grammar": [
    {
      "id": "g1",
      "title": "잘 먹겠습니다 / 잘 먹었습니다",
      "title_en": "Korean Meal Expressions",
      "icon": "🍽️",
      "rule": "식사 전: 잘 먹겠습니다  |  식사 후: 잘 먹었습니다",
      "explanation_en": "These are essential Korean mealtime expressions. Say 잘 먹겠습니다 before eating (like 'thank you for this food') and 잘 먹었습니다 after finishing (like 'that was a great meal'). Always say these to the person who prepared the food!",
      "examples": [
        {
          "ko": "잘 먹겠습니다!",
          "en": "Thank you for the food! (before eating)"
        },
        {
          "ko": "잘 먹었습니다, 엄마!",
          "en": "Thank you for the meal, Mom! (after eating)"
        },
        {
          "ko": "나도 잘 먹었어요.",
          "en": "I enjoyed the meal too."
        }
      ]
    },
    {
      "id": "g2",
      "title": "이거 / 그거 / 저거 — 지시대명사",
      "title_en": "This / That / That over there",
      "icon": "👆",
      "rule": "이거 (here) · 그거 (near you) · 저거 (over there)",
      "explanation_en": "이거 means 'this thing' (near the speaker), 그거 means 'that thing' (near the listener), and 저거 means 'that thing over there' (far from both). They replace 여기/거기/저기 when talking about objects!",
      "examples": [
        {
          "ko": "엄마, 이거 너무 맛있어요!",
          "en": "Mom, this is so delicious!"
        },
        {
          "ko": "그거 뭐야?",
          "en": "What's that (near you)?"
        },
        {
          "ko": "저거 봐!",
          "en": "Look at that over there!"
        }
      ]
    },
    {
      "id": "g3",
      "title": "너무 — '너무' vs '아주'",
      "title_en": "너무 · So / Very / Too Much",
      "icon": "✨",
      "rule": "너무 + adjective/verb",
      "explanation_en": "너무 originally meant 'too much' (negative), but in modern Korean it's commonly used to mean 'so / very' (positive too). 아주 is the safer 'very' for formal situations. In everyday speech, 너무 맛있어요 = This is SO delicious!",
      "examples": [
        {
          "ko": "이거 너무 맛있어요!",
          "en": "This is SO delicious!"
        },
        {
          "ko": "너무 좋아요!",
          "en": "I love it so much!"
        },
        {
          "ko": "너무 많아요.",
          "en": "There's too much."
        }
      ]
    }
  ],
