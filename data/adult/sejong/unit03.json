    "grammar": {
      "sections": [
        {
          "id": "g03_demonstrative",
          "title": "이 / 그 / 저",
          "subtitle": "Demonstrative determiners — this / that (near listener) / that (far)",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "이 + N: 화자에게 가까운 것 (near speaker)",
              "examples": [
                "이 가방 (this bag)",
                "이 사람 (this person)"
              ]
            },
            {
              "color": "blue",
              "label": "그 + N: 청자에게 가까운 것 (near listener)",
              "examples": [
                "그 책 (that book)",
                "그 사람 (that person)"
              ]
            },
            {
              "color": "blue",
              "label": "저 + N: 둘 다에게 먼 것 (far from both)",
              "examples": [
                "저 의자 (that chair over there)",
                "저 사람 (that person over there)"
              ]
            },
            {
              "color": "teal",
              "label": "독립형 (standalone): 이것/이거, 그것/그거, 저것/저거",
              "examples": [
                "이게 뭐예요? (What is this?)",
                "그거 주세요. (Give me that.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "이 사람이 누구예요?",
              "english": "Who is this person?"
            },
            {
              "korean": "저것이 뭐예요?",
              "english": "What is that over there?"
            },
            {
              "korean": "이게 제 가방이에요.",
              "english": "This is my bag."
            }
          ]
        },
        {
          "id": "g03_issda",
          "title": "N에 있어요 / 없어요",
          "subtitle": "Existence: 'there is / there isn't' at a location",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "N에 있어요 = N is at / there is N at",
              "examples": [
                "가방이 의자 옆에 있어요. (The bag is next to the chair.)"
              ]
            },
            {
              "color": "blue",
              "label": "N에 없어요 = N is not at / there is no N at",
              "examples": [
                "시계가 책상 위에 없어요. (The clock isn't on the desk.)"
              ]
            },
            {
              "color": "teal",
              "label": "위치 명사 + 에: 위, 아래/밑, 앞, 뒤, 옆, 안, 밖, 사이",
              "examples": [
                "책상 위에 있어요. (It's on the desk.)",
                "가방 안에 있어요. (It's inside the bag.)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "제 가방은 책상 옆에 있어요.",
              "english": "My bag is next to the desk."
            },
            {
              "korean": "공책이 가방 안에 없어요.",
              "english": "The notebook is not inside the bag."
            },
            {
              "korean": "시계가 어디에 있어요?",
              "english": "Where is the clock?"
            }
          ]
        }
      ]
    },
    "key_points": [
      {
        "ko": "이/그/저는 항상 뒤에 명사가 와요. 독립형: 이것(이거)/그것(그거)/저것(저거).",
        "en": "이/그/저 always precede a noun. Standalone forms: 이것/그것/저것 (or 이거/그거/저거)."
      },
      {
        "ko": "위치: 위·아래·앞·뒤·옆·안·밖·사이 뒤에 '에'를 붙여요.",
        "en": "Location words (위, 아래, 앞, 뒤, 옆, 안, 밖, 사이) are followed by the particle 에."
      },
      {
        "ko": "'옆에 [여페]' — 받침 ㅂ + 에 → 연음 → [여페]",
        "en": "옆에 is pronounced [여페] — consonant liaison."
      }
    ],
    "practice": {
      "quiz_items": [
        {
          "id": "q03_01",
          "type": "multiple_choice",
          "question": "Fill in: '책이 책상 ___ 에 있어요.'",
          "choices": [
            "앞",
            "위",
            "안",
            "밖"
          ],
          "answer": "위",
          "explanation": "ON TOP of the desk = 위. 책이 책상 위에 있어요."
        },
        {
          "id": "q03_02",
          "type": "multiple_choice",
          "question": "Of 이/그/저, which is farthest from the speaker?",
          "choices": [
            "이",
            "그",
            "저",
            "all equal"
          ],
          "answer": "저",
          "explanation": "이 (near speaker) / 그 (near listener) / 저 (far from both)."
        },
        {
          "id": "q03_03",
          "type": "multiple_choice",
          "question": "Contracted form of '이것은'?",
          "choices": [
            "이거",
            "이건",
            "이게",
            "이걸"
          ],
          "answer": "이건",
          "explanation": "이것은 → 이건. (이것이 → 이게 / 이것을 → 이걸)"
        },
        {
          "id": "q03_04",
          "type": "multiple_choice",
          "question": "How do you pronounce '침대 옆에'?",
          "choices": [
            "침대 옆에",
            "침대 여페",
            "침대 엽에",
            "침대 여베"
          ],
          "answer": "침대 여페",
          "explanation": "옆 (ㅂ) + 에 → liaison → [여페]."
        },
        {
          "id": "q03_05",
          "type": "multiple_choice",
          "question": "Which can fit INSIDE (안) a bag?",
          "choices": [
            "책상",
            "공책",
            "침대",
            "교실"
          ],
          "answer": "공책",
          "explanation": "A notebook (공책) fits inside a bag."
        }
      ]
    },
    "self_check": [
