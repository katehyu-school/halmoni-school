    "grammar": {
      "sections": [
        {
          "id": "g06_numbers",
          "title": "고유어 vs. 한자어 숫자",
          "subtitle": "두 가지 숫자 시스템 — 상황에 따라 다르게 사용해요",
          "pattern": "고유어 (하나, 둘…) / 한자어 (일, 이…)",
          "meaning": "two number systems used in different situations",
          "description": "Korean has two counting systems. The key rule: use native numbers (고유어) for counting everyday objects and people; use sino-Korean numbers (한자어) for prices, dates, phone numbers, and measurements.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "고유어 — 물건·사람·나이 셀 때",
              "examples": [
                "사과 두 개 (two apples)",
                "학생 세 명 (three students)",
                "고양이 네 마리 (four cats)",
                "커피 다섯 잔 (five cups of coffee)"
              ]
            },
            {
              "color": "blue",
              "label": "한자어 — 가격·날짜·전화번호",
              "examples": [
                "이천 원 (2,000 won)",
                "삼월 (March — 3rd month)",
                "02-1234-5678 (phone number)",
                "오 층 (5th floor)"
              ]
            },
            {
              "color": "green",
              "label": "⚠️ 하나/둘/셋/넷 → 단위명사 앞에서 변형!",
              "examples": [
                "하나 → 한  (한 개, 한 명, 한 잔)",
                "둘  → 두  (두 개, 두 명, 두 마리)",
                "셋  → 세  (세 개, 세 마리, 세 잔)",
                "넷  → 네  (네 개, 네 병, 네 권)"
              ]
            }
          ],
          "conjugation_table": [
            { "base": "하나", "stem": "한", "rule": "단위명사 앞에서", "result": "한 개 / 한 명 / 한 잔" },
            { "base": "둘",   "stem": "두", "rule": "단위명사 앞에서", "result": "두 개 / 두 명 / 두 마리" },
            { "base": "셋",   "stem": "세", "rule": "단위명사 앞에서", "result": "세 개 / 세 마리 / 세 잔" },
            { "base": "넷",   "stem": "네", "rule": "단위명사 앞에서", "result": "네 개 / 네 병 / 네 권" },
            { "base": "다섯", "stem": "다섯", "rule": "변형 없음", "result": "다섯 개 / 다섯 명" },
            { "base": "열하나","stem": "열한", "rule": "단위명사 앞에서", "result": "열한 개 / 열한 명" }
          ],
          "examples": [
            { "korean": "빵 한 개 주세요.",      "english": "Give me one loaf of bread.",        "highlight": "한 개" },
            { "korean": "학생이 두 명 있어요.",  "english": "There are two students.",            "highlight": "두 명" },
            { "korean": "고양이 세 마리예요.",   "english": "There are three cats.",              "highlight": "세 마리" },
            { "korean": "커피 네 잔 주세요.",    "english": "Please give me four cups of coffee.","highlight": "네 잔" },
            { "korean": "사과 다섯 개 주세요.",  "english": "Give me five apples.",              "highlight": "다섯 개" },
            { "korean": "이 사과 얼마예요?",     "english": "How much are these apples?",         "highlight": "얼마예요" },
            { "korean": "이천 원이에요.",        "english": "It's 2,000 won.",                    "highlight": "이천 원" }
          ],
          "qna": [
            { "question": "지우개를 몇 개 사요?",     "answer": "지우개를 두 개 사요." },
            { "question": "학생이 몇 명 있어요?",     "answer": "학생이 세 명 있어요." },
            { "question": "커피 한 잔 얼마예요?",     "answer": "삼천 원이에요." }
          ]
        },
        {
          "id": "g06_seyo",
          "title": "-(으)세요",
          "subtitle": "동사 뒤에 붙어서 부드러운 명령/요청을 나타내요",
          "pattern": "받침 있음 → 으세요 / 받침 없음 · 받침 ㄹ → 세요",
          "meaning": "polite command or request",
          "description": "Add -(으)세요 to the verb stem to make a polite request or command. If the stem ends in a consonant (받침), add 으세요. If it ends in a vowel or ㄹ, add 세요.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "받침 있음 → 으세요",
              "examples": [
                "앉다 → 앉으세요 (Please sit)",
                "읽다 → 읽으세요 (Please read)",
                "먹다 → 먹으세요 (Please eat)"
              ]
            },
            {
              "color": "blue",
              "label": "받침 없음 / ㄹ 받침 → 세요",
              "examples": [
                "오다 → 오세요 (Please come)",
                "주다 → 주세요 (Please give)",
                "마시다 → 마시세요 (Please drink)"
              ]
            },
            {
              "color": "green",
              "label": "⚠️ 불규칙 — 주의!",
              "examples": [
                "듣다 → 들으세요 (ㄷ → ㄹ irregular)",
                "놀다 → 노세요 (ㄹ dropped)"
              ]
            }
          ],
          "conjugation_table": [
            { "base": "앉다",   "stem": "앉",   "rule": "받침 있음 → 으세요", "result": "앉으세요" },
            { "base": "읽다",   "stem": "읽",   "rule": "받침 있음 → 으세요", "result": "읽으세요" },
            { "base": "먹다",   "stem": "먹",   "rule": "받침 있음 → 으세요", "result": "먹으세요" },
            { "base": "오다",   "stem": "오",   "rule": "받침 없음 → 세요",   "result": "오세요" },
            { "base": "주다",   "stem": "주",   "rule": "받침 없음 → 세요",   "result": "주세요" },
            { "base": "마시다", "stem": "마시", "rule": "받침 없음 → 세요",   "result": "마시세요" },
            { "base": "타다",   "stem": "타",   "rule": "받침 없음 → 세요",   "result": "타세요" },
            { "base": "듣다",   "stem": "들",   "rule": "ㄷ 불규칙 → 들+으세요","result": "들으세요" },
            { "base": "놀다",   "stem": "노",   "rule": "ㄹ 탈락 → 세요",    "result": "노세요" }
          ],
          "examples": [
            { "korean": "안나 씨, 여기 앉으세요.",    "english": "Anna, please sit here.",          "highlight": "앉으세요" },
            { "korean": "라면 세 개 주세요.",          "english": "Please give me three ramens.",    "highlight": "주세요" },
            { "korean": "음악을 들으세요.",            "english": "Please listen to the music.",     "highlight": "들으세요" },
            { "korean": "내일 일찍 오세요.",           "english": "Please come early tomorrow.",     "highlight": "오세요" },
            { "korean": "35 쪽을 읽으세요.",            "english": "Please read page 35.",            "highlight": "읽으세요" },
            { "korean": "5 번 버스를 타세요.",          "english": "Please take bus number 5.",       "highlight": "타세요" }
          ],
          "qna": [
            { "question": "학생에게 뭐라고 해요? (읽다 + 으세요)",   "answer": "35 쪽을 읽으세요." },
            { "question": "손님에게 뭐라고 해요? (주다 + 세요)",     "answer": "여기 있어요. / 커피 드세요." },
            { "question": "듣다의 (으)세요 형은?",                  "answer": "들으세요 (ㄷ 불규칙)" }
          ]
        }
      ]
