    "pronunciation": {
      "sections": [
        {
          "id": "pron06_01",
          "title": "받침 발음 규칙 — Final Consonant Simplification",
          "rule_en": "In Korean, final consonants are pronounced as one of only 7 sounds: [ㄱ], [ㄴ], [ㄷ], [ㄹ], [ㅁ], [ㅂ], [ㅇ]. Multiple consonants get simplified.",
          "rule_ko": "받침은 7가지 소리([ㄱ ㄴ ㄷ ㄹ ㅁ ㅂ ㅇ])로만 발음돼요. ㅅ·ㅆ·ㅈ·ㅊ·ㅌ → [ㄷ], ㅍ → [ㅂ], ㅋ·ㄲ → [ㄱ]",
          "examples": [
            { "written": "다섯", "pronounced": "다섣",  "romanization": "da-seot" },
            { "written": "여섯", "pronounced": "여섣",  "romanization": "yeo-seot" },
            { "written": "옷",   "pronounced": "옫",    "romanization": "ot" },
            { "written": "꽃",   "pronounced": "꼳",    "romanization": "kkot" },
            { "written": "책",   "pronounced": "책",    "romanization": "chaek" },
            { "written": "앞",   "pronounced": "압",    "romanization": "ap" }
          ]
        },
        {
          "id": "pron06_02",
          "title": "연음 — Liaison (받침 + 모음)",
          "rule_en": "When a syllable ending in a consonant (받침) is followed by a vowel, the consonant sound moves to the next syllable.",
          "rule_ko": "받침 뒤에 모음이 오면 받침이 다음 음절의 첫소리가 돼요.",
          "examples": [
            { "written": "한 개",    "pronounced": "한개",   "romanization": "han-gae" },
            { "written": "몇 개",    "pronounced": "며때",   "romanization": "myeot-kkae" },
            { "written": "다섯 개",  "pronounced": "다서개", "romanization": "da-seo-gae" }
          ]
        }
      ]
    },

