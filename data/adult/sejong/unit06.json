    "dialogue": {
      "scenes": [
        {
          "id": "dlg06_01",
          "title": "과일 가게에서",
          "subtitle": "Anna goes to a fruit store",
          "lines": [
            { "speaker": "주인", "korean": "어서 오세요.", "english": "Welcome!" },
            { "speaker": "안나", "korean": "이 사과 얼마예요?", "english": "How much are these apples?" },
            { "speaker": "주인", "korean": "이천 원이에요.", "english": "They are 2,000 won." },
            { "speaker": "안나", "korean": "배는 얼마예요?", "english": "How much are the pears?" },
            { "speaker": "주인", "korean": "오천 원이에요.", "english": "They are 5,000 won." },
            { "speaker": "안나", "korean": "그럼 사과 두 개하고 배 한 개 주세요.", "english": "Then give me two apples and one pear please." },
            { "speaker": "주인", "korean": "여기 있어요.", "english": "Here you go." },
            { "speaker": "안나", "korean": "모두 얼마예요?", "english":  "How much is it altogether?" },
            { "speaker": "주인", "korean": "구천 원이에요.", "english": "They are 9,000 won altogether." }
          ]
        },
        {
          "id": "dlg06_02",
