    "grammar": {
      "sections": [
        {
          "id": "g10_gosipda",
          "title": "V-고 싶다",
          "subtitle": "Expressing wishes — 'want to do'",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "동사 어간 + -고 싶어요 (1·2인칭: I/you want to...)",
              "examples": [
                "가다 → 가고 싶어요 (I want to go)",
                "먹다 → 먹고 싶어요 (I want to eat)",
                "보다 → 보고 싶어요 (I want to see)"
              ]
            },
            {
              "color": "teal",
              "label": "3인칭 주어 → -고 싶어 하다 (he/she wants to...)",
              "examples": [
                "안나 씨는 제주도에 가고 싶어 해요.",
                "수지 씨는 비빔밥을 먹고 싶어 해요."
              ]
            },
            {
              "color": "amber",
              "label": "부정: -고 싶지 않아요 (don't want to...)",
              "examples": [
                "지금은 밥을 먹고 싶지 않아요."
              ]
            }
          ],
          "examples": [
            {
              "korean": "저녁에 뭘 먹고 싶어요?",
              "english": "What do you want to eat for dinner?"
            },
            {
              "korean": "저는 한국 음식을 먹고 싶어요.",
              "english": "I want to eat Korean food."
            },
            {
              "korean": "안나 씨는 어디에 가고 싶어 해요?",
              "english": "Where does Anna want to go?"
            },
            {
              "korean": "안나 씨는 제주도에 가고 싶어 해요.",
              "english": "Anna wants to go to Jeju Island."
            }
          ]
        },
        {
          "id": "g10_ulkkayo",
          "title": "-(으)ㄹ까요?",
          "subtitle": "Asking the listener's opinion — 'Shall we...?'",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 없음 (vowel ending) → -ㄹ까요?",
              "examples": [
                "가다 → 갈까요?",
                "타다 → 탈까요?",
                "보다 → 볼까요?"
              ]
            },
            {
              "color": "blue",
              "label": "받침 있음 (consonant ending) → -을까요?",
              "examples": [
                "먹다 → 먹을까요?",
                "걷다 → 걸을까요? (ㄷ 불규칙)"
              ]
            },
            {
              "color": "teal",
              "label": "응답 패턴",
              "examples": [
                "네. 그래요. / 좋아요! — Yes, sounds good!",
                "미안해요, 오늘은 바빠요. — Sorry, busy today.",
                "다른 약속이 있어요. — I have other plans."
              ]
            }
          ],
          "examples": [
            {
              "korean": "여기에서 사진을 찍을까요?",
              "english": "Shall we take a photo here?"
            },
            {
              "korean": "주말에 같이 자전거를 탈까요?",
              "english": "Shall we ride bikes together this weekend?"
            },
            {
              "korean": "내일 놀이공원에 갈까요?",
              "english": "Shall we go to the amusement park tomorrow?"
            },
            {
              "korean": "몇 시에 만날까요?",
              "english": "What time shall we meet?"
            }
          ]
        }
      ]
    },
    "dialogue": {
      "title": "약속 잡기",
      "title_en": "Making Plans",
      "scenes": [
        {
          "id": "d10_scene1",
          "title": "쇼핑몰 약속",
          "lines": [
            {
              "speaker": "A",
              "korean": "마리 씨, 오후에 뭐 해요?",
              "english": "Mari, what are you doing this afternoon?"
            },
            {
              "speaker": "마리",
              "korean": "쇼핑몰에 가요.",
              "english": "I'm going to the shopping mall."
            },
            {
              "speaker": "A",
              "korean": "그래요? 저도 쇼핑몰 가고 싶어요.",
              "english": "Really? I want to go to the mall too."
            },
            {
              "speaker": "마리",
              "korean": "그럼 같이 쇼핑몰에 갈까요?",
              "english": "Then shall we go to the mall together?"
            }
          ]
        },
        {
          "id": "d10_scene2",
          "title": "놀이공원 약속",
          "lines": [
            {
              "speaker": "수지",
              "korean": "안나 씨, 내일 놀이공원에 갈까요?",
              "english": "Anna, shall we go to the amusement park tomorrow?"
            },
            {
              "speaker": "안나",
              "korean": "좋아요. 저도 놀이공원에 가고 싶어요.",
              "english": "Sounds great! I want to go too."
            },
            {
              "speaker": "수지",
              "korean": "몇 시에 만날까요?",
              "english": "What time shall we meet?"
            },
            {
              "speaker": "안나",
              "korean": "두 시가 어때요?",
              "english": "How about 2 o'clock?"
            },
            {
              "speaker": "수지",
              "korean": "그래요. 놀이공원 앞에서 만날까요?",
              "english": "Okay. Shall we meet in front of the amusement park?"
            },
            {
              "speaker": "안나",
              "korean": "네, 좋아요.",
              "english": "Yes, sounds good!"
            }
          ]
        }
      ]
    },
    "pronunciation": {
      "sections": [
