    "dialogue": {
      "scenes": [
        {
          "id": "dlg08_01",
          "title": "날씨가 어때요?",
          "subtitle": "Talking about today's weather",
          "lines": [
            {
              "speaker": "안나",
              "korean": "유진 씨, 요즘 날씨가 어때요?",
              "english": "Yujin, how's the weather lately?"
            },
            {
              "speaker": "유진",
              "korean": "좀 추워요. 매일 비가 와요. 안나 씨 고향은요?",
              "english": "It's a bit cold. It rains every day. How about your hometown, Anna?"
            },
            {
              "speaker": "안나",
              "korean": "제 고향은 지금 여름이에요. 아주 더워요.",
              "english": "My hometown is in summer now. It's very hot."
            },
            {
              "speaker": "유진",
              "korean": "그래요? 저는 더운 날씨를 안 좋아해요.",
              "english": "Really? I don't like hot weather."
            },
            {
              "speaker": "안나",
              "korean": "저도 더위는 좀 힘들어요. 그렇지만 바다에 갈 수 있어서 좋아요!",
              "english": "I find the heat a bit tough too. But I like that I can go to the beach!"
            }
          ]
        },
        {
          "id": "dlg08_02",
          "title": "한국의 사계절",
          "subtitle": "Asking about Korea's four seasons",
          "lines": [
            {
              "speaker": "마리",
              "korean": "재민 씨, 한국은 사계절이 있어요?",
              "english": "Jaemin, does Korea have four seasons?"
            },
            {
              "speaker": "재민",
              "korean": "네, 있어요. 봄, 여름, 가을, 겨울이 있어요.",
              "english": "Yes, it does. There's spring, summer, autumn, and winter."
            },
            {
              "speaker": "마리",
              "korean": "어떤 계절이 제일 좋아요?",
              "english": "Which season do you like best?"
            },
            {
              "speaker": "재민",
              "korean": "가을이요! 날씨가 시원하고 단풍이 아름다워요.",
              "english": "Autumn! The weather is cool and the autumn leaves are beautiful."
            },
            {
              "speaker": "마리",
              "korean": "겨울은요? 눈이 많이 와요?",
              "english": "What about winter? Does it snow a lot?"
            },
            {
              "speaker": "재민",
              "korean": "서울은 좀 와요. 그런데 제주도는 안 와요. 거기는 따뜻해요.",
              "english": "In Seoul, it snows a little. But in Jeju Island, it doesn't snow. It's warm there."
            },
            {
              "speaker": "마리",
              "korean": "와, 제주도에 가고 싶어요!",
              "english": "Wow, I want to go to Jeju Island!"
            }
          ]
        },
        {
          "id": "dlg08_03",
          "title": "이번 주말 날씨",
          "subtitle": "Planning around the weekend weather",
          "lines": [
            {
              "speaker": "선생님",
              "korean": "여러분, 이번 주말에 날씨가 어때요?",
              "english": "Everyone, what's the weather like this weekend?"
            },
            {
              "speaker": "재민",
              "korean": "토요일은 맑아요. 일요일은 비가 와요.",
              "english": "Saturday is clear. Sunday it will rain."
            },
            {
              "speaker": "선생님",
              "korean": "그럼 토요일에 뭐 해요?",
              "english": "So what are you doing Saturday?"
            },
            {
              "speaker": "재민",
              "korean": "친구하고 한강에 가요. 자전거를 타요.",
              "english": "I'm going to the Han River with a friend. We'll ride bikes."
            },
            {
              "speaker": "선생님",
              "korean": "좋겠네요! 일요일은요?",
              "english": "That sounds nice! And Sunday?"
            },
            {
              "speaker": "재민",
              "korean": "비가 오니까 집에서 영화 봐요. 밖에 안 나가요.",
              "english": "Since it's raining, I'll watch movies at home. I'm not going out."
            }
          ]
        }
      ]
    },
