    "grammar": {
      "sections": [
        {
          "id": "g08_an",
          "title": "안 — 부정",
          "subtitle": "동사나 형용사 앞에 놓아서 부정을 나타내요",
          "pattern": "안 + 동사/형용사",
          "meaning": "negation (not)",
          "description": "Place 안 directly before a verb or adjective to negate it. For 하다 verbs, 안 goes between the noun and 하다: '운동 안 해요' (not '안 운동해요').",
          "rule_boxes": [
            {
              "color": "red",
              "label": "일반 동사/형용사 → 안 + V/A",
              "examples": [
                "가요 → 안 가요 (don't go)",
                "먹어요 → 안 먹어요 (don't eat)",
                "더워요 → 안 더워요 (not hot)",
                "좋아요 → 안 좋아요 (not good)"
              ]
            },
            {
              "color": "blue",
              "label": "하다 동사 → 명사 + 안 + 해요",
              "examples": [
                "운동해요 → 운동 안 해요 ✅",
                "안 운동해요 ❌",
                "공부해요 → 공부 안 해요 ✅",
                "요리해요 → 요리 안 해요 ✅"
              ]
            }
          ],
          "examples": [
            {
              "korean": "서울은 날씨가 좋아요?",
              "english": "Is the weather nice in Seoul?",
              "highlight": ""
            },
            {
              "korean": "아니요, 안 좋아요. 비가 와요.",
              "english": "No, it's not nice. It's raining.",
              "highlight": "안 좋아요"
            },
            {
              "korean": "오늘 운동해요?",
              "english": "Are you exercising today?",
              "highlight": ""
            },
            {
              "korean": "아니요. 오늘은 운동 안 해요.",
              "english": "No. I'm not exercising today.",
              "highlight": "운동 안 해요"
            },
            {
              "korean": "밤에는 좀 쌀쌀해요?",
              "english": "Is it a bit chilly at night?",
              "highlight": ""
            },
            {
              "korean": "네, 낮에는 안 추워요. 밤에는 좀 쌀쌀해요.",
              "english": "Yes, it's not cold in the daytime. It's a bit chilly at night.",
              "highlight": "안 추워요"
            }
          ],
          "qna": [
            {
              "question": "오늘 학교에 가요?",
              "answer": "아니요. 오늘은 안 가요."
            },
            {
              "question": "김치가 매워요?",
              "answer": "아니요. 안 매워요. 맛있어요."
            },
            {
              "question": "요즘 바빠요?",
              "answer": "아니요. 요즘은 안 바빠요."
            }
          ]
        },
        {
          "id": "g08_bieup",
          "title": "ㅂ 불규칙",
          "subtitle": "받침 ㅂ이 모음 앞에서 '우'로 바뀌어요",
          "pattern": "ㅂ 받침 + 어/아요 → ㅂ → 우 + 어요",
          "meaning": "ㅂ irregular conjugation",
          "description": "When a verb or adjective stem ends in ㅂ and is followed by a vowel ending (like 아요/어요), the ㅂ changes to 우. Then 우+어 contracts to 워. Exception: 돕다 (to help) → 도와요. Regular ㅂ verbs (잡다, 입다) do NOT change.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "ㅂ → 우 + 어요 → 워요 (불규칙)",
              "examples": [
                "춥다 → 추우+어요 → 추워요",
                "덥다 → 더우+어요 → 더워요",
                "어렵다 → 어려우+어요 → 어려워요",
                "쉽다 → 쉬우+어요 → 쉬워요"
              ]
            },
            {
              "color": "blue",
              "label": "예외 — 돕다 → 도와요",
              "examples": [
                "돕다 → 도오+아요 → 도와요",
                "(ㅂ → 오, not 우 — memorize this!)"
              ]
            },
            {
              "color": "green",
              "label": "규칙 활용 ㅂ — 변화 없음",
              "examples": [
                "잡다 → 잡아요 (catch — no change)",
                "입다 → 입어요 (wear — no change)",
                "씹다 → 씹어요 (chew — no change)"
              ]
            }
          ],
          "conjugation_table": [
            {
              "base": "춥다",
              "stem": "추우",
