    "pronunciation": {
      "sections": [
        {
          "id": "pron05_01",
          "title": "연음 — Liaison (받침 + 모음)",
          "rule": "When a syllable ending in a consonant (받침) is followed by a syllable beginning with ㅇ (silent), the consonant moves to the next syllable.",
          "rule_ko": "받침이 있는 글자 다음에 모음이 오면 받침 소리가 다음 음절로 넘어가요.",
          "examples": [
            {
              "written": "공원이에요",
              "pronounced": "공워니에요",
              "romanization": "kong-woe-ni-e-yo",
              "note": "ㄴ → final ㄴ of 원 moves forward"
            },
            {
              "written": "마트에",
              "pronounced": "마트에",
              "romanization": "ma-teu-e",
              "note": "no liaison — ends in vowel"
            },
            {
              "written": "신발이에요",
              "pronounced": "신바리에요",
              "romanization": "sin-ba-ri-e-yo",
              "note": "받침 ㄹ links to 이에요"
            }
          ]
        }
      ]
    },
    "practice": {
      "quiz_items": [
        {
          "id": "q05_01",
          "type": "multiple_choice",
          "question": "Choose the correct form to connect two nouns.",
          "sentence": "저는 빵___ 우유를 사요.",
          "choices": [
            "하고",
            "에",
            "을",
            "가"
          ],
          "answer": "하고",
          "explanation": "'하고' connects two nouns meaning 'and'. 빵하고 우유 = bread and milk."
        },
        {
          "id": "q05_02",
          "type": "multiple_choice",
          "question": "Choose the correct particle.",
          "sentence": "마트___ 가요.",
          "choices": [
            "에",
            "을",
            "가",
            "하고"
          ],
          "answer": "에",
          "explanation": "'에' attaches to place nouns to express destination. 마트에 가요 = I'm going to the mart."
        },
        {
          "id": "q05_03",
          "type": "multiple_choice",
          "question": "Which is the correct contraction?",
          "sentence": "교실에 누구 + 가 있어요?",
          "choices": [
            "누가",
            "누구가",
            "누구이",
            "누구를"
          ],
          "answer": "누가",
          "explanation": "'누구' + subject marker '가' contracts to '누가'. This is a fixed form."
        },
        {
          "id": "q05_04",
          "type": "multiple_choice",
          "question": "What is the casual form of '무엇을 사요?'",
          "choices": [
            "뭘 사요?",
            "무가 사요?",
            "뭐이 사요?",
            "무엇가 사요?"
          ],
          "answer": "뭘 사요?",
          "explanation": "무엇을 → 뭘 (casual contracted form). Used in everyday conversation."
        },
        {
          "id": "q05_05",
          "type": "multiple_choice",
          "question": "Complete the dialogue.",
          "sentence": "가: 어디에 가요?\n나: ___.",
          "choices": [
            "카페에 가요",
            "카페가 가요",
            "카페를 가요",
            "카페에 있어요"
          ],
          "answer": "카페에 가요",
          "explanation": "Use '에 가요' after place nouns to express going to a destination."
        },
        {
          "id": "q05_06",
          "type": "multiple_choice",
          "question": "Which word means 'department store'?",
          "choices": [
            "백화점",
            "마트",
            "카페",
            "식당"
          ],
          "answer": "백화점",
          "explanation": "백화점 = department store. 마트 = supermarket, 카페 = café, 식당 = restaurant."
        },
        {
          "id": "q05_07",
          "type": "multiple_choice",
          "question": "Choose the more formal version of '빵하고 우유'.",
          "choices": [
            "빵과 우유",
            "빵를 우유",
            "빵이 우유",
            "빵에 우유"
          ],
          "answer": "빵과 우유",
          "explanation": "'빵' ends in a consonant (ㅇ), so the formal connector is '과'. 하고 = 와/과 (casual vs. formal)."
        },
        {
          "id": "q05_08",
          "type": "multiple_choice",
          "question": "What does 여기 mean?",
          "choices": [
            "here",
            "there (near you)",
            "over there",
            "where"
          ],
          "answer": "here",
          "explanation": "여기 = here (near the speaker). 거기 = there (near the listener). 저기 = over there (distant)."
        }
      ]
