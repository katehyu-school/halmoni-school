    "grammar": {
      "sections": [
        {
          "id": "g05_e_gada",
          "title": "에 가다",
          "subtitle": "장소 명사 뒤에 붙어 이동 방향을 나타내요",
          "pattern": "Place noun + 에 가다",
          "meaning": "go to a place",
          "description": "Attach '에' to a place noun to express direction or destination. Then add '가요' (the present tense form of 가다) to say you are going there.",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "장소 + 에 가요",
              "examples": [
                "학교에 가요.",
                "마트에 가요.",
                "카페에 가요.",
                "공원에 가요."
              ]
            },
            {
              "color": "green",
              "label": "가서 뭐 해요? (What do you do there?)",
              "examples": [
                "마트에 가요. 빵을 사요.",
                "카페에 가요. 커피를 마셔요.",
                "공원에 가요. 자전거를 타요.",
                "식당에 가요. 라면을 먹어요."
              ]
            }
          ],
          "examples": [
            {
              "korean": "마리 씨는 어디에 가요?",
              "english": "Where are you going, Marie?",
              "highlight": "에 가요"
            },
            {
              "korean": "학교에 가요.",
              "english": "I'm going to school.",
              "highlight": "에 가요"
            },
            {
              "korean": "뭐해요?",
              "english": "What are you doing?",
              "highlight": ""
            },
            {
              "korean": "한국어를 배워요.",
              "english": "I'm learning Korean.",
              "highlight": ""
            },
            {
              "korean": "오늘 마트에 가요.",
              "english": "I'm going to the mart today.",
              "highlight": "에 가요"
            }
          ],
          "qna": [
            {
              "question": "어디에 가요?",
              "answer": "마트에 가요."
            },
            {
              "question": "카페에서 뭐 해요?",
              "answer": "커피를 마셔요."
            },
            {
              "question": "오늘 어디에 가요?",
              "answer": "학교에 가요."
            }
          ]
        },
        {
          "id": "g05_hago",
          "title": "하고 / 와·과",
          "subtitle": "명사와 명사를 연결해요",
          "pattern": "Noun + 하고 + Noun",
          "meaning": "and (connecting nouns)",
          "description": "'하고' connects two nouns meaning 'and'. '와' (after vowel) and '과' (after consonant) are more formal alternatives. In everyday speech, '하고' is most common.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "하고 (casual — most common)",
              "examples": [
                "빵하고 우유를 사요.",
                "엄마하고 동생이 있어요.",
                "필통하고 연필을 사요."
              ]
            },
            {
              "color": "blue",
              "label": "와 (after vowel) / 과 (after consonant) — formal",
              "examples": [
                "너하고 나 → 너와 나",
                "리암하고 리아 → 리암과 리아",
                "엄마하고 동생 → 엄마와 동생"
              ]
            }
          ],
          "examples": [
            {
              "korean": "집에 누가 있어요?",
              "english": "Who is at home?",
              "highlight": "누가"
            },
            {
              "korean": "엄마하고 동생이 있어요.",
              "english": "My mom and younger sibling are there.",
              "highlight": "하고"
            },
            {
              "korean": "뭘 사요?",
              "english": "What are you buying?",
              "highlight": ""
            },
            {
              "korean": "빵하고 우유를 사요.",
              "english": "I'm buying bread and milk.",
              "highlight": "하고"
            },
            {
              "korean": "수지 씨는 신발하고 옷을 사요.",
              "english": "Suji is buying shoes and clothes.",
              "highlight": "하고"
            }
          ],
          "key_points": [
            {
              "title": "누구 + 가 → 누가",
              "note": "'누구' (who) + subject marker '가' contracts to '누가'. This is a common irregular combination.",
              "examples": [
                {
                  "formal": "누구 + 가",
                  "result": "누가",
                  "english": "who (subject)"
                },
                {
                  "sentence": "교실에 누가 있어요?",
                  "english": "Who is in the classroom?"
                }
              ]
            },
            {
              "title": "무엇 + 이 → 뭐가",
              "note": "'무엇' (what) + '이' → '뭐가' in casual speech. The object marker '무엇을' becomes '뭘'.",
              "examples": [
                {
                  "formal": "무엇이 있어요?",
                  "casual": "뭐가 있어요?",
                  "english": "What is there?"
                },
                {
                  "formal": "무엇을 사요?",
                  "casual": "뭘 사요?",
                  "english": "What are you buying?"
                }
              ]
            }
          ],
          "qna": [
            {
              "question": "집에 누가 있어요?",
              "answer": "엄마하고 아빠가 있어요."
            },
            {
              "question": "뭘 사요?",
              "answer": "사과하고 우유를 사요."
            },
            {
              "question": "교실에 뭐가 있어요?",
              "answer": "책상하고 의자가 있어요."
            }
          ]
        }
      ]
    },
