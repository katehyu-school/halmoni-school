    "grammar": {
      "sections": [
        {
          "id": "g04_a_eo_yo",
          "title": "-아요/어요",
          "subtitle": "동사·형용사 뒤에 붙어서 동작이나 상태를 나타내요",
          "pattern": "Verb/Adj stem + 아요/어요",
          "meaning": "present tense ending",
          "description": "Attach to verb or adjective stems. Stems with ㅏ or ㅗ → 아요. All others → 어요. 하다 verbs → 해요.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "ㅏ / ㅗ 로 끝나면 → 아요",
              "examples": [
                "가다 → 가요",
                "살다 → 살아요",
                "보다 → 봐요",
                "만나다 → 만나요"
              ]
            },
            {
              "color": "blue",
              "label": "그 외 → 어요",
              "examples": [
                "먹다 → 먹어요",
                "읽다 → 읽어요",
                "맛있다 → 맛있어요",
                "*듣다 → 들어요 (불규칙)"
              ]
            },
            {
              "color": "green",
              "label": "하다 동사 → 해요",
              "examples": [
                "일하다 → 일해요",
                "요리하다 → 요리해요",
                "공부하다 → 공부해요"
              ]
            }
          ],
          "conjugation_table": [
            {
              "base": "가다",
              "stem": "가",
              "rule": "ㅏ → 아요",
              "result": "가요"
            },
            {
              "base": "보다",
              "stem": "보",
              "rule": "ㅗ → 아요",
              "result": "봐요"
            },
            {
              "base": "만나다",
              "stem": "만나",
              "rule": "ㅏ → 아요",
              "result": "만나요"
            },
            {
              "base": "먹다",
              "stem": "먹",
              "rule": "→ 어요",
              "result": "먹어요"
            },
            {
              "base": "읽다",
              "stem": "읽",
              "rule": "→ 어요",
              "result": "읽어요"
            },
            {
              "base": "맛있다",
              "stem": "맛있",
              "rule": "→ 어요",
              "result": "맛있어요"
            },
            {
              "base": "듣다",
              "stem": "들",
              "rule": "불규칙 → 어요",
              "result": "들어요"
            },
            {
              "base": "공부하다",
              "stem": "공부",
              "rule": "하다 → 해요",
              "result": "공부해요"
            }
          ],
          "examples": [
            {
              "korean": "오늘 친구 만나요.",
              "english": "I'm meeting a friend today.",
              "highlight": "만나요"
            },
            {
              "korean": "동생은 자요.",
              "english": "My younger sibling is sleeping.",
              "highlight": "자요"
            },
            {
              "korean": "저는 빵 먹어요.",
              "english": "I'm eating bread.",
              "highlight": "먹어요"
            },
            {
              "korean": "책 읽어요.",
              "english": "I'm reading a book.",
              "highlight": "읽어요"
            },
            {
              "korean": "주노 씨는 매일 요리해요.",
              "english": "Juno cooks every day.",
              "highlight": "요리해요"
            },
            {
              "korean": "불고기 맛있어요.",
              "english": "The bulgogi is delicious.",
              "highlight": "맛있어요"
            }
          ],
          "qna": [
            {
              "question": "오늘 무엇을 해요?",
              "answer": "친구 만나요."
            },
            {
              "question": "지금 뭐 해요?",
              "answer": "한국어 공부해요."
            },
            {
              "question": "불고기 맛있어요?",
              "answer": "네, 정말 맛있어요."
            }
          ]
        },
        {
          "id": "g04_eul_reul",
          "title": "을/를",
          "subtitle": "명사 뒤에 붙어서 목적어를 나타내요",
          "pattern": "Noun + 을/를",
          "meaning": "object marker",
          "description": "Attach 을/를 after a noun to mark it as the object of the sentence. 받침 있음 → 을, 받침 없음 → 를.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "받침 있음 (consonant ending) → 을",
              "examples": [
                "책 → 책을",
                "꽃 → 꽃을",
                "게임 → 게임을"
              ]
            },
            {
              "color": "blue",
              "label": "받침 없음 (vowel ending) → 를",
              "examples": [
                "영화 → 영화를",
                "친구 → 친구를",
                "불고기 → 불고기를",
                "한국어 → 한국어를"
              ]
            }
          ],
          "examples": [
            {
              "korean": "책을 읽어요.",
              "english": "I'm reading a book.",
              "highlight": "을"
            },
            {
              "korean": "음악을 들어요.",
              "english": "I'm listening to music.",
              "highlight": "을"
            },
            {
              "korean": "한국 영화를 좋아해요.",
              "english": "I like Korean movies.",
              "highlight": "를"
            },
            {
              "korean": "물을 마셔요.",
              "english": "I'm drinking water.",
              "highlight": "을"
            },
            {
              "korean": "텔레비전을 봐요.",
              "english": "I'm watching TV.",
              "highlight": "을"
            },
            {
              "korean": "노래를 들어요.",
              "english": "I'm listening to a song.",
              "highlight": "를"
            }
          ],
          "qna": [
            {
              "question": "오늘 무엇을 해요?",
              "answer": "책을 읽어요."
            },
            {
              "question": "무엇을 좋아해요?",
              "answer": "한국 영화를 좋아해요."
            }
          ]
        }
      ]
    },
