    "pronunciation": {
      "sections": [
        {
          "id": "pron04_01",
          "title": "억양 — Intonation",
          "rule": "Questions rise ↗, statements fall ↘",
          "rule_ko": "In questions, we say the end of a sentence in a rising tone and other than that, in a falling tone.",
          "examples": [
            {
              "korean": "공부해요?",
              "intonation": "↗",
              "note": "question — rising tone"
            },
            {
              "korean": "공부해요.",
              "intonation": "↘",
              "note": "statement — falling tone"
            },
            {
              "korean": "책을 읽어요?",
              "intonation": "↗",
              "note": "question"
            },
            {
              "korean": "네, 책을 읽어요.",
              "intonation": "↘",
              "note": "answer"
            }
          ]
        },
        {
          "id": "pron04_02",
          "title": "연음 — Liaison",
          "rule": "받침 ㄱ + ㄴ/ㄹ/ㅁ/ㅇ → ㅇ으로 발음",
          "rule_en": "Final consonant ㄱ followed by ㄴ, ㄹ, ㅁ, or ㅇ is pronounced as ㅇ",
          "examples": [
            {
              "written": "한국어",
              "pronounced": "한구거",
              "romanization": "han-gu-geo"
            },
            {
              "written": "한국말",
              "pronounced": "한궁말",
              "romanization": "han-gung-mal"
            }
          ]
        }
      ]
    },
    "key_points": [
      {
        "id": "kp04_01",
        "title": "무엇 → 뭐",
        "note": "In everyday speech, '무엇' is often replaced with '뭐'. '무엇을' → '뭘' or '뭐'.",
        "examples": [
          {
            "formal": "무엇을 해요?",
            "casual": "뭘 해요? / 뭐 해요?",
            "english": "What are you doing?"
          },
          {
            "formal": "무엇을 먹어요?",
            "casual": "뭘 먹어요? / 뭐 먹어요?",
            "english": "What are you eating?"
          }
        ]
      }
    ],
    "practice": {
      "quiz_items": [
        {
          "id": "q04_01",
          "type": "multiple_choice",
          "question": "Choose the correct object marker.",
          "sentence": "저는 한국 영화___ 좋아해요.",
          "choices": [
            "을",
            "를",
            "이",
            "가"
          ],
          "answer": "를",
          "explanation": "영화 ends with a vowel (no final consonant), so use '를'."
        },
        {
          "id": "q04_02",
          "type": "multiple_choice",
          "question": "Choose the correct object marker.",
          "sentence": "저는 책___ 읽어요.",
          "choices": [
            "을",
            "를",
            "이",
            "가"
          ],
          "answer": "을",
          "explanation": "책 ends with a final consonant (ㄱ), so use '을'."
        },
        {
          "id": "q04_03",
          "type": "conjugation",
          "question": "Conjugate into the present tense (해요 form).",
          "base": "먹다",
          "answer": "먹어요",
          "hint": "stem ends with ㄱ → 어요"
        },
        {
          "id": "q04_04",
          "type": "conjugation",
          "question": "Conjugate into the present tense (해요 form).",
          "base": "공부하다",
          "answer": "공부해요",
          "hint": "하다 verbs → 해요"
        },
        {
          "id": "q04_05",
          "type": "multiple_choice",
          "question": "Complete the conversation.",
          "sentence": "가: 오늘 뭐 해요?\n나: ___.",
          "choices": [
            "친구를 만나요",
            "친구가 만나요",
            "친구를 만나",
            "친구이 만나요"
          ],
          "answer": "친구를 만나요",
          "explanation": "친구 ends with a vowel, so use '를'. The verb needs the polite ending → 만나요."
        },
        {
          "id": "q04_06",
          "type": "multiple_choice",
          "question": "Which has the same meaning as '무엇을 해요?'",
          "choices": [
            "뭐 해요?",
            "무슨 해요?",
            "무엇이 해요?",
            "뭐가 해요?"
          ],
          "answer": "뭐 해요?",
          "explanation": "무엇 (formal) = 뭐 (casual). 무엇을 해요? → 뭐 해요? (object marker dropped in casual speech)"
        },
        {
          "id": "q04_07",
          "type": "multiple_choice",
          "question": "Which is the correct pronunciation?",
          "sentence": "한국어",
          "choices": [
            "한국어",
            "한구거",
            "항국어",
            "한국여"
          ],
          "answer": "한구거",
          "explanation": "Liaison rule: final consonant ㄱ links to the next vowel → 한국어 is pronounced '한구거'."
        },
        {
          "id": "q04_08",
          "type": "multiple_choice",
          "question": "Choose the correct object marker.",
          "sentence": "저는 음악___ 들어요.",
          "choices": [
            "을",
            "를",
            "이",
            "가"
          ],
          "answer": "을",
          "explanation": "음악 ends with a final consonant (ㄱ), so use '을'."
        }
      ]
    },
