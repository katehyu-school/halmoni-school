    "grammar": {
      "sections": [
        {
          "id": "g01_ieyo",
          "title": "N이에요 / 예요",
          "subtitle": "'to be' — identifying what something/someone is",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 있음 (consonant ending) → 이에요",
              "examples": [
                "학생이에요 (I'm a student)",
                "선생님이에요 (I'm a teacher)",
                "한국 사람이에요 (I'm Korean)"
              ]
            },
            {
              "color": "blue",
              "label": "받침 없음 (vowel ending) → 예요",
              "examples": [
                "의사예요 (I'm a doctor)",
                "가수예요 (I'm a singer)",
                "안나예요 (I'm Anna)"
              ]
            },
            {
              "color": "amber",
              "label": "부정: N이/가 아니에요 (I'm not N)",
              "examples": [
                "학생이 아니에요 (I'm not a student)",
                "의사가 아니에요 (I'm not a doctor)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "저는 안나예요.",
              "english": "I'm Anna."
            },
            {
              "korean": "저는 학생이에요.",
              "english": "I'm a student."
            },
            {
              "korean": "저는 한국 사람이 아니에요.",
              "english": "I'm not Korean."
            }
          ]
        },
        {
          "id": "g01_eunneun",
          "title": "N은 / 는",
          "subtitle": "Topic marker — 'as for N' / 'speaking of N'",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 있음 → 은",
              "examples": [
                "이름은 (as for the name)",
                "학생은 (as for students)"
              ]
            },
            {
              "color": "blue",
              "label": "받침 없음 → 는",
              "examples": [
                "저는 (as for me)",
                "의사는 (as for doctors)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "저는 안나예요.",
              "english": "I'm Anna. (topic: me)"
            },
            {
              "korean": "이름은 뭐예요?",
              "english": "What's your name? (topic: name)"
            }
          ]
        }
      ]
    },
    "key_points": [
      {
        "ko": "받침이 있으면 '이에요', 없으면 '예요'를 써요.",
        "en": "Use 이에요 after a consonant, 예요 after a vowel."
      },
      {
        "ko": "'저는'은 격식체, '나는'은 반말 (casual). 수업에서는 '저는'을 쓰세요.",
        "en": "저는 is formal; 나는 is casual. Use 저는 in class."
      }
    ],
    "practice": {
      "quiz_items": [
        {
          "id": "q01_01",
          "type": "multiple_choice",
          "question": "Fill in the blank: 저___ 안나예요.",
          "choices": [
            "은",
            "는",
            "이",
            "가"
          ],
          "answer": "는",
          "explanation": "저 ends in a vowel → 는. (Topic marker: vowel → 는)"
        },
        {
          "id": "q01_02",
          "type": "multiple_choice",
          "question": "In '저는 의사예요', why '예요' not '이에요'?",
          "choices": [
            "의사 is a respected job",
            "의사 ends in a vowel",
            "예요 is more polite",
            "의 ends in a vowel"
          ],
          "answer": "의사 ends in a vowel",
          "explanation": "Last syllable '사' ends in a vowel → 예요."
        },
        {
          "id": "q01_03",
          "type": "multiple_choice",
          "question": "Which word needs '이에요'?",
          "choices": [
            "의사",
            "가수",
            "요리사",
            "학생"
          ],
          "answer": "학생",
          "explanation": "학생 ends in ㅇ (consonant) → 이에요."
        },
        {
          "id": "q01_04",
          "type": "multiple_choice",
          "question": "Fill in: '제 이름___ 안나예요.'",
          "choices": [
            "이",
            "가",
            "은",
            "를"
          ],
          "answer": "은",
          "explanation": "이름 ends in ㅁ → 은."
        },
        {
          "id": "q01_05",
          "type": "multiple_choice",
          "question": "Most natural self-introduction order?",
          "choices": [
            "저는 학생이에요. 안녕하세요! 저는 안나예요.",
            "안녕하세요! 저는 안나예요. 저는 학생이에요.",
            "저는 안나예요. 안녕하세요! 저는 학생이에요.",
            "학생이에요. 안나예요. 안녕하세요!"
          ],
          "answer": "안녕하세요! 저는 안나예요. 저는 학생이에요.",
          "explanation": "Greeting → name → job/country is the natural order."
        }
      ]
    },
    "self_check": [
