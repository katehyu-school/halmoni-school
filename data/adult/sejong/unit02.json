    "grammar": {
      "sections": [
        {
          "id": "g02_iga",
          "title": "N이 / 가",
          "subtitle": "Subject marker — marks the grammatical subject",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "받침 있음 → 이",
              "examples": [
                "이름이 (name-SUBJ)",
                "학생이 (student-SUBJ)"
              ]
            },
            {
              "color": "blue",
              "label": "받침 없음 → 가",
              "examples": [
                "의사가 (doctor-SUBJ)",
                "전화번호가 (phone number-SUBJ)"
              ]
            },
            {
              "color": "teal",
              "label": "'이/가 아니에요' = negative identity (I'm not N)",
              "examples": [
                "학생이 아니에요 (not a student)",
                "전화번호가 아니에요 (not the phone number)"
              ]
            }
          ],
          "examples": [
            {
              "korean": "전화번호가 뭐예요?",
              "english": "What is the phone number?"
            },
            {
              "korean": "저는 학생이 아니에요.",
              "english": "I'm not a student."
            },
            {
              "korean": "이름이 뭐예요?",
              "english": "What is your name?",
              "highlight": "이"
            }
          ]
        },
        {
          "id": "g02_numbers",
          "title": "숫자 읽기 (Sino-Korean)",
          "subtitle": "Numbers used for phone numbers, addresses, prices",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "0~9: 공/영, 일, 이, 삼, 사, 오, 육, 칠, 팔, 구"
            },
            {
              "color": "amber",
              "label": "전화번호에서 0 → 공. 예: 010 → 공일공",
              "examples": [
                "010-1234-5678 → 공일공 일이삼사 오육칠팔"
              ]
            },
            {
              "color": "coral",
              "label": "⚠️ 십육 [심뉵] — 받침 ㅂ이 ㄴ 앞에서 ㅁ으로 비음화!",
              "examples": [
                "16 → 십육 → [심뉵]"
              ]
            }
          ],
          "examples": [
            {
              "korean": "전화번호가 뭐예요?",
              "english": "What's your phone number?"
            },
            {
              "korean": "제 전화번호는 010-1234-5678이에요.",
              "english": "My phone number is 010-1234-5678."
            }
          ]
        }
      ]
    },
    "key_points": [
      {
        "ko": "이/가는 주어 표지, 은/는은 주제 표지 — 뉘앙스가 달라요!",
        "en": "이/가 = subject marker; 은/는 = topic marker — they carry different nuances."
      },
      {
        "ko": "'이/가 아니에요'의 이/가는 보어 표지예요 (subject marker가 아님!).",
        "en": "이/가 in 'N이/가 아니에요' is a complement marker, not a subject marker."
      },
      {
        "ko": "전화번호에서 0은 항상 '공'으로 읽어요.",
        "en": "0 in phone numbers is always read as '공'."
      }
    ],
    "practice": {
      "quiz_items": [
        {
          "id": "q02_01",
          "type": "multiple_choice",
          "question": "Fill in: '전화번호___ 뭐예요?'",
          "choices": [
            "은",
            "는",
            "이",
            "가"
          ],
          "answer": "가",
          "explanation": "전화번호 ends in a vowel → 가."
        },
        {
          "id": "q02_02",
          "type": "multiple_choice",
          "question": "Fill in: '저는 학생___ 아니에요.'",
          "choices": [
            "는",
            "가",
            "이",
            "을"
          ],
          "answer": "이",
          "explanation": "학생 ends in ㅇ → 이. '이/가 아니에요' = negative form."
        },
        {
          "id": "q02_03",
          "type": "multiple_choice",
          "question": "How do you pronounce 16 (십육)?",
          "choices": [
            "십육",
            "시뷱",
            "심뉵",
            "시육"
          ],
          "answer": "심뉵",
          "explanation": "십육 → nasalization → [심뉵]."
        },
        {
          "id": "q02_04",
          "type": "multiple_choice",
          "question": "What kind of marker is 이/가 in '이/가 아니에요'?",
          "choices": [
            "Subject marker",
            "Complement marker",
            "Object marker",
            "Location marker"
          ],
          "answer": "Complement marker",
          "explanation": "Here 이/가 is the complement marker, not the subject marker!"
        },
        {
          "id": "q02_05",
          "type": "multiple_choice",
          "question": "How do you read '0' in a phone number?",
          "choices": [
            "오",
            "이",
            "영 or 공",
            "일"
          ],
          "answer": "영 or 공",
          "explanation": "0 in a phone number → '공'. e.g. 010 → 공일공."
        }
      ]
    },
    "self_check": [
      {
        "ko": "N이/가와 N은/는의 차이를 설명할 수 있어요?",
        "en": "Can you explain the difference between 이/가 and 은/는?"
      },
      {
        "ko": "전화번호를 한국어로 말할 수 있어요?",
        "en": "Can you say a phone number in Korean?"
      }
    ]
  }
