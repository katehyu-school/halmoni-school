    "grammar": {
      "sections": [
        {
          "id": "g09_eseo",
          "title": "N에서",
          "subtitle": "Location particle — where an action happens",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "N에서 = 'at / in / from' — used when an action takes place at a location"
            },
            {
              "color": "green",
              "label": "N에 있어요 = something EXISTS at a location\nN에서 해요 = an action HAPPENS at a location"
            }
          ],
          "examples": [
            {
              "korean": "공원에서 자전거를 타요.",
              "english": "I ride a bicycle in the park."
            },
            {
              "korean": "도서관에서 책을 읽어요.",
              "english": "I read books at the library."
            },
            {
              "korean": "집에서 쉬었어요.",
              "english": "I rested at home."
            },
            {
              "korean": "회사에서 일해요.",
              "english": "I work at the company."
            }
          ]
        },
        {
          "id": "g09_past",
          "title": "-았/었어요",
          "subtitle": "Past tense — describing completed actions or states",
          "rule_boxes": [
            {
              "color": "blue",
              "label": "어간의 마지막 모음이 ㅏ 또는 ㅗ → 았어요\nLast vowel of stem is ㅏ or ㅗ → 았어요"
            },
            {
              "color": "blue",
              "label": "그 외 (other vowels) → 었어요"
            },
            {
              "color": "teal",
              "label": "하다 → 하 + 였어요 → 했어요 (contracted)"
            },
            {
              "color": "amber",
              "label": "ㅂ 불규칙: 덥다 → 더 + 웠어요 → 더웠어요\nㅡ 탈락: 바쁘다 → 바ㅃ + 았어요 → 바빴어요"
            }
          ],
          "conjugation_table": {
            "rows": [
              {
                "base": "가다",
                "stem": "가",
                "rule": "ㅏ → 았",
                "result": "갔어요"
              },
              {
                "base": "오다",
                "stem": "오",
                "rule": "ㅗ → 았",
                "result": "왔어요"
              },
              {
                "base": "보다",
                "stem": "보",
                "rule": "ㅗ → 았",
                "result": "봤어요"
              },
              {
                "base": "살다",
                "stem": "살",
                "rule": "ㅏ → 았",
                "result": "살았어요"
              },
              {
                "base": "먹다",
                "stem": "먹",
                "rule": "→ 었",
                "result": "먹었어요"
              },
              {
                "base": "읽다",
                "stem": "읽",
                "rule": "→ 었",
                "result": "읽었어요"
              },
              {
                "base": "있다",
                "stem": "있",
                "rule": "→ 었",
                "result": "있었어요"
              },
              {
                "base": "없다",
                "stem": "없",
                "rule": "→ 었",
                "result": "없었어요"
              },
              {
