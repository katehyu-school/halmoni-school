    "key_points": [
      {
        "id": "kp07_01",
        "title": "시간 읽기 — 고유어 vs 한자어",
        "note": "시 (hours): native Korean numbers (only 12 hours, easy to count). 분 (minutes): sino-Korean numbers (up to 60, larger range).",
        "examples": [
          {
