    "grammar": {
      "sections": [
        {
          "id": "g07_e",
          "title": "N에 — 시간 조사",
          "subtitle": "동작이 일어나는 시간을 나타낼 때 써요",
          "pattern": "시간 명사 + 에",
          "meaning": "at / on [time]",
          "description": "Attach 에 to a time expression to say when something happens. Use it with hours, days of the week, dates, and months — but NOT with 오늘, 내일, 어제, or 언제.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "에 사용 — 시각·요일·날짜·월",
              "examples": [
                "일곱 시에 시작해요. (starts at 7)",
                "월요일에 수업이 있어요. (class on Monday)",
                "시월 오일에 생일이에요. (birthday on Oct 5)",
                "삼월에 한국에 가요. (going to Korea in March)"
              ]
            },
            {
              "color": "blue",
              "label": "에 없음 ❌ — 오늘·내일·어제·언제·주말",
              "examples": [
                "오늘 뭐 해요? (not 오늘에)",
                "내일 만나요. (not 내일에)",
                "언제 와요? (not 언제에)",
                "주말에 ✅ — 주말은 예외! 에 사용"
              ]
            }
          ],
          "examples": [
            {
              "korean": "몇 시에 일어나요?",
              "english": "What time do you wake up?",
              "highlight": "에"
            },
            {
              "korean": "여섯 시에 일어나요.",
              "english": "I wake up at 6 o'clock.",
              "highlight": "에"
            },
            {
              "korean": "수요일에 한국어 수업이 있어요.",
              "english": "I have Korean class on Wednesday.",
              "highlight": "에"
            },
            {
              "korean": "생일이 언제예요?",
              "english": "When is your birthday?",
              "highlight": "언제"
            },
            {
              "korean": "시월 오일이에요.",
              "english": "It's October 5th.",
              "highlight": "시월 오일"
            },
            {
              "korean": "주말에 친구를 만나요.",
              "english": "I meet friends on the weekend.",
              "highlight": "에"
            }
          ],
          "qna": [
            {
              "question": "몇 시에 자요?",
              "answer": "열두 시에 자요."
            },
            {
              "question": "한국어 수업이 언제 있어요?",
              "answer": "화요일하고 목요일에 있어요."
            },
            {
              "question": "생일이 언제예요?",
              "answer": "오월 십오일이에요."
            }
          ]
        },
        {
          "id": "g07_time",
          "title": "몇 시예요? — 시간 읽기",
          "subtitle": "시(hour)는 고유어, 분(minute)은 한자어로 읽어요",
          "pattern": "[고유어]시 [한자어]분",
          "meaning": "telling the time",
          "description": "Korean uses two number systems for time. For hours (시), use native Korean numbers (한, 두, 세...) because there are only 12 hours — easy to count. For minutes (분), use sino-Korean numbers (일, 이, 삼...) because minutes go up to 60.",
          "rule_boxes": [
            {
              "color": "red",
              "label": "시 (hour) → 고유어",
              "examples": [
                "한 시 (1:00)　두 시 (2:00)　세 시 (3:00)",
                "네 시 (4:00)　다섯 시 (5:00)　여섯 시 (6:00)",
                "일곱 시 (7:00)　여덟 시 (8:00)　아홉 시 (9:00)",
                "열 시 (10:00)　열한 시 (11:00)　열두 시 (12:00)"
              ]
            },
            {
              "color": "blue",
              "label": "분 (minute) → 한자어",
              "examples": [
                "십 분 (10 min)　이십 분 (20 min)",
                "삼십 분 (30 min) = 반 (half)",
                "사십오 분 (45 min)　오십 분 (50 min)"
              ]
            },
            {
              "color": "green",
              "label": "오전 / 오후 + 시간",
              "examples": [
                "오전 아홉 시 (9:00 AM)",
                "오후 두 시 삼십 분 (2:30 PM)",
                "오후 일곱 시 반 (7:30 PM)"
              ]
            }
          ],
          "number_forms": [
            {
              "base": "1:00",
              "short": "한 시",
              "examples": [
                "오전 한 시",
                "새벽 한 시"
              ]
            },
            {
              "base": "3:30",
              "short": "세 시 반",
              "examples": [
                "세 시 삼십 분",
                "세 시 반"
              ]
            },
            {
              "base": "7:00",
              "short": "일곱 시",
              "examples": [
                "오후 일곱 시",
                "저녁 일곱 시"
              ]
            },
            {
              "base": "12:00",
              "short": "열두 시",
              "examples": [
                "낮 열두 시",
                "밤 열두 시"
              ]
            }
          ],
          "examples": [
            {
              "korean": "지금 몇 시예요?",
              "english": "What time is it now?",
              "highlight": "몇 시"
            },
            {
              "korean": "오후 일곱 시 삼십 분이에요.",
              "english": "It's 7:30 PM.",
              "highlight": "일곱 시 삼십 분"
            },
            {
              "korean": "수업이 몇 시에 시작해요?",
              "english": "What time does class start?",
              "highlight": "몇 시에"
            },
            {
              "korean": "열두 시에 점심을 먹어요.",
              "english": "I eat lunch at noon.",
              "highlight": "열두 시에"
            },
            {
              "korean": "아홉 시 반에 도착해요.",
              "english": "I arrive at 9:30.",
              "highlight": "아홉 시 반에"
            }
          ],
          "qna": [
            {
              "question": "지금 몇 시예요?",
              "answer": "오후 세 시 사십오 분이에요."
            },
            {
              "question": "수업이 몇 시에 끝나요?",
              "answer": "오후 다섯 시 삼십 분에 끝나요."
            }
          ]
        }
      ]
    },
    "dialogue": {
      "scenes": [
        {
          "id": "dlg07_01",
          "title": "생일이 언제예요?",
          "subtitle": "Asking about birthdays and special dates",
          "lines": [
            {
              "speaker": "마리",
              "korean": "재민 씨, 생일이 언제예요?",
              "english": "Jaemin, when is your birthday?"
            },
            {
              "speaker": "재민",
              "korean": "시월 이십삼일이에요. 마리 씨는요?",
              "english": "It's October 23rd. How about you, Marie?"
            },
            {
              "speaker": "마리",
              "korean": "저는 사월 오일이에요.",
              "english": "Mine is April 5th."
            },
            {
              "speaker": "재민",
              "korean": "사월 오일은 무슨 요일이에요?",
              "english": "What day of the week is April 5th?"
            },
            {
              "speaker": "마리",
              "korean": "올해는 토요일이에요!",
              "english": "This year it's a Saturday!"
            },
            {
              "speaker": "재민",
              "korean": "와, 좋겠다! 주말 생일이네요.",
              "english": "Oh nice! A weekend birthday."
            }
          ]
        },
        {
          "id": "dlg07_02",
          "title": "수업이 몇 시에 시작해요?",
          "subtitle": "Talking about schedules and times",
          "lines": [
            {
              "speaker": "안나",
              "korean": "유진 씨, 오늘 한국어 수업 있어요?",
              "english": "Yujin, do you have Korean class today?"
            },
            {
              "speaker": "유진",
              "korean": "네, 있어요. 오후 두 시에 시작해요.",
              "english": "Yes, I do. It starts at 2 PM."
            },
            {
              "speaker": "안나",
              "korean": "몇 시에 끝나요?",
              "english": "What time does it end?"
            },
            {
              "speaker": "유진",
              "korean": "네 시 반에 끝나요. 안나 씨는요?",
              "english": "It ends at 4:30. How about you, Anna?"
            },
            {
              "speaker": "안나",
              "korean": "저는 오전 열 시 수업이에요. 벌써 끝났어요.",
              "english": "My class is at 10 AM. It already finished."
            },
            {
              "speaker": "유진",
              "korean": "그래요? 그럼 수업 후에 같이 커피 마셔요!",
              "english": "Really? Then let's have coffee after my class!"
            },
            {
              "speaker": "안나",
              "korean": "좋아요! 네 시 반에 카페에서 만나요.",
              "english": "Sounds good! Let's meet at the café at 4:30."
            }
          ]
        },
        {
          "id": "dlg07_03",
          "title": "주말 계획",
          "subtitle": "Making weekend plans using time expressions",
          "lines": [
            {
              "speaker": "선생님",
              "korean": "여러분, 이번 주말에 뭐 해요?",
              "english": "Everyone, what are you doing this weekend?"
            },
            {
              "speaker": "재민",
              "korean": "저는 토요일 오전에 운동해요. 오후에는 친구를 만나요.",
              "english": "I exercise Saturday morning. In the afternoon I'm meeting a friend."
            },
            {
              "speaker": "선생님",
              "korean": "몇 시에 친구를 만나요?",
              "english": "What time are you meeting your friend?"
            },
            {
              "speaker": "재민",
              "korean": "두 시에 만나요.",
              "english": "At 2 o'clock."
            },
            {
              "speaker": "선생님",
              "korean": "안나 씨는요?",
              "english": "How about you, Anna?"
            },
            {
              "speaker": "안나",
              "korean": "저는 일요일에 집에 있어요. 한국 드라마 봐요!",
              "english": "I'll be home on Sunday. I'm watching Korean dramas!"
            }
          ]
        }
      ]
    },
    "pronunciation": {
      "sections": [
        {
          "id": "pron07_01",
          "title": "유월 & 시월 — 불규칙 발음",
          "rule_en": "6월 and 10월 have irregular pronunciations. The final consonant is dropped before 월 to make pronunciation smoother.",
          "rule_ko": "발음을 매끄럽고 편하게 하기 위해 받침을 떼어 내요. 육월(X) → 유월(O), 십월(X) → 시월(O). 단, 육일(O), 십일(O)은 그대로예요.",
          "examples": [
